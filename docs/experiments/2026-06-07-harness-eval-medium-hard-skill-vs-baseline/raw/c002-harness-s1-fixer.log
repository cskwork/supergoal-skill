{"type":"item.completed","item":{"id":"item_24","type":"command_execution","command":"/bin/zsh -lc \"perl -ne 'printf \\\"%4d %s\\\", \"'$., $_'\"' src/cache.mjs\"","aggregated_output":"   1 // AsyncCache memoizes async loader results by key.\n   2 export class AsyncCache {\n   3   constructor() {\n   4     this.values = new Map();\n   5     this.inflight = new Map();\n   6   }\n   7 \n   8   // Returns cached value for key, or loads + caches it via loader(key).\n   9   async get(key, loader) {\n  10     if (this.values.has(key)) {\n  11       return this.values.get(key);\n  12     }\n  13 \n  14     if (!this.inflight.has(key)) {\n  15       const load = (async () => {\n  16         const value = await loader(key);\n  17         if (this.inflight.get(key) === load) {\n  18           this.values.set(key, value);\n  19         }\n  20         return value;\n  21       })().finally(() => {\n  22         if (this.inflight.get(key) === load) {\n  23           this.inflight.delete(key);\n  24         }\n  25       });\n  26 \n  27       this.inflight.set(key, load);\n  28     }\n  29 \n  30     return this.inflight.get(key);\n  31   }\n  32 \n  33   has(key) {\n  34     return this.values.has(key);\n  35   }\n  36 \n  37   clear() {\n  38     this.values.clear();\n  39     this.inflight.clear();\n  40   }\n  41 }\n  42 \n  43 export default AsyncCache;\n","exit_code":0,"status":"completed"}}
