 export function applyPatch(document, operations) {
+  if (!Array.isArray(operations)) {
+    throw new TypeError('operations must be an array');
+  }
+
+  let target = clone(document);
+
+  for (const operation of operations) {
+    target = applyOperation(target, operation);
+  }
+
+  return target;
+}
+
+function applyOperation(document, operation) {
+  if (!operation || typeof operation !== 'object' || typeof operation.op !== 'string') {
+    throw new TypeError('invalid operation');
+  }
+
+  switch (operation.op) {
+    case 'add':
+      requirePath(operation);
+      return addValue(document, operation.path, clone(operation.value));
+    case 'remove':
+      requirePath(operation);
+      return removeValue(document, operation.path);
+    case 'replace':
+      requirePath(operation);
+      return replaceValue(document, operation.path, clone(operation.value));
+    case 'test':
+      requirePath(operation);
+      if (!deepEqual(getValue(document, operation.path), operation.value)) {
