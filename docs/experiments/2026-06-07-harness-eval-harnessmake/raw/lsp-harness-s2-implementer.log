seIndex };\n   120\t}\n   121\t\n   122\tfunction tokenAt(lineText, column) {\n   123\t  if (!lineText) {\n   124\t    return null;\n   125\t  }\n   126\t\n   127\t  if (!/[A-Za-z_]/.test(lineText[column] || '')) {\n   128\t    return null;\n   129\t  }\n   130\t\n   131\t  let start = column;\n   132\t  while (start > 0 && /[A-Za-z0-9_]/.test(lineText[start - 1])) {\n   133\t    start -= 1;\n   134\t  }\n   135\t\n   136\t  let end = column;\n   137\t  while (end < lineText.length && /[A-Za-z0-9_]/.test(lineText[end])) {\n   138\t    end += 1;\n   139\t  }\n   140\t\n   141\t  if (start === end) {\n   142\t    return null;\n   143\t  }\n   144\t\n   145\t  return {\n   146\t    name: lineText.slice(start, end),\n   147\t    start,\n   148\t    end\n   149\t  };\n   150\t}\n   151\t\n   152\texport function parseMiniLang(text) {\n   153\t  const lines = text.split('\\n');\n   154\t  const diagnostics = [];\n   155\t  const symbols = [];\n   156\t  const declarationTokens = new Set();\n   157\t  const scopes = [\n   158\t    {\n   159\t      id: 'global',\n   160\t      startLine: 0,\n   161\t      endLine: Infinity,\n   162\t      depth: 0,\n   163\t      symbols: new Map()\n   164\t    }\n   165\t  ];\n   166\t  const activeScopes = [scopes[0]];\n   167\t\n   168\t  let depth = 0;\n   169\t\n   170\t  for (let line = 0; line < lines.length; line += 1) {\n   171\t    const lineText = lines[line];\n   172\t\n   173\t    const fnMatch = lineText.match(/^\\s*fn\\s+([A-Za-z_]\\w*)\\s*\\(([^)]*)\\)\\s*(\\{)?/);\n   174\t    const currentScope = activeScopes[activeScopes.length - 1];\n   175\t\n   176\t    if (fnMatch) {\n   177\t      const name = fnMatch[1];\n   178\t      const params = parseParams(fnMatch[2] || '');\n   179\t      const nameIndex = lineText.indexOf(name);\n   180\t      const fnSymbol = {\n   181\t        kind: 'function',\n   182\t        name,\n   183\t        range: makeRange(lineText, line, nameIndex, name),\n   184\t        params,\n   185\t        scopeId: `fn:${name}:${line}`,\n   186\t        declLine: line\n   187\t      };\n   188\t      currentScope.symbols.set(name, fnSymbol);\n   189\t      symbols.push(fnSymbol);\n   190\t      declarationTokens.add(symbolKey(line, nameIndex, nameIndex + name.length));\n   191\t\n   192\t      const functionScope = {\n   193\t        id: fnSymbol.scopeId,\n   194\t        startLine: line,\n   195\t        endLine: Infinity,\n   196\t        depth: depth + 1,\n   197\t        symbols: new Map()\n   198\t      };\n   199\t      scopes.push(functionScope);\n   200\t      activeScopes.push(functionScope);\n   201\t\n   202\t      let searchFrom = fnMatch[0].indexOf('(') + 1;\n   203\t      for (const param of params) {\n   204\t        const paramIndex = lineText.indexOf(param, searchFrom);\n   205\t        if (paramIndex !== -1) {\n   206\t          const paramSymbol = {\n   207\t            kind: 'variable',\n   208\t            name: param,\n   209\t            range: makeRange(lineText, line, paramIndex, param),\n   210\t            declLine: line,\n   211\t            scopeId: functionScope.id\n   212\t          };\n   213\t          functionScope.symbols.set(param, paramSymbol);\n   214\t          symbols.push(paramSymbol);\n   215\t          declarationTokens.add(symbolKey(line, paramIndex, paramIndex + param.length));\n   216\t          searchFrom = paramIndex + param.length;\n   217\t        }\n   218\t      }\n   219\t    }\n   220\t\n   221\t    const letMatch = lineText.match(/^\\s*let\\s+([A-Za-z_]\\w*)\\s*=/);\n   222\t    const activeScope = activeScopes[activeScopes.length - 1];\n   223\t    if (letMatch) {\n   224\t      const name = letMatch[1];\n   225\t      const nameIndex = lineText.indexOf(name);\n   226\t      const localSymbol = {\n   227\t        kind: 'variable',\n   228\t        name,\n   229\t        range: makeRange(lineText, line, nameIndex, name),\n   230\t        declLine: line,\n   231\t        scopeId: activeScope.id\n   232\t      };\n   233\t      activeScope.symbols.set(name, localSymbol);\n   234\t      symbols.push(localSymbol);\n   235\t      declarationTokens.add(symbolKey(line, nameIndex, nameIndex + name.length));\n   236\t    }\n   237\t\n   238\t    const identifierRE = /[A-Za-z_]\\w*/g;\n   239\t    const tokenCandidates = [...lineText.matchAll(identifierRE)];\n   240\t\n   241\t    for (const match of tokenCandidates) {\n   242\t      const token = match[0];\n   243\t      const index = match.index;\n   244\t\n   245\t      if (KEYWORDS.has(token)) {\n   246\t        continue;\n   247\t      }\n   248\t\n   249\t      const tokenStart = index;\n   250\t      const tokenEnd = index + token.length;\n   251\t      if (declarationTokens.has(symbolKey(line, tokenStart, tokenEnd))) {\n   252\t        continue;\n   253\t      }\n   254\t\n   255\t      const after = lineText.slice(tokenEnd);\n   256\t      const hasCall = /^\\s*\\(/.test(after);\n   257\t      const whitespace = /^\\s*/.exec(after)[0].length;\n   258\t      const openParenIndex = tokenEnd + whitespace;\n   259\t\n   260\t      let found = null;\n   261\t      for (let i = activeScopes.length - 1; i >= 0; i -= 1) {\n   262\t        if (activeScopes[i].symbols.has(token)) {\n   263\t          found = activeScopes[i].symbols.get(token);\n   264\t          break;\n   265\t        }\n   266\t      }\n   267\t\n   268\t      if (hasCall) {\n   269\t        const { count } = countCallArgs(lineText, openParenIndex);\n   270\t        if (count === null) {\n   271\t          continue;\n   272\t        }\n   273\t\n   274\t        if (!found || found.kind !== 'function') {\n   275\t          diagnostics.push(\n   276\t            makeDiagnostic(\n   277\t              lineText,\n   278\t              line,\n   279\t              match,\n   280\t              `Undefined symbol '${token}'`\n   281\t            )\n   282\t          );\n   283\t          continue;\n   284\t        }\n   285\t\n   286\t        if (count !== found.params.length) {\n   287\t          diagnostics.push(\n   288\t            makeDiagnostic(\n   289\t              lineText,\n   290\t              line,\n   291\t              match,\n   292\t              `Function '${token}' expects ${found.params.length} arguments but got ${count}`\n   293\t            )\n   294\t          );\n   295\t        }\n   296\t\n   297\t        continue;\n   298\t      }\n   299\t\n   300\t      if (!found) {\n   301\t        diagnostics.push(\n   302\t          makeDiagnostic(\n   303\t            lineText,\n   304\t            line,\n   305\t            match,\n   306\t            `Undefined symbol '${token}'`\n   307\t          )\n   308\t        );\n   309\t      }\n   310\t    }\n   311\t\n   312\t    const openCount = (lineText.match(/\\{/g) || []).length;\n   313\t    const closeCount = (lineText.match(/\\}/g) || []).length;\n   314\t    const nextDepth = depth + openCount - closeCount;\n   315\t    depth = nextDepth;\n   316\t\n   317\t    while (activeScopes.length > 1 && activeScopes[activeScopes.length - 1].depth > depth) {\n   318\t      const finishedScope = activeScopes.pop();\n   319\t      finishedScope.endLine = line;\n   320\t    }\n   321\t  }\n   322\t\n   323\t  for (const scope of scopes) {\n   324\t    if (scope.depth > 0 && scope.endLine === Infinity) {\n   325\t      scope.endLine = lines.length - 1;\n   326\t    }\n   327\t  }\n   328\t\n   329\t  return {\n   330\t    text,\n   331\t    diagnostics,\n   332\t    symbols,\n   333\t    scopes\n   334\t  };\n   335\t}\n   336\t\n   337\texport class MiniLangServer {\n   338\t  constructor() {\n   339\t    this.documents = new Map();\n   340\t    this.notifications = [];\n   341\t    this.shutdownRequested = false;\n   342\t  }\n   343\t\n   344\t  async handle(message) {\n   345\t    const { method, id } = message;\n   346\t\n   347\t    if (method === 'initialize') {\n   348\t      return {\n   349\t        jsonrpc: '2.0',\n   350\t        id,\n   351\t        result: {\n   352\t          capabilities: {\n   353\t            textDocumentSync: 2,\n   354\t            completionProvider: {},\n   355\t            definitionProvider: true,\n   356\t            hoverProvider: true\n   357\t          }\n   358\t        }\n   359\t      };\n   360\t    }\n   361\t\n   362\t    if (method === 'shutdown') {\n   363\t      this.shutdownRequested = true;\n   364\t      return {\n   365\t        jsonrpc: '2.0',\n   366\t        id,\n   367\t        result: null\n   368\t      };\n   369\t    }\n   370\t\n   371\t    if (method === 'exit') {\n   372\t      return null;\n   373\t    }\n   374\t\n   375\t    const uri = message.params?.textDocument?.uri;\n   376\t    if (!uri) {\n   377\t      return null;\n   378\t    }\n   379\t\n   380\t    if (method === 'textDocument/didOpen') {\n   381\t      const text = message.params.textDocument.text;\n   382\t      const parsed = parseMiniLang(text);\n   383\t      parsed.uri = uri;\n   384\t      this.documents.set(uri, { text, parsed });\n   385\t      this.notifications.push({\n   386\t        jsonrpc: '2.0',\n   387\t        method: 'textDocument/publishDiagnostics',\n   388\t        params: {\n   389\t          uri,\n   390\t          diagnostics: parsed.diagnostics\n   391\t        }\n   392\t      });\n   393\t      return null;\n   394\t    }\n   395\t\n   396\t    if (method === 'textDocument/didChange') {\n   397\t      const last = (message.params.contentChanges || []).at(-1);\n   398\t      const text = last?.text ?? this.documents.get(uri)?.text ?? '';\n   399\t      const parsed = parseMiniLang(text);\n   400\t      parsed.uri = uri;\n   401\t      this.documents.set(uri, { text, parsed });\n   402\t      this.notifications.push({\n   403\t        jsonrpc: '2.0',\n   404\t        method: 'textDocument/publishDiagnostics',\n   405\t        params: {\n   406\t          uri,\n   407\t          diagnostics: parsed.diagnostics\n   408\t        }\n   409\t      });\n   410\t      return null;\n   411\t    }\n   412\t\n   413\t    const stored = this.documents.get(uri);\n   414\t    if (!stored) {\n   415\t      return null;\n   416\t    }\n   417\t\n   418\t    if (method === 'textDocument/completion') {\n   419\t      const position = message.params.position;\n   420\t      return {\n   421\t        jsonrpc: '2.0',\n   422\t        id,\n   423\t        result: this._completion(stored.parsed, position)\n   424\t      };\n   425\t    }\n   426\t\n   427\t    if (method === 'textDocument/definition') {\n   428\t      const position = message.params.position;\n   429\t      return {\n   430\t        jsonrpc: '2.0',\n   431\t        id,\n   432\t        result: this._definition(stored.parsed, position)\n   433\t      };\n   434\t    }\n   435\t\n   436\t    if (method === 'textDocument/hover') {\n   437\t      const position = message.params.position;\n   438\t      return {\n   439\t        jsonrpc: '2.0',\n   440\t        id,\n   441\t        result: this._hover(stored.parsed, position)\n   442\t      };\n   443\t    }\n   444\t\n   445\t    return null;\n   446\t  }\n   447\t\n   448\t  takeNotifications() {\n   449\t    const out = this.notifications;\n   450\t    this.notifications = [];\n   451\t    return out;\n   452\t  }\n   453\t\n   454\t  getDiagnostics(uri) {\n   455\t    return this.documents.get(uri)?.parsed.diagnostics ?? [];\n   456\t  }\n   457\t\n   458\t  _scopesAtLine(parsed, line) {\n   459\t    return parsed.scopes\n   460\t      .filter((scope) => scope.startLine <= line && line <= scope.endLine)\n   461\t      .sort((a, b) => b.depth - a.depth);\n   462\t  }\n   463\t\n   464\t  _findSymbol(parsed, line, name) {\n   465\t    for (const scope of this._scopesAtLine(parsed, line)) {\n   466\t      if (scope.symbols.has(name)) {\n   467\t        return scope.symbols.get(name);\n   468\t      }\n   469\t    }\n   470\t    return null;\n   471\t  }\n   472\t\n   473\t  _completion(parsed, position) {\n   474\t    const lineText = parsed.text.split('\\n')[position.line] || '';\n   475\t    const line = position.line;\n   476\t    const scopes = this._scopesAtLine(parsed, line);\n   477\t    const byName = new Map();\n   478\t\n   479\t    const addKeyword = (name) => {\n   480\t      if (!byName.has(name)) {\n   481\t        byName.set(name, {\n   482\t          label: name,\n   483\t          kind: 14,\n   484\t          insertText: name,\n   485\t          insertTextFormat: 1\n   486\t        });\n   487\t      }\n   488\t    };\n   489\t    addKeyword('fn');\n   490\t    addKeyword('let');\n   491\t    addKeyword('return');\n   492\t\n   493\t    for (const scope of scopes) {\n   494\t      for (const symbol of scope.symbols.values()) {\n   495\t        if (byName.has(symbol.name)) {\n   496\t          continue;\n   497\t        }\n   498\t        if (symbol.kind === 'function') {\n   499\t          byName.set(symbol.name, {\n   500\t            label: symbol.name,\n   501\t            kind: 3,\n   502\t            insertText: `${symbol.name}(${symbol.params\n   503\t              .map((param, i) => `\\${${i + 1}:${param}}`)\n   504\t              .join(', ')})`,\n   505\t            insertTextFormat: 2,\n   506\t            detail: `fn ${symbol.name}(${symbol.params.join(', ')})`\n   507\t          });\n   508\t        } else {\n   509\t          byName.set(symbol.name, {\n   510\t            label: symbol.name,\n   511\t            kind: 6,\n   512\t            insertText: symbol.name,\n   513\t            insertTextFormat: 1\n   514\t          });\n   515\t        }\n   516\t      }\n   517\t    }\n   518\t\n   519\t    const visible = lineText ? [] : [];\n   520\t    return {\n   521\t      items: [...byName.values()],\n   522\t      isIncomplete: false,\n   523\t      lineText: visible\n   524\t    };\n   525\t  }\n   526\t\n   527\t  _definition(parsed, position) {\n   528\t    const lineText = parsed.text.split('\\n')[position.line] || '';\n   529\t    const current = tokenAt(lineText, position.character);\n   530\t    if (!current || !current.name) {\n   531\t      return null;\n   532\t    }\n   533\t\n   534\t    const symbol = this._findSymbol(parsed, position.line, current.name);\n   535\t    if (!symbol) {\n   536\t      return null;\n   537\t    }\n   538\t\n   539\t    return {\n   540\t      uri: parsed.uri,\n   541\t      range: symbol.range\n   542\t    };\n   543\t  }\n   544\t\n   545\t  _hover(parsed, position) {\n   546\t    const lineText = parsed.text.split('\\n')[position.line] || '';\n   547\t    const current = tokenAt(lineText, position.character);\n   548\t    if (!current || !current.name) {\n   549\t      return null;\n   550\t    }\n   551\t\n   552\t    const symbol = this._findSymbol(parsed, position.line, current.name);\n   553\t    if (!symbol) {\n   554\t      return null;\n   555\t    }\n   556\t\n   557\t    if (symbol.kind === 'function') {\n   558\t      return {\n   559\t        contents: `fn ${symbol.name}(${symbol.params.join(', ')})`\n   560\t      };\n   561\t    }\n   562\t\n   563\t    return {\n   564\t      contents: `${symbol.name}: ${symbol.kind}`\n   565\t    };\n   566\t  }\n   567\t}\n","exit_code":0,"status":"completed"}}
