{"type":"item.completed","item":{"id":"item_20","type":"command_execution","command":"/bin/zsh -lc \"node - <<'NODE'\nimport fs from 'node:fs';\nconst text=fs.readFileSync('test/lsp.visible.test.mjs','utf8');\ntext.split(/\\\\n/).forEach((line,i)=>console.log(\"'`${(i+1).toString().padStart(3,'\"'0')}|\"'${line}`));\nNODE'","aggregated_output":"001|import assert from 'node:assert/strict';\n002|import { test } from 'node:test';\n003|import { encodeMessage, MessageBuffer, MiniLangServer } from '../src/server.mjs';\n004|\n005|function request(method, params = {}, id = 1) {\n006|  return { jsonrpc: '2.0', id, method, params };\n007|}\n008|\n009|function notification(method, params = {}) {\n010|  return { jsonrpc: '2.0', method, params };\n011|}\n012|\n013|function textDocument(uri, text, version = 1) {\n014|  return { uri, languageId: 'minilang', version, text };\n015|}\n016|\n017|function itemsFrom(response) {\n018|  const result = response.result;\n019|  return Array.isArray(result) ? result : result.items;\n020|}\n021|\n022|function positionOf(text, line, needle, offset = 0) {\n023|  const lines = text.split('\\n');\n024|  const character = lines[line].indexOf(needle);\n025|  assert.notEqual(character, -1, `missing ${needle} on line ${line}`);\n026|  return { line, character: character + offset };\n027|}\n028|\n029|test('JSON-RPC transport frames and streams Content-Length messages', () => {\n030|  const message = { jsonrpc: '2.0', id: 7, result: { ok: true } };\n031|  const framed = encodeMessage(message);\n032|  assert.match(framed, /^Content-Length: \\d+\\r\\n\\r\\n/);\n033|\n034|  const buffer = new MessageBuffer();\n035|  assert.deepEqual(buffer.push(framed.slice(0, 9)), []);\n036|  const decoded = buffer.push(framed.slice(9) + framed);\n037|  assert.equal(decoded.length, 2);\n038|  assert.deepEqual(decoded[0], message);\n039|  assert.deepEqual(decoded[1], message);\n040|});\n041|\n042|test('initialize, shutdown, and exit expose expected LSP lifecycle', async () => {\n043|  const server = new MiniLangServer();\n044|  const init = await server.handle(request('initialize', { capabilities: {} }, 1));\n045|  assert.equal(init.id, 1);\n046|  assert.equal(init.result.capabilities.textDocumentSync, 2);\n047|  assert.ok(init.result.capabilities.completionProvider);\n048|  assert.equal(init.result.capabilities.definitionProvider, true);\n049|  assert.equal(init.result.capabilities.hoverProvider, true);\n050|\n051|  const shutdown = await server.handle(request('shutdown', {}, 2));\n052|  assert.deepEqual(shutdown, { jsonrpc: '2.0', id: 2, result: null });\n053|  assert.equal(await server.handle(notification('exit')), null);\n054|});\n055|\n056|test('didOpen publishes diagnostics for undefined symbols and wrong arity', async () => {\n057|  const uri = 'file:///visible-diagnostics.mini';\n058|  const text = [\n059|    'fn add(a, b) {',\n060|    '  return a',\n061|    '}',\n062|    'fn main() {',\n063|    '  let answer = add(1)',\n064|    '  return missing',\n065|    '}',\n066|  ].join('\\n');\n067|  const server = new MiniLangServer();\n068|  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n069|  const publish = server.takeNotifications().find((item) => item.method === 'textDocument/publishDiagnostics');\n070|  assert.ok(publish, 'expected publishDiagnostics notification');\n071|  const diagnostics = publish.params.diagnostics;\n072|  const messages = diagnostics.map((diag) => diag.message).join('\\n').toLowerCase();\n073|  assert.match(messages, /undefined.*missing|missing.*undefined/);\n074|  assert.match(messages, /arity|argument|expected 2/);\n075|  assert.equal(server.getDiagnostics(uri).length, diagnostics.length);\n076|});\n077|\n078|test('completion includes keywords, in-scope symbols, functions, and snippets', async () => {\n079|  const uri = 'file:///visible-completion.mini';\n080|  const text = [\n081|    'fn add(a, b) {',\n082|    '  return a',\n083|    '}',\n084|    'fn main() {',\n085|    '  let local = 1',\n086|    '  return ',\n087|    '}',\n088|  ].join('\\n');\n089|  const server = new MiniLangServer();\n090|  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n091|  const response = await server.handle(request('textDocument/completion', {\n092|    textDocument: { uri },\n093|    position: { line: 5, character: 9 },\n094|  }, 3));\n095|  const items = itemsFrom(response);\n096|  const labels = items.map((item) => item.label);\n097|  assert.ok(labels.includes('fn'));\n098|  assert.ok(labels.includes('let'));\n099|  assert.ok(labels.includes('return'));\n100|  assert.ok(labels.includes('add'));\n101|  assert.ok(labels.includes('local'));\n102|  assert.ok(items.some((item) => item.label === 'return' && /return/.test(JSON.stringify(item))));\n103|});\n104|\n105|test('definition and hover resolve function symbols', async () => {\n106|  const uri = 'file:///visible-definition.mini';\n107|  const text = [\n108|    'fn inc(value) {',\n109|    '  return value',\n110|    '}',\n111|    'fn main() {',\n112|    '  let total = inc(1)',\n113|    '  return total',\n114|    '}',\n115|  ].join('\\n');\n116|  const server = new MiniLangServer();\n117|  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n118|  const definition = await server.handle(request('textDocument/definition', {\n119|    textDocument: { uri },\n120|    position: positionOf(text, 4, 'inc', 1),\n121|  }, 4));\n122|  assert.equal(definition.result.uri, uri);\n123|  assert.equal(definition.result.range.start.line, 0);\n124|\n125|  const hover = await server.handle(request('textDocument/hover', {\n126|    textDocument: { uri },\n127|    position: positionOf(text, 4, 'inc', 1),\n128|  }, 5));\n129|  assert.match(JSON.stringify(hover.result.contents), /fn inc\\(value\\)/);\n130|});\n131|\n","exit_code":0,"status":"completed"}}
