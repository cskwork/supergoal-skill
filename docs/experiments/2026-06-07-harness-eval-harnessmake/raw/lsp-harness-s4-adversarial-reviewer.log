         range: paramRange,\n          scopeId: functionScope.id,\n          declLine: line,\n          declType: 'param',\n        });\n        cursor = paramEnd;\n        declarationTokens.add(symbolKey(line, paramStart, paramEnd));\n      }\n\n      symbols.push(...functionScope.symbols.values());\n      scopes.push(functionScope);\n      activeScopes.push(functionScope);\n    }\n\n    const letMatch = lineText.match(/^\\s*let\\s+([A-Za-z_]\\w*)\\s*=/);\n    if (letMatch) {\n      const name = letMatch[1];\n      const nameIndex = letMatch.index + letMatch[0].indexOf(name);\n      const symbol = {\n        kind: 'variable',\n        name,\n        range: makeRange(lineText, line, nameIndex, name),\n        scopeId: activeScopes[activeScopes.length - 1].id,\n      };\n\n      declarationTokens.add(symbolKey(line, nameIndex, nameIndex + name.length));\n      activeScopes[activeScopes.length - 1].symbols.set(name, symbol);\n      symbols.push(symbol);\n    }\n\n    const tokenRegex = /[A-Za-z_]\\w*/g;\n    let match;\n    while ((match = tokenRegex.exec(lineText))) {\n      const token = match[0];\n      const index = match.index;\n\n      if (KEYWORDS.has(token)) {\n        continue;\n      }\n\n      if (declarationTokens.has(symbolKey(line, index, index + token.length))) {\n        continue;\n      }\n\n      const tokenStart = index;\n      const after = lineText.slice(tokenStart + token.length);\n      const hasCall = /^\\s*\\(/.test(after);\n\n      let found = null;\n      for (let i = activeScopes.length - 1; i >= 0; i -= 1) {\n        const scope = activeScopes[i];\n        if (scope.symbols.has(token)) {\n          found = scope.symbols.get(token);\n          break;\n        }\n      }\n\n      if (!hasCall) {\n        if (!found) {\n          diagnostics.push(makeDiagnostic(lineText, line, match, `Undefined symbol '${token}'`));\n        }\n        continue;\n      }\n\n      const whitespace = after.match(/^\\s*/)[0].length;\n      const openParenIndex = tokenStart + token.length + whitespace;\n      const { count, closeIndex } = countCallArgs(lineText, openParenIndex);\n\n      if (!found || found.kind !== 'function') {\n        diagnostics.push(makeDiagnostic(lineText, line, match, `Undefined symbol '${token}'`));\n        continue;\n      }\n\n      if (count === null) {\n        continue;\n      }\n\n      if (count !== found.params.length) {\n        diagnostics.push(\n          makeDiagnostic(\n            lineText,\n            line,\n            {\n              index: tokenStart,\n              0: token,\n              length: token.length,\n            },\n            `Function '${token}' expects ${found.params.length} arguments but got ${count}`,\n          ),\n        );\n      }\n    }\n\n    const openCount = (lineText.match(/\\{/g) || []).length;\n    const closeCount = (lineText.match(/\\}/g) || []).length;\n    const nextDepth = depth + openCount - closeCount;\n\n    while (activeScopes.length > 1 && activeScopes[activeScopes.length - 1].depth > nextDepth) {\n      const finishedScope = activeScopes.pop();\n      finishedScope.endLine = line;\n    }\n\n    depth = nextDepth;\n  }\n\n  for (const scope of scopes) {\n    if (scope.depth > 0 && scope.endLine === Infinity) {\n      scope.endLine = lines.length - 1;\n    }\n  }\n\n  return {\n    text,\n    diagnostics,\n    symbols,\n    scopes,\n  };\n}\n\nexport class MiniLangServer {\n  constructor() {\n    this.documents = new Map();\n    this.notifications = [];\n    this.shutdownRequested = false;\n    this.exitCode = null;\n  }\n\n  async handle(message) {\n    const method = message.method;\n    const id = message.id;\n\n    if (method === 'initialize') {\n      return {\n        jsonrpc: '2.0',\n        id,\n        result: {\n          capabilities: {\n            textDocumentSync: 2,\n            completionProvider: {},\n            definitionProvider: true,\n            hoverProvider: true,\n          },\n        },\n      };\n    }\n\n    if (method === 'shutdown') {\n      this.shutdownRequested = true;\n      return {\n        jsonrpc: '2.0',\n        id,\n        result: null,\n      };\n    }\n\n    if (method === 'exit') {\n      this.exitCode = this.shutdownRequested ? 0 : 1;\n      return null;\n    }\n\n    if (method === 'textDocument/didOpen') {\n      const uri = message.params?.textDocument?.uri;\n      const text = message.params?.textDocument?.text;\n      if (!uri || typeof text !== 'string') {\n        return null;\n      }\n\n      const parsed = parseMiniLang(text);\n      parsed.uri = uri;\n      this.documents.set(uri, { text, parsed });\n      this._publishDiagnostics(uri, parsed);\n      return null;\n    }\n\n    if (method === 'textDocument/didChange') {\n      const uri = message.params?.textDocument?.uri;\n      const change = message.params?.contentChanges?.[0];\n      if (!uri || !change || typeof change.text !== 'string') {\n        return null;\n      }\n\n      const parsed = parseMiniLang(change.text);\n      parsed.uri = uri;\n      this.documents.set(uri, { text: change.text, parsed });\n      this._publishDiagnostics(uri, parsed);\n      return null;\n    }\n\n    const uri = message.params?.textDocument?.uri;\n    const stored = this.documents.get(uri);\n    if (!stored) {\n      return null;\n    }\n\n    const { parsed } = stored;\n    const position = message.params?.position;\n\n    if (method === 'textDocument/completion') {\n      return {\n        jsonrpc: '2.0',\n        id,\n        result: this._completion(parsed, position),\n      };\n    }\n\n    if (method === 'textDocument/definition') {\n      return {\n        jsonrpc: '2.0',\n        id,\n        result: this._definition(parsed, position),\n      };\n    }\n\n    if (method === 'textDocument/hover') {\n      return {\n        jsonrpc: '2.0',\n        id,\n        result: this._hover(parsed, position),\n      };\n    }\n\n    return null;\n  }\n\n  _publishDiagnostics(uri, parsed) {\n    this.notifications.push({\n      jsonrpc: '2.0',\n      method: 'textDocument/publishDiagnostics',\n      params: {\n        uri,\n        diagnostics: parsed.diagnostics,\n      },\n    });\n  }\n\n  takeNotifications() {\n    const notifications = this.notifications.slice();\n    this.notifications.length = 0;\n    return notifications;\n  }\n\n  getDiagnostics(uri) {\n    return this.documents.get(uri)?.parsed?.diagnostics ?? [];\n  }\n\n  _scopesAtLine(parsed, line) {\n    return parsed.scopes\n      .filter((scope) => scope.startLine <= line && line <= scope.endLine)\n      .sort((a, b) => b.depth - a.depth);\n  }\n\n  _findSymbol(parsed, line, column) {\n    const lineText = parsed.text.split('\\n')[line] || '';\n    const token = tokenAt(lineText, column);\n    if (!token) {\n      return null;\n    }\n\n    for (const scope of this._scopesAtLine(parsed, line)) {\n      if (scope.symbols.has(token.name)) {\n        return scope.symbols.get(token.name);\n      }\n    }\n\n    return null;\n  }\n\n  _completion(parsed, position) {\n    if (!position || typeof position.character !== 'number') {\n      return [];\n    }\n\n    const lineText = parsed.text.split('\\n')[position.line] || '';\n    const column = position.character;\n    let prefix = '';\n\n    for (let i = column - 1; i >= 0; i -= 1) {\n      const char = lineText[i] || '';\n      if (/[A-Za-z0-9_]/.test(char)) {\n        prefix = `${char}${prefix}`;\n      } else {\n        break;\n      }\n    }\n\n    const byName = new Map();\n    const items = [];\n\n    const addKeyword = (keyword) => {\n      if (!keyword.startsWith(prefix)) {\n        return;\n      }\n\n      byName.set(keyword, {\n        label: keyword,\n        kind: 14,\n        insertText: keyword,\n        insertTextFormat: 1,\n      });\n    };\n\n    addKeyword('fn');\n    addKeyword('let');\n    addKeyword('return');\n\n    for (const scope of this._scopesAtLine(parsed, position.line)) {\n      for (const symbol of scope.symbols.values()) {\n        if (!symbol.name.startsWith(prefix)) {\n          continue;\n        }\n\n        if (byName.has(symbol.name)) {\n          continue;\n        }\n\n        if (symbol.kind === 'function') {\n          const params = symbol.params\n            .map((param, i) => `\\${${i + 1}}:${param}`)\n            .join(', ');\n          byName.set(symbol.name, {\n            label: symbol.name,\n            kind: 3,\n            insertText: `${symbol.name}(${params})`,\n            insertTextFormat: 2,\n            detail: `function ${symbol.name}`,\n          });\n        } else {\n          byName.set(symbol.name, {\n            label: symbol.name,\n            kind: 6,\n            insertText: symbol.name,\n            insertTextFormat: 1,\n          });\n        }\n      }\n    }\n\n    for (const item of byName.values()) {\n      items.push(item);\n    }\n\n    return {\n      isIncomplete: false,\n      items,\n    };\n  }\n\n  _definition(parsed, position) {\n    if (!position || typeof position.character !== 'number') {\n      return null;\n    }\n\n    const symbol = this._findSymbol(parsed, position.line, position.character);\n    if (!symbol || !symbol.range) {\n      return null;\n    }\n\n    return {\n      uri: parsed.uri,\n      range: symbol.range,\n    };\n  }\n\n  _hover(parsed, position) {\n    if (!position || typeof position.character !== 'number') {\n      return null;\n    }\n\n    const symbol = this._findSymbol(parsed, position.line, position.character);\n    if (!symbol) {\n      return null;\n    }\n\n    if (symbol.kind === 'function') {\n      return {\n        contents: `fn ${symbol.name}(${symbol.params.join(', ')})`,\n      };\n    }\n\n    return {\n      contents: `${symbol.kind} ${symbol.name}`,\n    };\n  }\n}\n","exit_code":0,"status":"completed"}}
