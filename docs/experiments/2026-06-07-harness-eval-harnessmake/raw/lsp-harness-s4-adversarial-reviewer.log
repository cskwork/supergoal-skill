 lines = text.split('\\n');\n  const diagnostics = [];\n  const symbols = [];\n  const scopes = [];\n  const declarationTokens = new Set();\n\n  const globalScope = {\n    id: 'global',\n    startLine: 0,\n    endLine: Infinity,\n    depth: 0,\n    symbols: new Map(),\n  };\n\n  const activeScopes = [globalScope];\n  scopes.push(globalScope);\n\n  let depth = 0;\n\n  for (let line = 0; line < lines.length; line += 1) {\n    const lineText = lines[line];\n\n    const fnMatch = lineText.match(/^\\s*fn\\s+([A-Za-z_]\\w*)\\s*\\(([^)]*)\\)/);\n    if (fnMatch) {\n      const name = fnMatch[1];\n      const paramsText = fnMatch[2] || '';\n      const params = parseParams(paramsText);\n      const nameIndex = fnMatch.index + fnMatch[0].indexOf(name);\n\n      const fnSymbol = {\n        kind: 'function',\n        name,\n        params,\n        range: makeRange(lineText, line, nameIndex, name),\n        scopeId: `fn:${name}:${line}`,\n        declLine: line,\n      };\n\n      const currentScope = activeScopes[activeScopes.length - 1];\n      currentScope.symbols.set(name, fnSymbol);\n      symbols.push(fnSymbol);\n      declarationTokens.add(symbolKey(line, nameIndex, nameIndex + name.length));\n\n      const functionScope = {\n        id: fnSymbol.scopeId,\n        startLine: line,\n        endLine: Infinity,\n        depth: depth + 1,\n        symbols: new Map(),\n      };\n\n      const paramIndexBase = lineText.indexOf('(') + 1;\n      let cursor = 0;\n      for (const param of params) {\n        const paramStart = lineText.indexOf(param, paramIndexBase + cursor);\n","exit_code":0,"status":"completed"}}
