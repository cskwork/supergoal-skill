s = text.split(/\\r?\\n/);\n  const before = lines.slice(0, change.range.start.line).join('\\n')\n    + (change.range.start.line ? '\\n' : '')\n    + (lines[change.range.start.line] ?? '').slice(0, change.range.start.character);\n  const after = (lines[change.range.end.line] ?? '').slice(change.range.end.character)\n    + (change.range.end.line < lines.length - 1 ? '\\n' + lines.slice(change.range.end.line + 1).join('\\n') : '');\n  return before + change.text + after;\n}\n\nfunction functionAt(parsed, position) {\n  return [...parsed.functions.values()].find((fn) => {\n    const endLine = fn.endLine ?? Number.MAX_SAFE_INTEGER;\n    return fn.range.start.line <= position.line && position.line <= endLine;\n  })?.name;\n}\n\nexport class MiniLangServer {\n  constructor() {\n    this.documents = new Map();\n    this.notifications = [];\n    this.shutdownRequested = false;\n  }\n\n  async handle(message) {\n    if (message.method === 'initialize') return this.respond(message.id, this.initializeResult());\n    if (message.method === 'shutdown') {\n      this.shutdownRequested = true;\n      return this.respond(message.id, null);\n    }\n    if (message.method === 'exit') return null;\n    if (message.method === 'textDocument/didOpen') return this.didOpen(message.params.textDocument);\n    if (message.method === 'textDocument/didChange') return this.didChange(message.params);\n    if (message.method === 'textDocument/completion') return this.respond(message.id, this.completion(message.params));\n    if (message.method === 'textDocument/definition') return this.respond(message.id, this.definition(message.params));\n    if (message.method === 'textDocument/hover') return this.respond(message.id, this.hover(message.params));\n    if ('id' in message) return { jsonrpc: '2.0', id: message.id, error: { code: -32601, message: 'Method not found' } };\n    return null;\n  }\n\n  respond(id, result) {\n    return { jsonrpc: '2.0', id, result };\n  }\n\n  initializeResult() {\n    r