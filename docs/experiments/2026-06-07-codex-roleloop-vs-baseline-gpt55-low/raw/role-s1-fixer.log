}));\n    47\t  const items = completionItems(response);\n    48\t  const labels = items.map((item) => item.label);\n    49\t\n    50\t  assert.deepEqual(labels.sort(), ['apple', 'apply'].sort());\n    51\t  const apply = items.find((item) => item.label === 'apply');\n    52\t  assert.match(apply?.detail ?? '', /fn apply\\(value\\)/);\n    53\t});\n    54\t\n    55\ttest('parser recovery keeps semantic diagnostics after a missing closing brace', async () => {\n    56\t  const uri = 'file:///recover-diagnostics.mini';\n    57\t  const text = [\n    58\t    'fn first() {',\n    59\t    '  let local = 1',\n    60\t    'fn second() {',\n    61\t    '  return missingValue',\n    62\t    '}',\n    63\t  ].join('\\n');\n    64\t  const server = new MiniLangServer();\n    65\t  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n    66\t\n    67\t  const messages = server.getDiagnostics(uri).map((diag) => diag.message).join('\\n');\n    68\t  assert.match(messages, /missing.*\\}/i);\n    69\t  assert.match(messages, /Undefined variable 'missingValue'/);\n    70\t});\n    71\t\n    72\ttest('go-to-definition prefers a local symbol over a same-named global function', async () => {\n    73\t  const uri = 'file:///local-definition.mini';\n    74\t  const text = [\n    75\t    'fn item() {',\n    76\t    '  return 1',\n    77\t    '}',\n    78\t    'fn main() {',\n    79\t    '  let item = 2',\n    80\t    '  return item',\n    81\t    '}',\n    82\t  ].join('\\n');\n    83\t  const server = new MiniLangServer();\n    84\t  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n    85\t\n    86\t  const response = await server.handle(request('textDocument/definition', {\n    87\t    textDocument: { uri },\n    88\t    position: positionOf(text, 5, 'item', 1),\n    89\t  }));\n    90\t\n    91\t  assert.equal(response.result.uri, uri);\n    92\t  assert.equal(response.result.range.start.line, 4);\n    93\t});\n    94\t\n    95\ttest('comments do not create symbols, calls, or diagnostics', async () => {\n    96\t  const uri = 'file:///comments.mini';\n    97\t  const text = [\n    98\t    '# fn ghost(param) {',\n    99\t    'fn main() {',\n   100\t    '  # missingCall(unknownName)',\n   101\t    '  return 1 # trailingName',\n   102\t    '}',\n   103\t  ].join('\\n');\n   104\t  const server = new MiniLangServer();\n   105\t  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n   106\t\n   107\t  assert.deepEqual(server.getDiagnostics(uri), []);\n   108\t\n   109\t  const response = await server.handle(request('textDocument/completion', {\n   110\t    textDocument: { uri },\n   111\t    position: { line: 3, character: 9 },\n   112\t  }));\n   113\t  const labels = completionItems(response).map((item) => item.label);\n   114\t  assert.ok(!labels.includes('ghost'));\n   115\t  assert.ok(!labels.includes('missingCall'));\n   116\t  assert.ok(!labels.includes('unknownName'));\n   117\t});\n   118\t\n   119\ttest('didChange range edits update the document and clear stale diagnostics', async () => {\n   120\t  const uri = 'file:///range-change.mini';\n   121\t  const original = [\n   122\t    'fn main() {',\n   123\t    '  return missing',\n   124\t    '}',\n   125\t  ].join('\\n');\n   126\t  const server = new MiniLangServer();\n   127\t  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, original, 1) }));\n   128\t  assert.match(server.getDiagnostics(uri).map((diag) => diag.message).join('\\n'), /missing/);\n   129\t  server.takeNotifications();\n   130\t\n   131\t  await server.handle(notification('textDocument/didChange', {\n   132\t    textDocument: { uri, version: 2 },\n   133\t    contentChanges: [{\n   134\t      range: { start: { line: 1, character: 2 }, end: { line: 1, character: 16 } },\n   135\t      text: 'let missing = 1\\n  return missing',\n   1