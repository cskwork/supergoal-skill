{"type":"item.completed","item":{"id":"item_7","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' test/spec.gen.test.mjs\"","aggregated_output":"import assert from 'node:assert/strict';\nimport test from 'node:test';\nimport { MiniLangServer, parseMiniLang } from '../src/server.mjs';\n\nfunction request(method, params = {}, id = 1) {\n  return { jsonrpc: '2.0', id, method, params };\n}\n\nfunction notification(method, params = {}) {\n  return { jsonrpc: '2.0', method, params };\n}\n\nfunction textDocument(uri, text, version = 1) {\n  return { uri, languageId: 'minilang', version, text };\n}\n\nfunction itemsFrom(response) {\n  const result = response.result;\n  return Array.isArray(result) ? result : result.items;\n}\n\nfunction positionOf(text, line, needle, offset = 0) {\n  const lines = text.split('\\n');\n  const character = lines[line].indexOf(needle);\n  assert.notEqual(character, -1, `missing ${needle} on line ${line}`);\n  return { line, character: character + offset };\n}\n\nfunction diagnosticText(diagnostics) {\n  return diagnostics.map((diag) => diag.message).join('\\n').toLowerCase();\n}\n\ntest('completion filters by typed prefix and exposes function signatures', async () => {\n  const server = new MiniLangServer();\n  const uri = 'file:///completion-prefix.mini';\n  const text = [\n    'fn add(left, right) {',\n    '  return left',\n    '}',\n    'fn adjust(value) {',\n    '  return value',\n    '}',\n    'fn main() {',\n    '  ad',\n    '}',\n  ].join('\\n');\n\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n  const response = await server.handle(request('textDocument/completion', {\n    textDocument: { uri },\n    position: { line: 7, character: 4 },\n  }));\n\n  const items = itemsFrom(response);\n  const labels = items.map((item) => item.label);\n  assert.deepEqual(labels.sort(), ['add', 'adjust']);\n\n  for (const item of items) {\n    const rendered = JSON.stringify(item);\n    assert.match(rendered, new RegExp(`fn ${item.label}\\\\(`));\n  }\n});\n\ntest('parser recovers from a missing brace and still reports later semantic diagnostics', () => {\n  const text = [\n    'fn broken(value) {',\n    '  let local = value',\n    'fn later() {',\n    '  missing(1)',\n    '  broken(1, 2)',\n    '}',\n  ].join('\\n');\n\n  const parsed = parseMiniLang(text);\n  const messages = diagnosticText(parsed.diagnostics);\n  assert.match(messages, /missing closing brace|closing brace/);\n  assert.match(messages, /undefined.*missing|missing.*undefined/);\n  assert.match(messages, /arity|argument|expected 1/);\n});\n\ntest('definition prefers the local binding over a same-named function', async () => {\n  const server = new MiniLangServer();\n  const uri = 'file:///definition-local-scope.mini';\n  const text = [\n    'fn value() {',\n    '  return 1',\n    '}',\n    'fn main(value) {',\n    '  let other = value',\n    '  return value',\n    '}',\n  ].join('\\n');\n\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n  const definition = await server.handle(request('textDocument/definition', {\n    textDocument: { uri },\n    position: positionOf(text, 5, 'value', 1),\n  }));\n\n  assert.equal(definition.result.uri, uri);\n  assert.deepEqual(definition.result.range.start, { line: 3, character: 8 });\n});\n\ntest('comments are ignored for diagnostics and completion prefixes', async () => {\n  const server = new MiniLangServer();\n  const uri = 'file:///comments.mini';\n  const text = [\n    'fn real() {',\n    '  return 1',\n    '}',\n    '# fn fake(unclosed',\n    '# missing(1)',\n    'fn main() {',\n    '  re # missing(2)',\n    '}',\n  ].join('\\n');\n\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n  assert.equal(server.getDiagnostics(uri).length, 0);\n\n  const response = await server.handle(request('textDocument/completion', {\n    textDocument: { uri },\n    position: { line: 6, character: 4 },\n  }));\n  const labels = itemsFrom(response).map((item) => item.label);\n  assert.deepEqual(labels, ['real']);\n});\n\ntest('didChange replaces stale diagnostics and is idempotent for the same full text', async () => {\n  const server = new MiniLangServer();\n  const uri = 'file:///change-diagnostics.mini';\n  const badText = [\n    'fn takesOne(value) {',\n    '  return value',\n    '}',\n    'fn main() {',\n    '  missing(1)',\n    '  takesOne(1, 2)',\n    '}',\n  ].join('\\n');\n  const goodText = [\n    'fn takesOne(value) {',\n    '  return value',\n    '}',\n    'fn main() {',\n    '  takesOne(1)',\n    '}',\n  ].join('\\n');\n\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, badText) }));\n  assert.match(diagnosticText(server.getDiagnostics(uri)), /undefined|arity|argument/);\n\n  await server.handle(notification('textDocument/didChange', {\n    textDocument: { uri, version: 2 },\n    contentChanges: [{ text: goodText }],\n  }));\n  assert.deepEqual(server.getDiagnostics(uri), []);\n\n  const firstPublish = server.takeNotifications().at(-1);\n  await server.handle(notification('textDocument/didChange', {\n    textDocument: { uri, version: 3 },\n    contentChanges: [{ text: goodText }],\n  }));\n  const secondPublish = server.takeNotifications().at(-1);\n\n  assert.deepEqual(secondPublish.params.diagnostics, []);\n  assert.deepEqual(secondPublish.params.diagnostics, firstPublish.params.diagnostics);\n});\n","exit_code":0,"status":"completed"}}
