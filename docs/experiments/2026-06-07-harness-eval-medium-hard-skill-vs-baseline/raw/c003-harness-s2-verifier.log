{"type":"item.completed","item":{"id":"item_9","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,240p' test/spec.gen.test.mjs\"","aggregated_output":"import assert from 'node:assert/strict';\nimport { test } from 'node:test';\nimport * as orderModule from '../src/order.mjs';\n\nconst { calculateInvoice } = orderModule;\n\ntest('public API exposes only calculateInvoice and returns the required fields in order', () => {\n  assert.deepEqual(Object.keys(orderModule), ['calculateInvoice']);\n\n  assert.deepEqual(\n    Object.keys(calculateInvoice({ items: [{ price: 12.34, qty: 1 }], region: 'US' })),\n    ['subtotal', 'discount', 'tax', 'shipping', 'total'],\n  );\n});\n\ntest('VIP floor is only a minimum and never reduces larger coupon discounts', () => {\n  assert.deepEqual(\n    calculateInvoice({\n      items: [{ price: 125, qty: 1 }],\n      region: 'US',\n      coupon: 'SAVE20',\n      vip: true,\n    }),\n    { subtotal: 125, discount: 25, tax: 7, shipping: 0, total: 107 },\n  );\n\n  assert.deepEqual(\n    calculateInvoice({\n      items: [{ price: 80, qty: 1 }],\n      region: 'EU',\n      coupon: 'SAVE10',\n      vip: true,\n    }),\n    { subtotal: 80, discount: 8, tax: 14.4, shipping: 3, total: 89.4 },\n  );\n});\n\ntest('HALF coupon is ignored for non-VIP orders but VIP floor still applies without a coupon', () => {\n  assert.deepEqual(\n    calculateInvoice({\n      items: [{ price: 120, qty: 1 }],\n      region: 'US',\n      coupon: 'HALF',\n      vip: false,\n    }),\n    { subtotal: 120, discount: 0, tax: 8.4, shipping: 0, total: 128.4 },\n  );\n\n  assert.deepEqual(\n    calculateInvoice({\n      items: [{ price: 40, qty: 1 }],\n      region: 'US',\n      vip: true,\n    }),\n    { subtotal: 40, discount: 2, tax: 2.66, shipping: 7.5, total: 48.16 },\n  );\n});\n\ntest('shipping tiers use subtotal minus discount with exact lower boundaries', () => {\n  assert.deepEqual(\n    calculateInvoice({\n      items: [{ price: 50, qty: 1 }],\n      region: 'US',\n      vip: false,\n    }),\n    { subtotal: 50, discount: 0, tax: 3.5, shipping: 3, total: 56.5 },\n  );\n\n  assert.deepEqual(\n    calculateInvoice({\n      items: [{ price: 55.55555555555556, qty: 1 }],\n      region: 'US',\n      coupon: 'SAVE10',\n    }),\n    { subtotal: 55.56, discount: 5.56, tax: 3.5, shipping: 3, total: 56.5 },\n  );\n\n  assert.deepEqual(\n    calculateInvoice({\n      items: [{ price: 125, qty: 1 }],\n      region: 'US',\n      coupon: 'SAVE20',\n      express: true,\n    }),\n    { subtotal: 125, discount: 25, tax: 7, shipping: 12, total: 119 },\n  );\n});\n\ntest('cent rounding applies independently to subtotal, discount, tax, shipping, and total', () => {\n  assert.deepEqual(\n    calculateInvoice({\n      items: [{ price: 0.335, qty: 1 }],\n      region: 'EU',\n      coupon: 'SAVE10',\n      express: true,\n    }),\n    { subtotal: 0.34, discount: 0.03, tax: 0.06, shipping: 19.5, total: 19.86 },\n  );\n});\n","exit_code":0,"status":"completed"}}
