{"type":"item.completed","item":{"id":"item_21","type":"command_execution","command":"/bin/zsh -lc \"node -e \\\"const fs=require('fs'); const lines=fs.readFileSync('src/server.mjs','utf8').split('\\\\n'); for (let i=1;i<90;i++) console.log(String(i).padStart(3,' ')+': '+JSON.stringify(lines[i-1]||''));\\\"\"","aggregated_output":"  1: \"const KEYWORDS = ['fn', 'let', 'return'];\"\n  2: \"const IDENT = /[A-Za-z_][A-Za-z0-9_]*/g;\"\n  3: \"\"\n  4: \"export function encodeMessage(message) {\"\n  5: \"  const body = JSON.stringify(message);\"\n  6: \"  return `Content-Length: ${Buffer.byteLength(body, 'utf8')}\\\\r\\\\n\\\\r\\\\n${body}`;\"\n  7: \"}\"\n  8: \"\"\n  9: \"export class MessageBuffer {\"\n 10: \"  constructor() {\"\n 11: \"    this.buffer = Buffer.alloc(0);\"\n 12: \"  }\"\n 13: \"\"\n 14: \"  push(chunk) {\"\n 15: \"    const next = Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk), 'utf8');\"\n 16: \"    this.buffer = Buffer.concat([this.buffer, next]);\"\n 17: \"    const messages = [];\"\n 18: \"\"\n 19: \"    while (true) {\"\n 20: \"      const split = this.buffer.indexOf('\\\\r\\\\n\\\\r\\\\n');\"\n 21: \"      if (split < 0) return messages;\"\n 22: \"      const header = this.buffer.subarray(0, split).toString('ascii');\"\n 23: \"      const match = /^Content-Length:\\\\s*(\\\\d+)/im.exec(header);\"\n 24: \"      if (!match) throw new Error('Missing Content-Length header');\"\n 25: \"\"\n 26: \"      const start = split + 4;\"\n 27: \"      const length = Number(match[1]);\"\n 28: \"      if (this.buffer.length < start + length) return messages;\"\n 29: \"\"\n 30: \"      const body = this.buffer.subarray(start, start + length).toString('utf8');\"\n 31: \"      this.buffer = this.buffer.subarray(start + length);\"\n 32: \"      messages.push(JSON.parse(body));\"\n 33: \"    }\"\n 34: \"  }\"\n 35: \"}\"\n 36: \"\"\n 37: \"function pos(line, character) {\"\n 38: \"  return { line, character };\"\n 39: \"}\"\n 40: \"\"\n 41: \"function range(line, start, end) {\"\n 42: \"  return { start: pos(line, start), end: pos(line, end) };\"\n 43: \"}\"\n 44: \"\"\n 45: \"function diag(line, start, end, message) {\"\n 46: \"  return {\"\n 47: \"    range: range(line, start, Math.max(end, start + 1)),\"\n 48: \"    severity: 1,\"\n 49: \"    source: 'minilang',\"\n 50: \"    message,\"\n 51: \"  };\"\n 52: \"}\"\n 53: \"\"\n 54: \"function stripComment(line) {\"\n 55: \"  const at = line.indexOf('#');\"\n 56: \"  return at < 0 ? line : line.slice(0, at);\"\n 57: \"}\"\n 58: \"\"\n 59: \"function splitArgs(text) {\"\n 60: \"  const trimmed = text.trim();\"\n 61: \"  return trimmed ? trimmed.split(',').map((part) => part.trim()).filter(Boolean) : [];\"\n 62: \"}\"\n 63: \"\"\n 64: \"function scanReferences(expr, line, baseColumn, scope) {\"\n 65: \"  const calls = [];\"\n 66: \"  const callSpans = [];\"\n 67: \"  for (const match of expr.matchAll(/([A-Za-z_][A-Za-z0-9_]*)\\\\s*\\\\(([^)]*)\\\\)/g)) {\"\n 68: \"    calls.push({\"\n 69: \"      name: match[1],\"\n 70: \"      args: splitArgs(match[2]),\"\n 71: \"      line,\"\n 72: \"      start: baseColumn + match.index,\"\n 73: \"      end: baseColumn + match.index + match[1].length,\"\n 74: \"      scope,\"\n 75: \"      isCall: true,\"\n 76: \"    });\"\n 77: \"    callSpans.push([match.index, match.index + match[0].length]);\"\n 78: \"  }\"\n 79: \"\"\n 80: \"  const names = [];\"\n 81: \"  for (const match of expr.matchAll(IDENT)) {\"\n 82: \"    const insideCall = callSpans.some(([start, end]) => match.index >= start && match.index < end);\"\n 83: \"    if (!insideCall && !KEYWORDS.includes(match[0])) {\"\n 84: \"      names.push({\"\n 85: \"        name: match[0],\"\n 86: \"        line,\"\n 87: \"        start: baseColumn + match.index,\"\n 88: \"        end: baseColumn + match.index + match[0].length,\"\n 89: \"        scope,\"\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_20","type":"command_execution","command":"/bin/zsh -lc \"node -e \\\"const fs=require('fs'); const lines=fs.readFileSync('src/server.mjs','utf8').split('\\\\n'); for (let i=250;i<350;i++) console.log(String(i+1).padStart(3,' ')+': '+JSON.stringify(lines[i]||''));\\\"\"","aggregated_output":"251: \"  return word ? { word, range: range(position.line, start, end) } : null;\"\n252: \"}\"\n253: \"\"\n254: \"function functionAt(parsed, position) {\"\n255: \"  let match = null;\"\n256: \"  for (const symbol of parsed.symbols.filter((item) => item.kind === 'function')) {\"\n257: \"    if (symbol.line <= position.line && (!match || symbol.line > match.line)) match = symbol;\"\n258: \"  }\"\n259: \"  return match;\"\n260: \"}\"\n261: \"\"\n262: \"function applyChange(text, change) {\"\n263: \"  if (!change.range) return change.text;\"\n264: \"  const lines = text.split(/\\\\r?\\\\n/);\"\n265: \"  const before = lines.slice(0, change.range.start.line);\"\n266: \"  before.push((lines[change.range.start.line] ?? '').slice(0, change.range.start.character));\"\n267: \"  const after = lines.slice(change.range.end.line);\"\n268: \"  after[0] = (after[0] ?? '').slice(change.range.end.character);\"\n269: \"  return `${before.join('\\\\n')}${change.text}${after.join('\\\\n')}`;\"\n270: \"}\"\n271: \"\"\n272: \"export class MiniLangServer {\"\n273: \"  constructor() {\"\n274: \"    this.documents = new Map();\"\n275: \"    this.notifications = [];\"\n276: \"    this.shutdownRequested = false;\"\n277: \"  }\"\n278: \"\"\n279: \"  handle(message) {\"\n280: \"    switch (message.method) {\"\n281: \"      case 'initialize':\"\n282: \"        return this.response(message.id, {\"\n283: \"          capabilities: {\"\n284: \"            textDocumentSync: 2,\"\n285: \"            completionProvider: {},\"\n286: \"            definitionProvider: true,\"\n287: \"            hoverProvider: true,\"\n288: \"          },\"\n289: \"        });\"\n290: \"      case 'shutdown':\"\n291: \"        this.shutdownRequested = true;\"\n292: \"        return this.response(message.id, null);\"\n293: \"      case 'exit':\"\n294: \"        return null;\"\n295: \"      case 'textDocument/didOpen':\"\n296: \"        this.didOpen(message.params.textDocument);\"\n297: \"        return undefined;\"\n298: \"      case 'textDocument/didChange':\"\n299: \"        this.didChange(message.params);\"\n300: \"        return undefined;\"\n301: \"      case 'textDocument/completion':\"\n302: \"        return this.response(message.id, this.completion(message.params));\"\n303: \"      case 'textDocument/definition':\"\n304: \"        return this.response(message.id, this.definition(message.params));\"\n305: \"      case 'textDocument/hover':\"\n306: \"        return this.response(message.id, this.hover(message.params));\"\n307: \"      default:\"\n308: \"        return this.response(message.id, null);\"\n309: \"    }\"\n310: \"  }\"\n311: \"\"\n312: \"  response(id, result) {\"\n313: \"    return { jsonrpc: '2.0', id, result };\"\n314: \"  }\"\n315: \"\"\n316: \"  didOpen(document) {\"\n317: \"    this.setDocument(document.uri, document.text, document.version);\"\n318: \"  }\"\n319: \"\"\n320: \"  didChange(params) {\"\n321: \"    const doc = this.documents.get(params.textDocument.uri);\"\n322: \"    let text = doc?.text ?? '';\"\n323: \"    for (const change of params.contentChanges ?? []) {\"\n324: \"      text = applyChange(text, change);\"\n325: \"    }\"\n326: \"    this.setDocument(params.textDocument.uri, text, params.textDocument.version);\"\n327: \"  }\"\n328: \"\"\n329: \"  setDocument(uri, text, version) {\"\n330: \"    const parsed = parseMiniLang(text);\"\n331: \"    this.documents.set(uri, { uri, text, version, parsed });\"\n332: \"    this.notifications.push({\"\n333: \"      jsonrpc: '2.0',\"\n334: \"      method: 'textDocument/publishDiagnostics',\"\n335: \"      params: { uri, diagnostics: parsed.diagnostics },\"\n336: \"    });\"\n337: \"  }\"\n338: \"\"\n339: \"  takeNotifications() {\"\n340: \"    return this.notifications.splice(0);\"\n341: \"  }\"\n342: \"\"\n343: \"  getDiagnostics(uri) {\"\n344: \"    return this.documents.get(uri)?.parsed.diagnostics ?? [];\"\n345: \"  }\"\n346: \"\"\n347: \"  completion(params) {\"\n348: \"    const doc = this.documents.get(params.textDocument.uri);\"\n349: \"    if (!doc) return { isIncomplete: false, items: [] };\"\n350: \"\"\n","exit_code":0,"status":"completed"}}
