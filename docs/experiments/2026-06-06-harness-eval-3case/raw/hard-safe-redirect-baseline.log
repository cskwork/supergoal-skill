diff --git a/test/safeRedirect.test.mjs b/test/safeRedirect.test.mjs
index 3f36cda8946dcec69d7f33469d605869622e83b5..59ec77c8287b90c0252c2593197d841bc7374063
--- a/test/safeRedirect.test.mjs
+++ b/test/safeRedirect.test.mjs
@@ -5,13 +5,35 @@
 test('allows configured hosts and subdomains', () => {
   assert.equal(isSafeRedirect('https://example.com/welcome'), true);
   assert.equal(isSafeRedirect('https://app.example.com/welcome'), true);
+  assert.equal(isSafeRedirect('http://docs.example.org/path', ['example.org']), true);
 });
 
-test('rejects obvious unsafe redirects', () => {
+test('rejects suffix, userinfo, slash, and control character bypasses', () => {
   assert.equal(isSafeRedirect('javascript:alert(1)'), false);
   assert.equal(isSafeRedirect('https://evil.test'), false);
+  assert.equal(isSafeRedirect('https://badexample.com'), false);
   assert.equal(isSafeRedirect('https://example.com.evil.test'), false);
   assert.equal(isSafeRedirect('https://evil.test@example.com'), false);
-  assert.equal(isSafeRedirect('http://127.0.0.1/admin'), false);
-  assert.equal(isSafeRedirect('http://localhost./admin'), false);
+  assert.equal(isSafeRedirect('https://example.com\\evil.test'), false);
+  assert.equal(isSafeRedirect('https://example.com/\nadmin'), false);
+});
+
+test('rejects localhost and private IPv4 forms', () => {
+  assert.equal(isSafeRedirect('http://localhost/admin', ['localhost']), false);
+  assert.equal(isSafeRedirect('http://localhost./admin', ['localhost']), false);
+  assert.equal(isSafeRedirect('http://127.0.0.1/admin', ['127.0.0.1']), false);
+  assert.equal(isSafeRedirect('http://0177.0.0.1/admin', ['127.0.0.1']), false);
+  assert.equal(isSafeRedirect('http://0x7f.0.0.1/admin', ['127.0.0.1']), false);
+  assert.equal(isSafeRedirect('http://2130706433/admin', ['127.0.0.1']), false);
+  assert.equal(isSafeRedirect('http://10.0.0.1/admin', ['10.0.0.1']), false);
+  assert.equal(isSafeRedirect('http://172.16.0.1/admin', ['172.16.0.1']), false);
+  assert.equal(isSafeRedirect('http://192.168.1.1/admin', ['192.168.1.1']), false);
+});
+
+test('rejects unsafe IPv6 hosts', () => {
+  assert.equal(isSafeRedirect('http://[::1]/admin', ['[::1]']), false);
+  assert.equal(isSafeRedirect('http://[fc00::1]/admin', ['[fc00::1]']), false);
+  assert.equal(isSafeRedirect('http://[fd12:3456::1]/admin', ['[fd12:3456::1]']), false);
+  assert.equal(isSafeRedirect('http://[::ffff:127.0.0.1]/admin', ['[::ffff:7f00:1]']), false);
+  assert.equal(isSafeRedirect('http://[::ffff:192.168.1.1]/admin', ['[::ffff:c0a8:101]']), false);
 });

