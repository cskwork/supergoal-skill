m.range, position),\n    );\n    if (reference?.target) return reference.target;\n\n    return doc.parsed.symbols.find(\n      (symbol) => symbol.name === word.text && contains(symbol.range, position),\n    ) ?? null;\n  }\n}\n\nfunction parseLine(state, raw, lineNo) {\n  const code = stripComment(raw);\n  const trimmed = code.trim();\n  if (!trimmed) return closeScopes(state, raw, lineNo);\n\n  const first = code.search(/\\S/);\n  const fn = /^fn\\s+([A-Za-z_]\\w*)\\s*\\(([^)]*)\\)\\s*\\{?/.exec(trimmed);\n  if (fn) {\n    addFunction(state, raw, lineNo, fn);\n    parseInlineFunctionBody(state, code, lineNo);\n  } else if (trimmed.startsWith('fn ')) {\n    state.diagnostics.push(diag(lineNo, first, code.length, 'Malformed function declaration'));\n  } else {\n    parseStatement(state, code, trimmed, first, lineNo);\n  }\n\n  closeScopes(state, code, lineNo);\n}\n\nfunction parseInlineFunctionBody(state, raw, lineNo) {\n  const open = raw.indexOf('{');\n  if (open < 0) return;\n  const close = raw.lastIndexOf('}');\n  const body = raw.slice(open + 1, close > open ? close : undefined).trim();\n  if (!body) return;\n  parseStatement(state, body, body, raw.indexOf(body), lineNo);\n}\n\nfunction addFunction(state, raw, lineNo, fn) {\n  if (state.currentFunction) {\n    state.diagnostics.push(diag(lineNo, 0, raw.length, 'Nested function declarations are not supported'));\n  }\n\n  const nameCol = raw.indexOf(fn[1]);\n  const params = splitParams(fn[2], lineNo, raw.indexOf('(') + 1, state.diagnostics);\n  const symbol = makeSymbol('function', fn[1], lineNo, nameCol, {\n    params,\n    detail: `fn ${fn[1]}(${params.join(', ')})`,\n  });\n\n  state.symbols.push(symbol);\n  state.functions.set(symbol.name, symbol);\n  state.scopes[0].set(symbol.name, symbol);\n  state.currentFunction = symbol;\n\n  const scope = new Map();\n  for (const param of params) {\n    const col = raw.indexOf(param, raw.indexOf('('));\n    const paramSymbol = makeSymbol('parameter', param, lineNo, col, { container: symbol.name });\n    state.symbols.push(paramSymbol);\n    scope.set(param, paramSymbol);\n  }\n  state.scopes.push(scope);\n}\n\nfunction parseStatement(state, raw, trimmed, first, lineNo) {\n  const variable = /^let\\s+([A-Za-z_]\\w*)\\s*=\\s*(.*)$/.exec(trimmed);\n  if (variable) return addVariable(state, raw, lineNo, variable);\n\n  if (trimmed.startsWith('let ')) {\n    state.diagnostics.push(diag(lineNo, first, raw.length, 'Malformed variable declaration'));\n    return;\n  }\n\n  if (trimmed.startsWith('return')) {\n    const expression = trimmed.slice('return'.length).trim();\n    if (!state.currentFunction) {\n      state.diagnostics.push(diag(lineNo, first, first + 6, 'Return statement outside function'));\n    }\n    if (expression) scanExpression(expression, lineNo, raw.indexOf(expression), state);\n    return;\n  }\n\n  scanExpression(trimmed, lineNo, first, state);\n}\n\nfunction addVariable(state, raw, lineNo, variable) {\n  const name = variable[1];\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,120p' src/server.mjs\"","aggregated_output":"const KEYWORDS = ['fn', 'let', 'return'];\nconst BUILTINS = new Set(['print']);\n\nexport function encodeMessage(message) {\n  const body = JSON.stringify(message);\n  return `Content-Length: ${Buffer.byteLength(body, 'utf8')}\\r\\n\\r\\n${body}`;\n}\n\nexport class MessageBuffer {\n  constructor() {\n    this.buffer = Buffer.alloc(0);\n  }\n\n  push(chunk) {\n    const incoming = Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk), 'utf8');\n    this.buffer = Buffer.concat([this.buffer, incoming]);\n    const messages = [];\n\n    while (true) {\n      const headerEnd = this.buffer.indexOf('\\r\\n\\r\\n');\n      if (headerEnd < 0) return messages;\n\n      const header = this.buffer.subarray(0, headerEnd).toString('ascii');\n      const match = /^Content-Length:\\s*(\\d+)\\s*$/im.exec(header);\n      if (!match) throw new Error('Missing Content-Length header');\n\n      const bodyStart = headerEnd + 4;\n      const bodyEnd = bodyStart + Number(match[1]);\n      if (this.buffer.length < bodyEnd) return messages;\n\n      const body = this.buffer.subarray(bodyStart, bodyEnd).toString('utf8');\n      messages.push(JSON.parse(body));\n      this.buffer = this.buffer.subarray(bodyEnd);\n    }\n  }\n}\n\nexport function parseMiniLang(text) {\n  const state = {\n    text,\n    symbols: [],\n    references: [],\n    diagnostics: [],\n    functions: new Map(),\n    scopes: [new Map()],\n    currentFunction: null,\n    braceDepth: 0,\n  };\n\n  text.split(/\\r?\\n/).forEach((line, lineNo) => parseLine(state, line, lineNo));\n  reconcileForwardFunctions(state);\n  return {\n    text,\n    symbols: state.symbols,\n    references: state.references,\n    diagnostics: state.diagnostics,\n  };\n}\n\nexport class MiniLangServer {\n  constructor() {\n    this.documents = new Map();\n    this.diagnostics = new Map();\n    this.notifications = [];\n    this.shutdownRequested = false;\n  }\n\n  async handle(message) {\n    if (!message || message.jsonrpc !== '2.0') return null;\n    if (!message.method) return null;\n\n    if (message.method === 'initialize') return response(message.id, initializeResult());\n    if (message.method === 'shutdown') {\n      this.shutdownRequested = true;\n      return response(message.id, null);\n    }\n    if (message.method === 'exit') return null;\n    if (this.shutdownRequested) {\n      return message.id === undefined\n        ? null\n        : errorResponse(message.id, -32600, 'Server is shut down');\n    }\n\n    if (message.method === 'textDocument/didOpen') return this.didOpen(message.params);\n    if (message.method === 'textDocument/didChange') return this.didChange(message.params);\n    if (message.method === 'textDocument/completion') return response(message.id, this.completion(message.params));\n    if (message.method === 'textDocument/definition') return response(message.id, this.definition(message.params));\n    if (message.method === 'textDocument/hover') return response(message.id, this.hover(message.params));\n\n    if (message.id === undefined) return null;\n    return response(message.id, null);\n  }\n\n  takeNotifications() {\n    const out = this.notifications;\n    this.notifications = [];\n    return out;\n  }\n\n  getDiagnostics(uri) {\n    return this.diagnostics.get(uri) ?? [];\n  }\n\n  didOpen(params) {\n    const doc = params.textDocument;\n    this.setDocument(doc.uri, doc.text ?? '', doc.version);\n    return null;\n  }\n\n  didChange(params) {\n    const uri = params.textDocument.uri;\n    const oldText = this.documents.get(uri)?.text ?? '';\n    let text = oldText;\n\n    for (const change of params.contentChanges ?? []) {\n      text = change.range ? applyTextChange(text, change) : change.text;\n    }\n\n    this.setDocument(uri, text, params.textDocument.version);\n    return null;\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_17","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' test/lsp.visible.test.mjs\"","aggregated_output":"import assert from 'node:assert/strict';\nimport { test } from 'node:test';\nimport { encodeMessage, MessageBuffer, MiniLangServer } from '../src/server.mjs';\n\nfunction request(method, params = {}, id = 1) {\n  return { jsonrpc: '2.0', id, method, params };\n}\n\nfunction notification(method, params = {}) {\n  return { jsonrpc: '2.0', method, params };\n}\n\nfunction textDocument(uri, text, version = 1) {\n  return { uri, languageId: 'minilang', version, text };\n}\n\nfunction itemsFrom(response) {\n  const result = response.result;\n  return Array.isArray(result) ? result : result.items;\n}\n\nfunction positionOf(text, line, needle, offset = 0) {\n  const lines = text.split('\\n');\n  const character = lines[line].indexOf(needle);\n  assert.notEqual(character, -1, `missing ${needle} on line ${line}`);\n  return { line, character: character + offset };\n}\n\ntest('JSON-RPC transport frames and streams Content-Length messages', () => {\n  const message = { jsonrpc: '2.0', id: 7, result: { ok: true } };\n  const framed = encodeMessage(message);\n  assert.match(framed, /^Content-Length: \\d+\\r\\n\\r\\n/);\n\n  const buffer = new MessageBuffer();\n  assert.deepEqual(buffer.push(framed.slice(0, 9)), []);\n  const decoded = buffer.push(framed.slice(9) + framed);\n  assert.equal(decoded.length, 2);\n  assert.deepEqual(decoded[0], message);\n  assert.deepEqual(decoded[1], message);\n});\n\ntest('initialize, shutdown, and exit expose expected LSP lifecycle', async () => {\n  const server = new MiniLangServer();\n  const init = await server.handle(request('initialize', { capabilities: {} }, 1));\n  assert.equal(init.id, 1);\n  assert.equal(init.result.capabilities.textDocumentSync, 2);\n  assert.ok(init.result.capabilities.completionProvider);\n  assert.equal(init.result.capabilities.definitionProvider, true);\n  assert.equal(init.result.capabilities.hoverProvider, true);\n\n  const shutdown = await server.handle(request('shutdown', {}, 2));\n  assert.deepEqual(shutdown, { jsonrpc: '2.0', id: 2, result: null });\n  assert.equal(await server.handle(notification('exit')), null);\n});\n\ntest('shutdown rejects later requests and ignores later notifications', async () => {\n  const server = new MiniLangServer();\n  await server.handle(request('shutdown'));\n\n  const completion = await server.handle(request('textDocument/completion', {\n    textDocument: { uri: 'file:///after-shutdown.mini' },\n    position: { line: 0, character: 0 },\n  }));\n  assert.equal(completion.error.code, -32600);\n\n  assert.equal(await server.handle(notification('textDocument/didOpen', {\n    textDocument: textDocument('file:///after-shutdown.mini', 'return missing'),\n  })), null);\n  assert.deepEqual(server.takeNotifications(), []);\n});\n\ntest('didOpen publishes diagnostics for undefined symbols and wrong arity', async () => {\n  const uri = 'file:///visible-diagnostics.mini';\n  const text = [\n    'fn add(a, b) {',\n    '  return a',\n    '}',\n    'fn main() {',\n    '  let answer = add(1)',\n    '  return missing',\n    '}',\n  ].join('\\n');\n  const server = new MiniLangServer();\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n  const publish = server.takeNotifications().find((item) => item.method === 'textDocument/publishDiagnostics');\n  assert.ok(publish, 'expected publishDiagnostics notification');\n  const diagnostics = publish.params.diagnostics;\n  const messages = diagnostics.map((diag) => diag.message).join('\\n').toLowerCase();\n  assert.match(messages, /undefined.*missing|missing.*undefined/);\n  assert.match(messages, /arity|argument|expected 2/);\n  assert.equal(server.getDiagnostics(uri).length, diagnostics.length);\n});\n\ntest('completion includes keywords, in-scope symbols, functions, and snippets', async () => {\n  const uri = 'file:///visible-completion.mini';\n  const text = [\n    'fn add(a, b) {',\n    '  return a',\n    '}',\n    'fn main() {',\n    '  let local = 1',\n    '  return ',\n    '}',\n  ].join('\\n');\n  const server = new MiniLangServer();\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n  const response = await server.handle(request('textDocument/completion', {\n    textDocument: { uri },\n    position: { line: 5, character: 9 },\n  }, 3));\n  const items = itemsFrom(response);\n  const labels = items.map((item) => item.label);\n  assert.ok(labels.includes('fn'));\n  assert.ok(labels.includes('let'));\n  assert.ok(labels.includes('return'));\n  assert.ok(labels.includes('add'));\n  assert.ok(labels.includes('local'));\n  assert.ok(items.some((item) => item.label === 'return' && /return/.test(JSON.stringify(item))));\n});\n\ntest('definition and hover resolve function symbols', async () => {\n  const uri = 'file:///visible-definition.mini';\n  const text = [\n    'fn inc(value) {',\n    '  return value',\n    '}',\n    'fn main() {',\n    '  let total = inc(1)',\n    '  return total',\n    '}',\n  ].join('\\n');\n  const server = new MiniLangServer();\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n  const definition = await server.handle(request('textDocument/definition', {\n    textDocument: { uri },\n    position: positionOf(text, 4, 'inc', 1),\n  }, 4));\n  assert.equal(definition.result.uri, uri);\n  assert.equal(definition.result.range.start.line, 0);\n\n  const hover = await server.handle(request('textDocument/hover', {\n    textDocument: { uri },\n    position: positionOf(text, 4, 'inc', 1),\n  }, 5));\n  assert.match(JSON.stringify(hover.result.contents), /fn inc\\(value\\)/);\n});\n","exit_code":0,"status":"completed"}}
