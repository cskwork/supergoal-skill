ine(name, lineText, line) {\n  const character = lineText.indexOf(name);\n  return {\n    start: { line, character: character === -1 ? 0 : character },\n    end: { line, character: character === -1 ? (0 + name.length) : (character + name.length) },\n  };\n}\n\nfunction tokenAtPosition(lineText, character) {\n  if (character < 0 || \"'!lineText) return null;\n\n  const safeCharacter = Math.max(0, Math.min(lineText.length, character));\n  let start = safeCharacter;\n  while (start > 0 && isIdentifierChar(lineText[start - 1])) {\n    start -= 1;\n  }\n\n  let end = safeCharacter;\n  while (end < lineText.length && isIdentifierChar(lineText[end])) {\n    end += 1;\n  }\n\n  if (!isIdentifierStart(lineText[start])) return null;\n\n  return { text: lineText.slice(start, end), start, end };\n}\n\nexport class MessageBuffer {\n  constructor() {\n    this.buffer = '\"'';\n  }\n\n  push(chunk) {\n    this.buffer += chunk;\n\n    const messages = [];\n    const separator = '\\\\r\\\\n\\\\r\\\\n';\n\n    while (true) {\n      const headerEnd = this.buffer.indexOf(separator);\n      if (headerEnd < 0) return messages;\n\n      const header = this.buffer.slice(0, headerEnd);\n      const match = /Content-Length:\\\\s*(\\\\d+)/i.exec(header);\n      if (\"'!match) {\n        this.buffer = '\"'';\n        return messages;\n      }\n\n      const length = Number.parseInt(match[1], 10);\n      const messageStart = headerEnd + separator.length;\n      const messageEnd = messageStart + length;\n\n      if (this.buffer.length < messageEnd) return messages;\n\n      const body = this.buffer.slice(messageStart, messageEnd);\n      this.buffer = this.buffer.slice(messageEnd);\n      messages.push(JSON.parse(body));\n    }\n  }\n}\n\nfunction parseMiniLang(text) {\n  const lines = text.split('\\\\n');\n  const globalScope = createScope(0, 'global', null, null);\n  globalScope.startLine = 0;\n  globalScope.endLine = Infinity;\n\n  const scopes = [globalScope];\n  const scopeStack = [globalSc