{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"/bin/zsh -lc \"sed -n '421,680p' src/server.mjs\"","aggregated_output":"    const { parsed } = stored;\n    const position = message.params?.position;\n\n    if (method === 'textDocument/completion') {\n      return {\n        jsonrpc: '2.0',\n        id,\n        result: this._completion(parsed, position),\n      };\n    }\n\n    if (method === 'textDocument/definition') {\n      return {\n        jsonrpc: '2.0',\n        id,\n        result: this._definition(parsed, position),\n      };\n    }\n\n    if (method === 'textDocument/hover') {\n      return {\n        jsonrpc: '2.0',\n        id,\n        result: this._hover(parsed, position),\n      };\n    }\n\n    return null;\n  }\n\n  _publishDiagnostics(uri, parsed) {\n    this.notifications.push({\n      jsonrpc: '2.0',\n      method: 'textDocument/publishDiagnostics',\n      params: {\n        uri,\n        diagnostics: parsed.diagnostics,\n      },\n    });\n  }\n\n  takeNotifications() {\n    const notifications = this.notifications.slice();\n    this.notifications.length = 0;\n    return notifications;\n  }\n\n  getDiagnostics(uri) {\n    return this.documents.get(uri)?.parsed?.diagnostics ?? [];\n  }\n\n  _scopesAtLine(parsed, line) {\n    return parsed.scopes\n      .filter((scope) => scope.startLine <= line && line <= scope.endLine)\n      .sort((a, b) => b.depth - a.depth);\n  }\n\n  _findSymbol(parsed, line, column) {\n    const lineText = parsed.text.split('\\n')[line] || '';\n    const token = tokenAt(lineText, column);\n    if (!token) {\n      return null;\n    }\n\n    for (const scope of this._scopesAtLine(parsed, line)) {\n      if (scope.symbols.has(token.name)) {\n        return scope.symbols.get(token.name);\n      }\n    }\n\n    return null;\n  }\n\n  _completion(parsed, position) {\n    if (!position || typeof position.character !== 'number') {\n      return [];\n    }\n\n    const lineText = parsed.text.split('\\n')[position.line] || '';\n    const column = position.character;\n    let prefix = '';\n\n    for (let i = column - 1; i >= 0; i -= 1) {\n      const char = lineText[i] || '';\n      if (/[A-Za-z0-9_]/.test(char)) {\n        prefix = `${char}${prefix}`;\n      } else {\n        break;\n      }\n    }\n\n    const byName = new Map();\n    const items = [];\n\n    const addKeyword = (keyword) => {\n      if (!keyword.startsWith(prefix)) {\n        return;\n      }\n\n      byName.set(keyword, {\n        label: keyword,\n        kind: 14,\n        insertText: keyword,\n        insertTextFormat: 1,\n      });\n    };\n\n    addKeyword('fn');\n    addKeyword('let');\n    addKeyword('return');\n\n    for (const scope of this._scopesAtLine(parsed, position.line)) {\n      for (const symbol of scope.symbols.values()) {\n        if (!symbol.name.startsWith(prefix)) {\n          continue;\n        }\n\n        if (byName.has(symbol.name)) {\n          continue;\n        }\n\n        if (symbol.kind === 'function') {\n          const params = symbol.params\n            .map((param, i) => `\\${${i + 1}}:${param}`)\n            .join(', ');\n          byName.set(symbol.name, {\n            label: symbol.name,\n            kind: 3,\n            insertText: `${symbol.name}(${params})`,\n            insertTextFormat: 2,\n            detail: `function ${symbol.name}`,\n          });\n        } else {\n          byName.set(symbol.name, {\n            label: symbol.name,\n            kind: 6,\n            insertText: symbol.name,\n            insertTextFormat: 1,\n          });\n        }\n      }\n    }\n\n    for (const item of byName.values()) {\n      items.push(item);\n    }\n\n    return {\n      isIncomplete: false,\n      items,\n    };\n  }\n\n  _definition(parsed, position) {\n    if (!position || typeof position.character !== 'number') {\n      return null;\n    }\n\n    const symbol = this._findSymbol(parsed, position.line, position.character);\n    if (!symbol || !symbol.range) {\n      return null;\n    }\n\n    return {\n      uri: parsed.uri,\n      range: symbol.range,\n    };\n  }\n\n  _hover(parsed, position) {\n    if (!position || typeof position.character !== 'number') {\n      return null;\n    }\n\n    const symbol = this._findSymbol(parsed, position.line, position.character);\n    if (!symbol) {\n      return null;\n    }\n\n    if (symbol.kind === 'function') {\n      return {\n        contents: `fn ${symbol.name}(${symbol.params.join(', ')})`,\n      };\n    }\n\n    return {\n      contents: `${symbol.kind} ${symbol.name}`,\n    };\n  }\n}\n","exit_code":0,"status":"completed"}}
