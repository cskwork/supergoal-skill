export function summarizeOrders(orders) {
  if (!Array.isArray(orders)) {
    throw new TypeError('orders must be an array');
  }

  const summaries = new Map();

  for (const order of orders) {
    if (!order || typeof order !== 'object' || Array.isArray(order)) {
      throw new TypeError('order must be an object');
    }

    if (order.status !== 'paid') {
      continue;
    }

    assertValidPaidOrder(order);

    const summary = summaries.get(order.currency);
    if (!summary) {
      summaries.set(order.currency, {
        currency: order.currency,
        count: 1,
        totalCents: order.amountCents,
        firstOrderDate: order.createdAt,
        lastOrderDate: order.createdAt,
      });
      continue;
    }

    summary.count += 1;
    summary.totalCents += order.amountCents;
    if (order.createdAt < summary.firstOrderDate) {
      summary.firstOrderDate = order.createdAt;
    }
    if (order.createdAt > summary.lastOrderDate) {
      summary.lastOrderDate = order.createdAt;
    }
  }

  return Array.from(summaries.values()).sort(
    (left, right) =>
      right.totalCents - left.totalCents ||
      left.currency.localeCompare(right.currency),
  );
}

function assertValidPaidOrder(order) {
  if (!/^[A-Z]{3}$/.test(order.currency)) {
    throw new TypeError('currency must be an uppercase 3-letter code');
  }
  if (!Number.isInteger(order.amountCents) || order.amountCents <= 0) {
    throw new TypeError('amountCents must be a positive integer');
  }
  if (!isValidDate(order.createdAt)) {
    throw new TypeError('createdAt must be a YYYY-MM-DD date');
  }
}

function isValidDate(value) {
  if (typeof value !== 'string' || !/^\d{4}-\d{2}-\d{2}$/.test(value)) {
    return false;
  }

  const [year, month, day] = value.split('-').map(Number);
  const date = new Date(Date.UTC(year, month - 1, day));

  return (
    date.getUTCFullYear() === year &&
    date.getUTCMonth() === month - 1 &&
    date.getUTCDate() === day
  );
}

