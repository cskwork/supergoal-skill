{"type":"item.started","item":{"id":"item_32","type":"command_execution","command":"/bin/zsh -lc \"cat > src/billing.mjs <<'EOF'\nconst RATES = {\n  standard: 2000,\n  reduced: 500,\n  exempt: 0,\n};\n\nexport function computeInvoice(invoice = {}) {\n  const {\n    lines = [],\n    orderDiscountMinor = 0,\n    shippingMinor = 0,\n  } = invoice;\n\n  let subtotal = 0;\n  const lineNets = [];\n\n  for (const line of lines) {\n    const gross = line.qty * line.unitPriceMinor;\n    const lineDiscount = Math.round(gross * ((line.lineDiscountBps || 0) / 10000));\n    const net = Math.max(0, gross - lineDiscount);\n    const rateBps = RATES[line.category] ?? RATES.standard;\n\n    subtotal += net;\n    lineNets.push({ net, rateBps });\n  }\n\n  const taxableSubtotal = Math.max(0, subtotal - orderDiscountMinor);\n  let totalTax = 0;\n\n  if (subtotal > 0 && taxableSubtotal > 0) {\n    for (const { net, rateBps } of lineNets) {\n      const discountedNet = (net / subtotal) * taxableSubtotal;\n      totalTax += Math.round((discountedNet * rateBps) / 10000);\n    }\n  }\n\n  const grandTotal = Math.max(0, taxableSubtotal + totalTax + shippingMinor);\n\n  return { subtotal, totalTax, shipping: shippingMinor, grandTotal };\n}\nEOF\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
