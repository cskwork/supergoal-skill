 1)), severity: 1, source: 'minilang', message };\n    47\t}\n    48\t\n    49\tfunction stripComment(line) {\n    50\t  const at = line.indexOf('#');\n    51\t  return at < 0 ? line : line.slice(0, at);\n    52\t}\n    53\t\n    54\tfunction scanNames(text) {\n    55\t  const names = [];\n    56\t  const re = /\\b[A-Za-z_][A-Za-z0-9_]*\\b/g;\n    57\t  let match;\n    58\t  while ((match = re.exec(text))) names.push({ name: match[0], start: match.index, end: match.index + match[0].length });\n    59\t  return names;\n    60\t}\n    61\t\n    62\tfunction parseCall(expr, baseColumn) {\n    63\t  const match = /^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*\\((.*)\\)\\s*$/.exec(expr);\n    64\t  if (!match) return null;\n    65\t  const before = expr.indexOf(match[1]);\n    66\t  const args = match[2].trim() ? match[2].split(',').map((arg) => arg.trim()).filter(Boolean) : [];\n    67\t  return { name: match[1], args, start: baseColumn + before, end: baseColumn + before + match[1].length };\n    68\t}\n    69\t\n    70\tfunction expressionUses(expr, baseColumn, scope) {\n    71\t  const call = parseCall(expr, baseColumn);\n    72\t  const names = scanNames(expr).filter((item) => !KEYWORDS.includes(item.name));\n    73\t  const scoped = (item) => ({ ...item, scope, start: item.start + baseColumn, end: item.end + baseColumn, line: null });\n    74\t  return { call: call ? { ...call, scope } : null, names: names.map(scoped) };\n    75\t}\n    76\t\n    77\texport function parseMiniLang(text) {\n    78\t  const diagnostics = [];\n    79\t  const functions = new Map();\n    80\t  const symbols = [];\n    81\t  const references = [];\n    82\t  let current = null;\n    83\t\n    84\t  const lines = text.split(/\\r?\\n/);\n    85\t  lines.forEach((raw, lineNo) => {\n    86\t    const line = stripComment(raw);\n    87\t    const trimmed = line.trim();\n    88\t    const indent = line.length - line.trimStart().length;\n    89\t    if (!trimmed) return;\n    90\t\n    91\t    const fn = /^f