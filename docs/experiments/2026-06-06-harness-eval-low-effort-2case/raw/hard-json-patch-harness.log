+  assertObject(parent);
+  if (!Object.prototype.hasOwnProperty.call(parent, key)) {
+    throw new TypeError('path does not exist');
+  }
+  parent[key] = value;
+  return document;
+}
+
+function getValue(document, path) {
+  let current = document;
+
+  for (const token of parsePointer(path)) {
+    current = readChild(current, token);
+  }
+
+  return current;
+}
+
+function resolveParent(document, path) {
+  const tokens = parsePointer(path);
+
+  if (tokens.length === 0) {
+    return { parent: null, key: '' };
+  }
+
+  let parent = document;
+  for (const token of tokens.slice(0, -1)) {
+    parent = readChild(parent, token);
+  }
+
+  return { parent, key: tokens[tokens.length - 1] };
+}
+
+function readChild(value, key) {
+  if (Array.isArray(value)) {
+    const index = parseArrayIndex(key, false);
+    if (index >= value.length) {
+      throw new TypeError('array index out of bounds');
+    }
+    return value[index];
+  }
