eaders(lines) {\n  const functions = [];\n  for (let lineIndex = 0; lineIndex < lines.length; lineIndex += 1) {\n    const line = lines[lineIndex];\n    const match = line.match(FN_HEADER_RE);\n    if (!match) continue;\n    const name = match[1];\n    const paramsText = match[2].trim();\n    const params = paramsText ? paramsText.split(',').map((p) => p.trim()).filter(Boolean) : [];\n    const nameIndex = line.indexOf(name);\n    functions.push({\n      kind: 'function',\n      name,\n      params,\n      owner: 'global',\n      declarationLine: lineIndex,\n      declarationStart: { line: lineIndex, character: nameIndex },\n      declarationEnd: { line: lineIndex, character: nameIndex + name.length },\n      range: {\n        start: { line: lineIndex, character: 0 },\n        end: { line: lineIndex, character: line.length },\n      },\n      bodyRange: null,\n      id: `fn:${lineIndex}:${name}`,\n      detail: `fn ${name}(${params.join(', ')})`,\n    });\n  }\n  return functions;\n}\n\nfunction parseBodyRange(lines, fn) {\n  const declarationLine = fn.declarationLine;\n  const searchStartCol = fn.declarationEnd.character;\n\n  let openLine = -1;\n  let openColumn = -1;\n  for (let i = declarationLine; i < lines.length; i += 1) {\n    const line = lines[i];\n    const idx = line.indexOf('{', i === declarationLine ? searchStartCol : 0);\n    if (idx !== -1) {\n      openLine = i;\n      openColumn = idx;\n      break;\n    }\n    if (i > declarationLine && line.match(FN_HEADER_RE)) {\n      return {\n        bodyRange: {\n          start: { line: declarationLine + 1, character: 0 },\n          end: { line: i - 1, character: i > 0 ? lines[i - 1].length : 0 },\n        },\n        syntaxError: true,\n      };\n    }\n  }\n\n  if (openLine === -1) {\n    return {\n      bodyRange: {\n        start: { line: declarationLine + 1, character: 0 },\n        end: { line: lines.length - 1, character: lines[lines.length - 1]?.length || 0 },\n      },\n      syntaxError: true,\n    };\n  }\n\n  let depth = 1;\n  for (let lineIndex = openLine; lineIndex < lines.length; lineIndex += 1) {\n    const line = lines[lineIndex];\n    const startCol = lineIndex === openLine ? openColumn + 1 : 0;\n    for (let j = startCol; j < line.length; j += 1) {\n      const ch = line[j];\n      if (ch === '{') depth += 1;\n      if (ch === '}') {\n        depth -= 1;\n        if (depth === 0) {\n          return {\n            bodyRange: {\n              start: { line: openLine, character: openColumn + 1 },\n              end: { line: lineIndex, character: j + 1 },\n            },\n            syntaxError: false,\n          };\n        }\n      }\n    }\n\n    if (depth > 0 && lineIndex > openLine && line.match(FN_HEADER_RE)) {\n      return {\n        bodyRange: {\n          start: { line: openLine, character: openColumn + 1 },\n          end: { line: lineIndex - 1, character: lineIndex > 0 ? lines[lineIndex - 1].length : 0 },\n        },\n        syntaxError: true,\n      };\n    }\n  }\n\n  return {\n    bodyRange: {\n      start: { line: openLine, character: openColumn + 1 },\n      end: { line: lines.length - 1, character: lines[lines.length - 1]?.length || 0 },\n    },\n    syntaxError: true,\n  };\n}\n\nfunction makeRange(line, start, end) {\n  return {\n    start: { line, character: start },\n    end: { line, character: end },\n  };\n}\n\nfunction parseCallArgumentEnd(line, openParenIndex) {\n  let depth = 0;\n  for (let i = openParenIndex; i < line.length; i += 1) {\n    const ch = line[i];\n    if (ch === '(') depth += 1;\n    else if (ch === ')' && depth > 0) {\n      depth -= 1;\n      if (depth === 0) {\n        return i;\n      }\n    }\n  }\n  return line.length;\n}\n\nfunction parseExpression(line, lineIndex, charBase, isDefined, resolveSymbol, diagnostics) {\n  for (let i = 0; i < line.length; i += 1) {\n    const ch = line[i];\n    if (!isIdentifierStart(ch)) continue;\n\n    let start = i;\n    while (i < line.length && isIdentifierChar(line[