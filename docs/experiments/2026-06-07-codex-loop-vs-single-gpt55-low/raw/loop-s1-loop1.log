].length), containerName: currentFunction?.name });\n   189\t      const exprStart = code.indexOf('=') + 1;\n   190\t      validateExpression(code.slice(exprStart), line, exprStart);\n   191\t      continue;\n   192\t    }\n   193\t\n   194\t    const ret = trimmed.match(/^return(?:\\s+(.+))?$/);\n   195\t    if (ret) {\n   196\t      if (!currentFunction) diagnostics.push({ range: range(line, base, base + 6), severity: 1, source: 'MiniLang', message: 'Return outside function' });\n   197\t      if (ret[1]) validateExpression(ret[1], line, code.indexOf(ret[1]));\n   198\t      continue;\n   199\t    }\n   200\t\n   201\t    validateExpression(trimmed, line, base);\n   202\t    diagnostics.push({\n   203\t      range: range(line, base, code.length),\n   204\t      severity: 1,\n   205\t      source: 'MiniLang',\n   206\t      message: `Could not parse statement: ${trimmed}`,\n   207\t    });\n   208\t  }\n   209\t\n   210\t  return { text, diagnostics, symbols, references };\n   211\t}\n   212\t\n   213\tfunction completionItems(parsed) {\n   214\t  const symbolItems = parsed.symbols.map((symbol) => ({\n   215\t    label: symbol.name,\n   216\t    kind: symbol.kind === 'function' ? 3 : 6,\n   217\t    detail: symbol.kind === 'function' ? `fn ${symbol.name}(${symbol.params.join(', ')})` : symbol.kind,\n   218\t  }));\n   219\t  return [\n   220\t    { label: 'fn', kind: 14 },\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/server.mjs | sed -n '221,520p'\"","aggregated_output":"   221\t    { label: 'let', kind: 14 },\n   222\t    { label: 'return', kind: 14 },\n   223\t    ...symbolItems,\n   224\t  ];\n   225\t}\n   226\t\n   227\texport class MiniLangServer {\n   228\t  constructor() {\n   229\t    this.documents = new Map();\n   230\t    this.notifications = [];\n   231\t    this.shutdown = false;\n   232\t  }\n   233\t\n   234\t  async handle(message) {\n   235\t    if (message.method === 'initialize') {\n   236\t      return {\n   237\t        jsonrpc: '2.0',\n   238\t        id: message.id,\n   239\t        result: {\n   240\t          capabilities: {\n   241\t            textDocumentSync: 2,\n   242\t            completionProvider: { triggerCharacters: [] },\n   243\t            definitionProvider: true,\n   244\t            hoverProvider: true,\n   245\t          },\n   246\t        },\n   247\t      };\n   248\t    }\n   249\t\n   250\t    if (message.method === 'shutdown') {\n   251\t      this.shutdown = true;\n   252\t      return { jsonrpc: '2.0', id: message.id, result: null };\n   253\t    }\n   254\t\n   255\t    if (message.method === 'exit') return null;\n   256\t    if (message.method === 'textDocument/didOpen') return this.didOpen(message.params.textDocument);\n   257\t    if (message.method === 'textDocument/didChange') return this.didChange(message.params);\n   258\t    if (message.method === 'textDocument/completion') return this.response(message.id, this.completion(message.params.textDocument.uri));\n   259\t    if (message.method === 'textDocument/definition') return this.response(message.id, this.definition(message.params.textDocument.uri, message.params.position));\n   260\t    if (message.method === 'textDocument/hover') return this.response(message.id, this.hover(message.params.textDocument.uri, message.params.position));\n   261\t\n   262\t    return message.id == null ? null : this.response(message.id, null);\n   263\t  }\n   264\t\n   265\t  response(id, result) {\n   266\t    return { jsonrpc: '2.0', id, result };\n   267\t  }\n   268\t\n   269\t  didOpen(textDocument) {\n   270\t    this.updateDocument(textDocument.uri, textDocument.text, textDocument.version);\n   271\t    return null;\n   272\t  }\n   273\t\n   274\t  didChange(params) {\n   275\t    let text = this.documents.get(params.textDocument.uri)?.text ?? '';\n   276\t    for (const change of params.contentChanges) {\n   277\t      text = applyChange(text, change);\n   278\t    }\n   279\t    this.updateDocument(params.textDocument.uri, text, params.textDocument.version);\n   280\t    return null;\n   281\t  }\n   282\t\n   283\t  updateDocument(uri, text, version) {\n   284\t    const parsed = parseMiniLang(text);\n   285\t    this.documents.set(uri, { uri, text, version, parsed });\n   286\t    this.notifications.push({\n   287\t      jsonrpc: '2.0',\n   288\t      method: 'textDocument/publishDiagnostics',\n   289\t      params: { uri, diagnostics: parsed.diagnostics, version },\n   290\t    });\n   291\t  }\n   292\t\n   293\t  takeNotifications() {\n   294\t    const out = this.notifications;\n   295\t    this.notifications = [];\n   296\t    return out;\n   297\t  }\n   298\t\n   299\t  getDiagnostics(uri) {\n   300\t    return this.documents.get(uri)?.parsed.diagnostics ?? [];\n   301\t  }\n   302\t\n   303\t  completion(uri) {\n   304\t    return { isIncomplete: false, items: completionItems(this.documents.get(uri)?.parsed ?? parseMiniLang('')) };\n   305\t  }\n   306\t\n   307\t  definition(uri, position) {\n   308\t    const doc = this.documents.get(uri);\n   309\t    const found = doc && wordAt(doc.text, position);\n   310\t    const symbol = found && this.resolveAt(doc.parsed, found.name);\n   311\t    return symbol ? { uri, range: symbol.range } : null;\n   312\t  }\n   313\t\n   314\t  hover(uri, position) {\n   315\t    const doc = this.documents.get(uri);\n   316\t    const found = doc && wordAt(doc.text, position);\n   317\t    const symbol = found && this.resolveAt(doc.parsed, found.name);\n   318\t    if (!symbol) return null;\n   319\t    const value = symbol.kind === 'function'\n   320\t      ? `fn ${symbol.name}(${symbol.params.join(', ')})`\n   321\t      : `${symbol.kind} ${symbol.name}`;\n   322\t    return { contents: { kind: 'markdown', value }, range: found.range };\n   323\t  }\n   324\t\n   325\t  resolveAt(parsed, name) {\n   326\t    return parsed.symbols.find((symbol) => symbol.name === name && symbol.kind === 'function')\n   327\t      ?? parsed.symbols.find((symbol) => symbol.name === name)\n   328\t      ?? null;\n   329\t  }\n   330\t}\n","exit_code":0,"status":"completed"}}
