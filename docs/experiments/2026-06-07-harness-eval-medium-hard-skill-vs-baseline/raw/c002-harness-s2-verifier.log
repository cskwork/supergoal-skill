{"type":"item.completed","item":{"id":"item_17","type":"command_execution","command":"/bin/zsh -lc 'nl -ba test/cache.visible.test.mjs'","aggregated_output":"     1\timport assert from 'node:assert/strict';\n     2\timport { test } from 'node:test';\n     3\timport { AsyncCache } from '../src/cache.mjs';\n     4\t\n     5\ttest('loads then caches; a second sequential get does not reload', async () => {\n     6\t  const cache = new AsyncCache();\n     7\t  let calls = 0;\n     8\t  const loader = async (k) => { calls += 1; return `v:${k}`; };\n     9\t  assert.equal(await cache.get('a', loader), 'v:a');\n    10\t  assert.equal(await cache.get('a', loader), 'v:a');\n    11\t  assert.equal(calls, 1);\n    12\t  assert.equal(cache.has('a'), true);\n    13\t});\n    14\t\n    15\ttest('clear() drops cached values', async () => {\n    16\t  const cache = new AsyncCache();\n    17\t  const loader = async (k) => `v:${k}`;\n    18\t  await cache.get('a', loader);\n    19\t  cache.clear();\n    20\t  assert.equal(cache.has('a'), false);\n    21\t});\n    22\t\n    23\ttest('distinct keys load independently', async () => {\n    24\t  const cache = new AsyncCache();\n    25\t  const loader = async (k) => `v:${k}`;\n    26\t  assert.equal(await cache.get('a', loader), 'v:a');\n    27\t  assert.equal(await cache.get('b', loader), 'v:b');\n    28\t});\n    29\t\n    30\ttest('concurrent gets for the same key share one in-flight load', async () => {\n    31\t  const cache = new AsyncCache();\n    32\t  let calls = 0;\n    33\t  let resolveLoad;\n    34\t  const loader = async (k) => {\n    35\t    calls += 1;\n    36\t    return new Promise((resolve) => {\n    37\t      resolveLoad = () => resolve(`v:${k}`);\n    38\t    });\n    39\t  };\n    40\t\n    41\t  const first = cache.get('a', loader);\n    42\t  const second = cache.get('a', loader);\n    43\t  const third = cache.get('a', loader);\n    44\t\n    45\t  assert.equal(calls, 1);\n    46\t  resolveLoad();\n    47\t  assert.deepEqual(await Promise.all([first, second, third]), ['v:a', 'v:a', 'v:a']);\n    48\t  assert.equal(await cache.get('a', loader), 'v:a');\n    49\t  assert.equal(calls, 1);\n    50\t});\n    51\t\n    52\ttest('concurrent gets for different keys do not block each other', async () => {\n    53\t  const cache = new AsyncCache();\n    54\t  const started = [];\n    55\t  const resolvers = new Map();\n    56\t  const loader = async (k) => {\n    57\t    started.push(k);\n    58\t    return new Promise((resolve) => {\n    59\t      resolvers.set(k, () => resolve(`v:${k}`));\n    60\t    });\n    61\t  };\n    62\t\n    63\t  const first = cache.get('a', loader);\n    64\t  const second = cache.get('b', loader);\n    65\t\n    66\t  assert.deepEqual(started, ['a', 'b']);\n    67\t  resolvers.get('b')();\n    68\t  assert.equal(await second, 'v:b');\n    69\t  resolvers.get('a')();\n    70\t  assert.equal(await first, 'v:a');\n    71\t});\n    72\t\n    73\ttest('rejected in-flight loads are not cached and can be retried', async () => {\n    74\t  const cache = new AsyncCache();\n    75\t  let calls = 0;\n    76\t  let rejectLoad;\n    77\t  const error = new Error('load failed');\n    78\t  const loader = async (k) => {\n    79\t    calls += 1;\n    80\t    if (calls === 1) {\n    81\t      return new Promise((resolve, reject) => {\n    82\t        rejectLoad = () => reject(error);\n    83\t      });\n    84\t    }\n    85\t    return `v:${k}`;\n    86\t  };\n    87\t\n    88\t  const first = cache.get('a', loader);\n    89\t  const second = cache.get('a', loader);\n    90\t\n    91\t  assert.equal(calls, 1);\n    92\t  rejectLoad();\n    93\t  await assert.rejects(first, error);\n    94\t  await assert.rejects(second, error);\n    95\t  assert.equal(cache.has('a'), false);\n    96\t  assert.equal(await cache.get('a', loader), 'v:a');\n    97\t  assert.equal(calls, 2);\n    98\t});\n","exit_code":0,"status":"completed"}}
