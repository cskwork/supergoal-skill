sition: positionOf(text, 5, 'value', 1),\n    98\t  }));\n    99\t\n   100\t  assert.equal(definition.result.uri, uri);\n   101\t  assert.deepEqual(definition.result.range.start, { line: 3, character: 8 });\n   102\t});\n   103\t\n   104\ttest('comments are ignored for diagnostics and completion prefixes', async () => {\n   105\t  const server = new MiniLangServer();\n   106\t  const uri = 'file:///comments.mini';\n   107\t  const text = [\n   108\t    'fn real() {',\n   109\t    '  return 1',\n   110\t    '}',\n   111\t    '# fn fake(unclosed',\n   112\t    '# missing(1)',\n   113\t    'fn main() {',\n   114\t    '  re # missing(2)',\n   115\t    '}',\n   116\t  ].join('\\n');\n   117\t\n   118\t  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n   119\t  assert.equal(server.getDiagnostics(uri).length, 0);\n   120\t\n   121\t  const response = await server.handle(request('textDocument/completion', {\n   122\t    textDocument: { uri },\n   123\t    position: { line: 6, character: 4 },\n   124\t  }));\n   125\t  const labels = itemsFrom(response).map((item) => item.label);\n   126\t  assert.deepEqual(labels, ['real']);\n   127\t});\n   128\t\n   129\ttest('didChange replaces stale diagnostics and is idempotent for the same full text', async () => {\n   130\t  const server = new MiniLangServer();\n   131\t  const uri = 'file:///change-diagnostics.mini';\n   132\t  const badText = [\n   133\t    'fn takesOne(value) {',\n   134\t    '  return value',\n   135\t    '}',\n   136\t    'fn main() {',\n   137\t    '  missing(1)',\n   138\t    '  takesOne(1, 2)',\n   139\t    '}',\n   140\t  ].join('\\n');\n   141\t  const goodText = [\n   142\t    'fn takesOne(value) {',\n   143\t    '  return value',\n   144\t    '}',\n   145\t    'fn main() {',\n   146\t    '  takesOne(1)',\n   147\t    '}',\n   148\t  ].join('\\n');\n   149\t\n   150\t  await server.handle(notification('textDocument/didOpen', { textDocument: textDocumen