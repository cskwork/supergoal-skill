e: {\n      start: { line, character: match.index },\n      end: { line, character: match.index + match[0].length }\n    }\n  };\n}\n\nfunction symbolKey(line, from, to) {\n  return `${line}:${from}-${to}`;\n}\n\nfunction countCallArgs(lineText, openIndex) {\n  let depth = 0;\n  let closeIndex = -1;\n\n  for (let i = openIndex; i < lineText.length; i += 1) {\n    const char = lineText[i];\n    if (char === '(') {\n      depth += 1;\n    } else if (char === ')') {\n      depth -= 1;\n      if (depth === 0) {\n        closeIndex = i;\n        break;\n      }\n    }\n  }\n\n  if (closeIndex === -1) {\n    return { count: null, closeIndex };\n  }\n\n  const argsText = lineText.slice(openIndex + 1, closeIndex).trim();\n  if (!argsText) {\n    return { count: 0, closeIndex };\n  }\n\n  let nested = 0;\n  let count = 1;\n  for (const char of argsText) {\n    if (char === '(') {\n      nested += 1;\n    } else if (char === ')') {\n      nested -= 1;\n    } else if (char === ',' && nested === 0) {\n      count += 1;\n    }\n  }\n\n  return { count, closeIndex };\n}\n","exit_code":0,"status":"completed"}}
