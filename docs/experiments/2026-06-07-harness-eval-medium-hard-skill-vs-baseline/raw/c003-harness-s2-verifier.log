{"type":"item.completed","item":{"id":"item_20","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,140p' src/order.mjs | cat -vet\"","aggregated_output":"export function calculateInvoice(order) {$\n  let subtotal = calculateSubtotal(order.items);$\n  let discount = calculateDiscount(order, subtotal);$\n  let taxableAmount = subtotal - discount;$\n  let tax = calculateTax(order.region, taxableAmount);$\n  let shipping = calculateShipping(order, taxableAmount);$\n  let total = taxableAmount + tax + shipping;$\n$\n  return {$\n    subtotal: roundCents(subtotal),$\n    discount: roundCents(discount),$\n    tax: roundCents(tax),$\n    shipping: roundCents(shipping),$\n    total: roundCents(total),$\n  };$\n}$\n$\nfunction calculateSubtotal(items) {$\n  let subtotal = 0;$\n  for (let i = 0; i < items.length; i++) {$\n    subtotal += items[i].price * items[i].qty;$\n  }$\n  return subtotal;$\n}$\n$\nfunction calculateDiscount(order, subtotal) {$\n  let discount = calculateCouponDiscount(order, subtotal);$\n  if (order.vip && discount < subtotal * 0.05) {$\n    discount = subtotal * 0.05;$\n  }$\n  return discount;$\n}$\n$\nfunction calculateCouponDiscount(order, subtotal) {$\n  if (!order.coupon) {$\n    return 0;$\n  }$\n  if (order.coupon === 'SAVE10') {$\n    return subtotal * 0.1;$\n  }$\n  if (order.coupon === 'SAVE20') {$\n    if (subtotal >= 100) {$\n      return subtotal * 0.2;$\n    }$\n    return subtotal * 0.1;$\n  }$\n  if (order.coupon === 'HALF' && order.vip) {$\n    return subtotal * 0.5;$\n  }$\n  return 0;$\n}$\n$\nfunction calculateTax(region, taxableAmount) {$\n  if (region === 'US') {$\n    return taxableAmount * 0.07;$\n  }$\n  if (region === 'EU') {$\n    return taxableAmount * 0.2;$\n  }$\n  return taxableAmount * 0.1;$\n}$\n$\nfunction calculateShipping(order, taxableAmount) {$\n  let shipping = 0;$\n  if (taxableAmount < 50) {$\n    shipping = 7.5;$\n  } else if (taxableAmount < 100) {$\n    shipping = 3;$\n  } else {$\n    shipping = 0;$\n  }$\n  if (order.express) {$\n    shipping += 12;$\n  }$\n  return shipping;$\n}$\n$\nfunction roundCents(amount) {$\n  return Math.round(amount * 100) / 100;$\n}$\n","exit_code":0,"status":"completed"}}
