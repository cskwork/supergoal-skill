+const CONTROL_CHARACTER = /[\u0000-\u001f\u007f]/;
+
 export function isSafeRedirect(rawUrl, allowedHosts = ['example.com']) {
+  if (
+    typeof rawUrl !== 'string' ||
+    CONTROL_CHARACTER.test(rawUrl) ||
+    rawUrl.includes('\\')
+  ) {
+    return false;
+  }
+
   try {
     const url = new URL(rawUrl);
-    if (!['http:', 'https:'].includes(url.protocol)) return false;
-    return allowedHosts.some((host) => url.hostname.endsWith(host));
+    if (url.protocol !== 'http:' && url.protocol !== 'https:') return false;
+    if (hasUserinfo(rawUrl, url)) return false;
+
+    const hostname = normalizeHostname(url.hostname);
+    if (!hostname || isUnsafeHostname(hostname)) return false;
+
+    return normalizeAllowedHosts(allowedHosts).some((allowedHost) => {
+      return hostname === allowedHost || hostname.endsWith(`.${allowedHost}`);
+    });
   } catch {
     return false;
   }
 }
+
+function normalizeAllowedHosts(allowedHosts) {
+  if (!Array.isArray(allowedHosts)) return [];
+
+  return allowedHosts
+    .filter((host) => typeof host === 'string')
+    .map((host) => normalizeHostname(host.trim()))
+    .filter((host) => host && !isUnsafeHostname(host));
+}
+
+function normalizeHostname(hostname) {
+  return hostname.toLowerCase().replace(/\.$/, '');
+}
+
+function hasUserinfo(rawUrl, url) {
+  if (url.username || url.password) return true;
+
+  const match = rawUrl.match(/^[a-z][a-z\d+.-]*:\/\/([^/?#]*)/i);
+  return Boolean(match?.[1].includes('@'));
+}
+
+function isUnsafeHostname(hostname) {
+  if (hostname.replace(/\.+$/, '') === 'localhost') return true;
+
+  const ipv4 = parseIPv4(hostname);
+  if (ipv4 !== null) return isUnsafeIPv4(ipv4);
+
+  const ipv6 = parseIPv6Hostname(hostname);
+  return ipv6 !== null && isUnsafeIPv6(ipv6);
+}
+
+function parseIPv4(hostname) {
+  const parts = hostname.split('.');
+  if (parts.length !== 4) return null;
+
+  let value = 0;
+  for (const part of parts) {
+    if (!/^\d+$/.test(part)) return null;
+    const octet = Number(part);
+    if (octet < 0 || octet > 255) return null;
+    value = value * 256 + octet;
+  }
+
+  return value >>> 0;
+}
+
+function isUnsafeIPv4(value) {
+  const first = (value >>> 24) & 255;
+  const second = (value >>> 16) & 255;
+
+  return (
+    first === 0 ||
+    first === 10 ||
+    first === 127 ||
+    (first === 169 && second === 254) ||
+    (first === 172 && second >= 16 && second <= 31) ||
+    (first === 192 && second === 168)
+  );
+}
+
+function parseIPv6Hostname(hostname) {
+  if (!hostname.startsWith('[') || !hostname.endsWith(']')) return null;
+
+  const halves = hostname.slice(1, -1).split('::');
+  if (halves.length > 2) return null;
+
+  const left = parseHextets(halves[0]);
+  const right = parseHextets(halves[1] ?? '');
+  if (!left || !right) return null;
+
+  const missing = 8 - left.length - right.length;
+  if (missing < (halves.length === 2 ? 1 : 0)) return null;
+  if (halves.length === 1 && missing !== 0) return null;
+
+  return [...left, ...Array(missing).fill(0), ...right];
+}
+
+function parseHextets(value) {
+  if (!value) return [];
+
+  return value.split(':').map((part) => {
+    if (!/^[\da-f]{1,4}$/i.test(part)) return null;
+    return Number.parseInt(part, 16);
+  });
+}
+
+function isUnsafeIPv6(words) {
+  const isLoopback = words.slice(0, 7).every((word) => word === 0) && words[7] === 1;
+  const isUnspecified = words.every((word) => word === 0);
+  const isUniqueLocal = (words[0] & 0xfe00) === 0xfc00;
+  const isLinkLocal = (words[0] & 0xffc0) === 0xfe80;
+  const isIPv4Mapped = words.slice(0, 5).every((word) => word === 0) && words[5] === 0xffff;
+  const mappedIPv4 = ((words[6] << 16) | words[7]) >>> 0;
+
+  return (
+    isLoopback ||
+    isUnspecified ||
+    isUniqueLocal ||
+    isLinkLocal ||
+    (isIPv4Mapped && isUnsafeIPv4(mappedIPv4))
+  );
+}
