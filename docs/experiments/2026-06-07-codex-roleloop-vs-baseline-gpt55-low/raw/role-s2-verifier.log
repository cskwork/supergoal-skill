{"type":"item.completed","item":{"id":"item_6","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' src/server.mjs\"","aggregated_output":"const KEYWORDS = ['fn', 'let', 'return'];\nconst IDENT = /[A-Za-z_][A-Za-z0-9_]*/g;\n\nexport function encodeMessage(message) {\n  const body = JSON.stringify(message);\n  return `Content-Length: ${Buffer.byteLength(body, 'utf8')}\\r\\n\\r\\n${body}`;\n}\n\nexport class MessageBuffer {\n  constructor() {\n    this.buffer = Buffer.alloc(0);\n  }\n\n  push(chunk) {\n    const next = Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk), 'utf8');\n    this.buffer = Buffer.concat([this.buffer, next]);\n    const messages = [];\n\n    while (true) {\n      const split = this.buffer.indexOf('\\r\\n\\r\\n');\n      if (split < 0) return messages;\n      const header = this.buffer.subarray(0, split).toString('ascii');\n      const match = /^Content-Length:\\s*(\\d+)/im.exec(header);\n      if (!match) throw new Error('Missing Content-Length header');\n\n      const start = split + 4;\n      const length = Number(match[1]);\n      if (this.buffer.length < start + length) return messages;\n\n      const body = this.buffer.subarray(start, start + length).toString('utf8');\n      this.buffer = this.buffer.subarray(start + length);\n      messages.push(JSON.parse(body));\n    }\n  }\n}\n\nfunction pos(line, character) {\n  return { line, character };\n}\n\nfunction range(line, start, end) {\n  return { start: pos(line, start), end: pos(line, end) };\n}\n\nfunction diag(line, start, end, message) {\n  return {\n    range: range(line, start, Math.max(end, start + 1)),\n    severity: 1,\n    source: 'minilang',\n    message,\n  };\n}\n\nfunction stripComment(line) {\n  const at = line.indexOf('#');\n  return at < 0 ? line : line.slice(0, at);\n}\n\nfunction splitArgs(text) {\n  const trimmed = text.trim();\n  return trimmed ? trimmed.split(',').map((part) => part.trim()).filter(Boolean) : [];\n}\n\nfunction scanReferences(expr, line, baseColumn, scope) {\n  const calls = [];\n  const callSpans = [];\n  for (const match of expr.matchAll(/([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^)]*)\\)/g)) {\n    calls.push({\n      name: match[1],\n      args: splitArgs(match[2]),\n      line,\n      start: baseColumn + match.index,\n      end: baseColumn + match.index + match[1].length,\n      scope,\n      isCall: true,\n    });\n    callSpans.push([match.index, match.index + match[0].length]);\n  }\n\n  const names = [];\n  for (const match of expr.matchAll(IDENT)) {\n    const insideCall = callSpans.some(([start, end]) => match.index >= start && match.index < end);\n    if (!insideCall && !KEYWORDS.includes(match[0])) {\n      names.push({\n        name: match[0],\n        line,\n        start: baseColumn + match.index,\n        end: baseColumn + match.index + match[0].length,\n        scope,\n        isCall: false,\n      });\n    }\n  }\n  return [...calls, ...names];\n}\n\nexport function parseMiniLang(text) {\n  const diagnostics = [];\n  const functions = new Map();\n  const symbols = [];\n  const references = [];\n  const lines = text.split(/\\r?\\n/);\n  let current = null;\n\n  function closeCurrent(endLine, missing) {\n    if (!current) return;\n    if (missing && current.hasBrace) {\n      diagnostics.push(diag(current.line, current.nameStart, current.nameEnd, `Function ${current.name} is missing closing brace`));\n    }\n    current.endLine = endLine;\n    current = null;\n  }\n\n  for (let lineNo = 0; lineNo < lines.length; lineNo += 1) {\n    const line = stripComment(lines[lineNo]);\n    const trimmed = line.trim();\n    const indent = line.length - line.trimStart().length;\n    if (!trimmed) continue;\n\n    const fnMatch = /^fn\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^)]*)\\)\\s*(\\{)?/.exec(trimmed);\n    if (fnMatch) {\n      closeCurrent(lineNo - 1, true);\n      const name = fnMatch[1];\n      const params = splitArgs(fnMatch[2]);\n      const nameStart = indent + fnMatch[0].indexOf(name);\n      const symbol = {\n        name,\n        kind: 'function',\n        params,\n        range: range(lineNo, nameStart, nameStart + name.length),\n        selectionRange: range(lineNo, nameStart, nameStart + name.length),\n        line: lineNo,\n        container: null,\n      };\n      symbols.push(symbol);\n      functions.set(name, symbol);\n      for (const param of params) {\n        const paramStart = indent + fnMatch[0].indexOf(param);\n        symbols.push({\n          name: param,\n          kind: 'variable',\n          range: range(lineNo, paramStart, paramStart + param.length),\n          selectionRange: range(lineNo, paramStart, paramStart + param.length),\n          line: lineNo,\n          container: name,\n        });\n      }\n      current = {\n        name,\n        params,\n        locals: new Map(params.map((param) => [param, true])),\n        hasBrace: Boolean(fnMatch[3]),\n        line: lineNo,\n        nameStart,\n        nameEnd: nameStart + name.length,\n        endLine: lines.length - 1,\n      };\n      continue;\n    }\n\n    if (trimmed === '}') {\n      closeCurrent(lineNo, false);\n      continue;\n    }\n\n    const scope = current?.name ?? null;\n    const letMatch = /^let\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/.exec(trimmed);\n    if (letMatch) {\n      const name = letMatch[1];\n      const nameStart = indent + trimmed.indexOf(name);\n      const symbol = {\n        name,\n        kind: 'variable',\n        range: range(lineNo, nameStart, nameStart + name.length),\n        selectionRange: range(lineNo, nameStart, nameStart + name.length),\n        line: lineNo,\n        container: scope,\n      };\n      symbols.push(symbol);\n      if (current) current.locals.set(name, true);\n      references.push(...scanReferences(letMatch[2], lineNo, indent + trimmed.indexOf(letMatch[2]), scope));\n      continue;\n    }\n\n    const returnMatch = /^return\\s+(.+)$/.exec(trimmed);\n    if (returnMatch) {\n      references.push(...scanReferences(returnMatch[1], lineNo, indent + trimmed.indexOf(returnMatch[1]), scope));\n      continue;\n    }\n\n    const callMatch = /^([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^)]*)\\)$/.exec(trimmed);\n    if (callMatch) {\n      references.push({\n        name: callMatch[1],\n        args: splitArgs(callMatch[2]),\n        line: lineNo,\n        start: indent,\n        end: indent + callMatch[1].length,\n        scope,\n        isCall: true,\n      });\n      continue;\n    }\n\n    if (/^[A-Za-z_][A-Za-z0-9_]*$/.test(trimmed)) continue;\n\n    diagnostics.push(diag(lineNo, indent, line.length, 'Unrecognized statement'));\n  }\n\n  closeCurrent(lines.length - 1, true);\n\n  for (const ref of references) {\n    if (ref.isCall) {\n      const fn = functions.get(ref.name);\n      if (!fn) {\n        diagnostics.push(diag(ref.line, ref.start, ref.end, `Undefined function ${ref.name}`));\n      } else if (ref.args.length !== fn.params.length) {\n        diagnostics.push(diag(ref.line, ref.start, ref.end, `Function ${ref.name} expected ${fn.params.length} argument(s), got ${ref.args.length}`));\n      }\n    } else if (!resolveParsedName(symbols, functions, ref)) {\n      diagnostics.push(diag(ref.line, ref.start, ref.end, `Undefined symbol ${ref.name}`));\n    }\n  }\n\n  return { text, diagnostics, symbols, functions, references };\n}\n\nfunction positionBefore(a, b) {\n  return a.line < b.line || (a.line === b.line && a.character <= b.character);\n}\n\nfunction resolveParsedName(symbols, functions, ref) {\n  if (functions.has(ref.name)) return true;\n  return symbols.some((symbol) => {\n    const sameName = symbol.name === ref.name;\n    const sameScope = symbol.kind === 'function' || !symbol.container || symbol.container === ref.scope;\n    const beforeRef = symbol.range.start.line < ref.line\n      || (symbol.range.start.line === ref.line && symbol.range.start.character <= ref.start);\n    return sameName && sameScope && beforeRef;\n  });\n}\n\nfunction wordAt(text, position) {\n  const raw = text.split(/\\r?\\n/)[position.line] ?? '';\n  const line = stripComment(raw);\n  let start = Math.min(position.character, line.length);\n  let end = start;\n  while (start > 0 && /[A-Za-z0-9_]/.test(line[start - 1])) start -= 1;\n  while (end < line.length && /[A-Za-z0-9_]/.test(line[end])) end += 1;\n  const word = line.slice(start, end);\n  return word ? { word, range: range(position.line, start, end) } : null;\n}\n\nfunction functionAt(parsed, position) {\n  let match = null;\n  for (const symbol of parsed.symbols.filter((item) => item.kind === 'function')) {\n    if (symbol.line <= position.line && (!match || symbol.line > match.line)) match = symbol;\n  }\n  return match;\n}\n","exit_code":0,"status":"completed"}}
