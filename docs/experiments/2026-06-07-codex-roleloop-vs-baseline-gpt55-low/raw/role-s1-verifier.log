{"type":"item.completed","item":{"id":"item_7","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' test/lsp.visible.test.mjs\"","aggregated_output":"import assert from 'node:assert/strict';\nimport { test } from 'node:test';\nimport { encodeMessage, MessageBuffer, MiniLangServer } from '../src/server.mjs';\n\nfunction request(method, params = {}, id = 1) {\n  return { jsonrpc: '2.0', id, method, params };\n}\n\nfunction notification(method, params = {}) {\n  return { jsonrpc: '2.0', method, params };\n}\n\nfunction textDocument(uri, text, version = 1) {\n  return { uri, languageId: 'minilang', version, text };\n}\n\nfunction itemsFrom(response) {\n  const result = response.result;\n  return Array.isArray(result) ? result : result.items;\n}\n\nfunction positionOf(text, line, needle, offset = 0) {\n  const lines = text.split('\\n');\n  const character = lines[line].indexOf(needle);\n  assert.notEqual(character, -1, `missing ${needle} on line ${line}`);\n  return { line, character: character + offset };\n}\n\ntest('JSON-RPC transport frames and streams Content-Length messages', () => {\n  const message = { jsonrpc: '2.0', id: 7, result: { ok: true } };\n  const framed = encodeMessage(message);\n  assert.match(framed, /^Content-Length: \\d+\\r\\n\\r\\n/);\n\n  const buffer = new MessageBuffer();\n  assert.deepEqual(buffer.push(framed.slice(0, 9)), []);\n  const decoded = buffer.push(framed.slice(9) + framed);\n  assert.equal(decoded.length, 2);\n  assert.deepEqual(decoded[0], message);\n  assert.deepEqual(decoded[1], message);\n});\n\ntest('initialize, shutdown, and exit expose expected LSP lifecycle', async () => {\n  const server = new MiniLangServer();\n  const init = await server.handle(request('initialize', { capabilities: {} }, 1));\n  assert.equal(init.id, 1);\n  assert.equal(init.result.capabilities.textDocumentSync, 2);\n  assert.ok(init.result.capabilities.completionProvider);\n  assert.equal(init.result.capabilities.definitionProvider, true);\n  assert.equal(init.result.capabilities.hoverProvider, true);\n\n  const shutdown = await server.handle(request('shutdown', {}, 2));\n  assert.deepEqual(shutdown, { jsonrpc: '2.0', id: 2, result: null });\n  assert.equal(await server.handle(notification('exit')), null);\n});\n\ntest('didOpen publishes diagnostics for undefined symbols and wrong arity', async () => {\n  const uri = 'file:///visible-diagnostics.mini';\n  const text = [\n    'fn add(a, b) {',\n    '  return a',\n    '}',\n    'fn main() {',\n    '  let answer = add(1)',\n    '  return missing',\n    '}',\n  ].join('\\n');\n  const server = new MiniLangServer();\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n  const publish = server.takeNotifications().find((item) => item.method === 'textDocument/publishDiagnostics');\n  assert.ok(publish, 'expected publishDiagnostics notification');\n  const diagnostics = publish.params.diagnostics;\n  const messages = diagnostics.map((diag) => diag.message).join('\\n').toLowerCase();\n  assert.match(messages, /undefined.*missing|missing.*undefined/);\n  assert.match(messages, /arity|argument|expected 2/);\n  assert.equal(server.getDiagnostics(uri).length, diagnostics.length);\n});\n\ntest('completion includes keywords, in-scope symbols, functions, and snippets', async () => {\n  const uri = 'file:///visible-completion.mini';\n  const text = [\n    'fn add(a, b) {',\n    '  return a',\n    '}',\n    'fn main() {',\n    '  let local = 1',\n    '  return ',\n    '}',\n  ].join('\\n');\n  const server = new MiniLangServer();\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n  const response = await server.handle(request('textDocument/completion', {\n    textDocument: { uri },\n    position: { line: 5, character: 9 },\n  }, 3));\n  const items = itemsFrom(response);\n  const labels = items.map((item) => item.label);\n  assert.ok(labels.includes('fn'));\n  assert.ok(labels.includes('let'));\n  assert.ok(labels.includes('return'));\n  assert.ok(labels.includes('add'));\n  assert.ok(labels.includes('local'));\n  assert.ok(items.some((item) => item.label === 'return' && /return/.test(JSON.stringify(item))));\n});\n\ntest('definition and hover resolve function symbols', async () => {\n  const uri = 'file:///visible-definition.mini';\n  const text = [\n    'fn inc(value) {',\n    '  return value',\n    '}',\n    'fn main() {',\n    '  let total = inc(1)',\n    '  return total',\n    '}',\n  ].join('\\n');\n  const server = new MiniLangServer();\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n  const definition = await server.handle(request('textDocument/definition', {\n    textDocument: { uri },\n    position: positionOf(text, 4, 'inc', 1),\n  }, 4));\n  assert.equal(definition.result.uri, uri);\n  assert.equal(definition.result.range.start.line, 0);\n\n  const hover = await server.handle(request('textDocument/hover', {\n    textDocument: { uri },\n    position: positionOf(text, 4, 'inc', 1),\n  }, 5));\n  assert.match(JSON.stringify(hover.result.contents), /fn inc\\(value\\)/);\n});\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_6","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' src/server.mjs\"","aggregated_output":"const KEYWORDS = ['fn', 'let', 'return'];\n\nfunction utf8Length(text) {\n  return Buffer.byteLength(text, 'utf8');\n}\n\nfunction range(line, start, end = start) {\n  return {\n    start: { line, character: start },\n    end: { line, character: end },\n  };\n}\n\nfunction diagnostic(line, start, end, message) {\n  return {\n    range: range(line, start, Math.max(start + 1, end)),\n    severity: 1,\n    source: 'minilang',\n    message,\n  };\n}\n\nfunction stripComment(line) {\n  const index = line.indexOf('#');\n  return index === -1 ? line : line.slice(0, index);\n}\n\nfunction wordAt(text, position) {\n  const lines = text.split(/\\r?\\n/);\n  const line = lines[position.line] ?? '';\n  let start = Math.min(position.character, line.length);\n  let end = start;\n\n  while (start > 0 && /[A-Za-z0-9_]/.test(line[start - 1])) start--;\n  while (end < line.length && /[A-Za-z0-9_]/.test(line[end])) end++;\n\n  const name = line.slice(start, end);\n  return name ? { name, range: range(position.line, start, end) } : null;\n}\n\nfunction splitArguments(source) {\n  const args = [];\n  let current = '';\n  let depth = 0;\n\n  for (const char of source) {\n    if (char === '(') depth++;\n    if (char === ')') depth = Math.max(0, depth - 1);\n    if (char === ',' && depth === 0) {\n      args.push(current.trim());\n      current = '';\n    } else {\n      current += char;\n    }\n  }\n\n  const tail = current.trim();\n  if (tail || source.trim()) args.push(tail);\n  return args.filter(Boolean);\n}\n\nfunction findCalls(expression) {\n  const calls = [];\n  const pattern = /\\b([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^()]*)\\)/g;\n  let match;\n\n  while ((match = pattern.exec(expression)) !== null) {\n    calls.push({\n      name: match[1],\n      args: splitArguments(match[2]),\n      index: match.index,\n    });\n  }\n\n  return calls;\n}\n\nexport function encodeMessage(message) {\n  const body = JSON.stringify(message);\n  return `Content-Length: ${utf8Length(body)}\\r\\n\\r\\n${body}`;\n}\n\nexport class MessageBuffer {\n  constructor() {\n    this.buffer = Buffer.alloc(0);\n  }\n\n  push(chunk) {\n    const incoming = Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk), 'utf8');\n    this.buffer = Buffer.concat([this.buffer, incoming]);\n    const messages = [];\n\n    while (true) {\n      const headerEnd = this.buffer.indexOf('\\r\\n\\r\\n');\n      if (headerEnd === -1) return messages;\n\n      const header = this.buffer.slice(0, headerEnd).toString('utf8');\n      const match = /^Content-Length:\\s*(\\d+)$/im.exec(header);\n      if (!match) {\n        this.buffer = Buffer.alloc(0);\n        throw new Error('Missing Content-Length header');\n      }\n\n      const length = Number(match[1]);\n      const bodyStart = headerEnd + 4;\n      const bodyEnd = bodyStart + length;\n      if (this.buffer.length < bodyEnd) return messages;\n\n      const messageBody = this.buffer.slice(bodyStart, bodyEnd).toString('utf8');\n      this.buffer = this.buffer.slice(bodyEnd);\n      messages.push(JSON.parse(messageBody));\n    }\n  }\n}\n\nexport function parseMiniLang(text) {\n  const diagnostics = [];\n  const symbols = [];\n  const functions = new Map();\n  const variables = new Map();\n  const lines = text.split(/\\r?\\n/);\n  let currentFunction = null;\n  let braceDepth = 0;\n\n  for (let lineNo = 0; lineNo < lines.length; lineNo++) {\n    const raw = lines[lineNo];\n    const line = stripComment(raw);\n    const trimmed = line.trim();\n    const indent = line.search(/\\S|$/);\n\n    if (!trimmed) continue;\n\n    const fn = /^\\s*fn\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^)]*)\\)\\s*\\{?/.exec(line);\n    if (fn) {\n      const name = fn[1];\n      const nameStart = line.indexOf(name);\n      const params = fn[2].split(',').map((param) => param.trim()).filter(Boolean);\n      const symbol = {\n        kind: 'function',\n        name,\n        params,\n        range: range(lineNo, nameStart, nameStart + name.length),\n        detail: `fn ${name}(${params.join(', ')})`,\n      };\n      symbols.push(symbol);\n      functions.set(name, symbol);\n      currentFunction = { symbol, locals: new Map(params.map((param) => [param, true])) };\n      braceDepth += (line.match(/\\{/g) ?? []).length - (line.match(/\\}/g) ?? []).length;\n      if (!line.includes('{')) {\n        diagnostics.push(diagnostic(lineNo, line.length, line.length + 1, `Function '${name}' is missing opening brace`));\n      }\n      continue;\n    }\n\n    if (/^\\s*fn\\b/.test(line)) {\n      diagnostics.push(diagnostic(lineNo, indent, line.length, 'Malformed function declaration'));\n      continue;\n    }\n\n    const variable = /^\\s*let\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.+)$/.exec(line);\n    if (variable) {\n      const name = variable[1];\n      const nameStart = line.indexOf(name);\n      const symbol = {\n        kind: 'variable',\n        name,\n        range: range(lineNo, nameStart, nameStart + name.length),\n        detail: `let ${name}`,\n      };\n      symbols.push(symbol);\n      variables.set(name, symbol);\n      currentFunction?.locals.set(name, true);\n      continue;\n    }\n\n    if (/^\\s*let\\b/.test(line)) {\n      diagnostics.push(diagnostic(lineNo, indent, line.length, 'Malformed variable declaration'));\n      continue;\n    }\n\n    if (/^\\s*return\\b/.test(line)) {\n      const expr = line.replace(/^\\s*return\\s*/, '');\n      if (!expr.trim()) {\n        diagnostics.push(diagnostic(lineNo, line.indexOf('return'), line.length, 'Return statement is missing an expression'));\n      }\n      continue;\n    }\n\n    if (/^\\s*\\}/.test(line)) {\n      braceDepth = Math.max(0, braceDepth - 1);\n      if (braceDepth === 0) currentFunction = null;\n      continue;\n    }\n\n    if (findCalls(line).length === 0) {\n      diagnostics.push(diagnostic(lineNo, indent, line.length, 'Unrecognized statement'));\n    }\n  }\n\n  if (braceDepth > 0 && currentFunction) {\n    diagnostics.push(diagnostic(\n      lines.length - 1,\n      lines[lines.length - 1]?.length ?? 0,\n      (lines[lines.length - 1]?.length ?? 0) + 1,\n      `Function '${currentFunction.symbol.name}' is missing }`,\n    ));\n  }\n\n  const knownVariables = new Set([...variables.keys()]);\n  for (const symbol of symbols) {\n    if (symbol.kind === 'function') {\n      for (const param of symbol.params) knownVariables.add(param);\n    }\n  }\n\n  for (let lineNo = 0; lineNo < lines.length; lineNo++) {\n    const line = stripComment(lines[lineNo]);\n    for (const call of findCalls(line)) {\n      if (KEYWORDS.includes(call.name)) continue;\n      const fn = functions.get(call.name);\n      if (!fn) {\n        diagnostics.push(diagnostic(lineNo, call.index, call.index + call.name.length, `Undefined function '${call.name}'`));\n      } else if (call.args.length !== fn.params.length) {\n        diagnostics.push(diagnostic(\n          lineNo,\n          call.index,\n          call.index + call.name.length,\n          `Function '${call.name}' expected ${fn.params.length} argument(s), got ${call.args.length}`,\n        ));\n      }\n    }\n\n    const identifierPattern = /\\b([A-Za-z_][A-Za-z0-9_]*)\\b/g;\n    let match;\n    while ((match = identifierPattern.exec(line)) !== null) {\n      const name = match[1];\n      const next = line.slice(match.index + name.length).trimStart()[0];\n      if (KEYWORDS.includes(name) || functions.has(name) || knownVariables.has(name) || next === '(') continue;\n      diagnostics.push(diagnostic(lineNo, match.index, match.index + name.length, `Undefined variable '${name}'`));\n    }\n  }\n\n  return { text, diagnostics, symbols };\n}\n\nexport class MiniLangServer {\n  constructor() {\n    this.documents = new Map();\n    this.notifications = [];\n    this.shutdownRequested = false;\n  }\n\n  async handle(message) {\n    if (message.method === 'initialize') return this.response(message.id, this.initializeResult());\n    if (message.method === 'shutdown') {\n      this.shutdownRequested = true;\n      return this.response(message.id, null);\n    }\n    if (message.method === 'exit') return null;\n    if (message.method === 'textDocument/didOpen') return this.didOpen(message.params);\n","exit_code":0,"status":"completed"}}
