index 8997415062e580d8c1ba02fc81a520dc07be6885..07b49867430dd0145ad0e74b362dfd5902b46677
--- a/test/priceBasket.test.mjs
+++ b/test/priceBasket.test.mjs
@@ -21,3 +21,38 @@
     totalCents: 4836,
   });
 });
+
+test('rounds per-line discounts down before tax', () => {
+  const items = [
+    { sku: 'lamp', category: 'home', unitCents: 999, quantity: 1, taxable: true },
+    { sku: 'mat', category: 'home', unitCents: 1001, quantity: 1, taxable: true },
+  ];
+  const rules = {
+    taxRateBps: 1000,
+    shippingCents: 300,
+    categoryDiscountsBps: { home: 333 },
+  };
+
+  assert.deepEqual(priceBasket(items, rules), {
+    subtotalCents: 2000,
+    discountCents: 66,
+    taxCents: 193,
+    shippingCents: 300,
+    totalCents: 2427,
+  });
+});
+
+test('validates items and rules', () => {
+  assert.throws(() => priceBasket('items', {}), /items must be an array/);
+  assert.throws(
+    () => priceBasket([{ category: 'home', unitCents: 100, quantity: 1, taxable: 'yes' }], {}),
+    /taxable must be a boolean/,
+  );
+  assert.throws(
+    () =>
+      priceBasket([], {
+        categoryDiscountsBps: { home: 10001 },
+      }),
+    /rules\.categoryDiscountsBps\.home/,
+  );
+});

