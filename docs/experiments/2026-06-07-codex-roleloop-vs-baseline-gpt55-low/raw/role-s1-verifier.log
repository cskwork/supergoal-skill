{"type":"item.completed","item":{"id":"item_8","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' test/spec.gen.test.mjs\"","aggregated_output":"import assert from 'node:assert/strict';\nimport test from 'node:test';\nimport { MiniLangServer } from '../src/server.mjs';\n\nfunction request(method, params = {}, id = 1) {\n  return { jsonrpc: '2.0', id, method, params };\n}\n\nfunction notification(method, params = {}) {\n  return { jsonrpc: '2.0', method, params };\n}\n\nfunction textDocument(uri, text, version = 1) {\n  return { uri, languageId: 'minilang', version, text };\n}\n\nfunction completionItems(response) {\n  const result = response.result;\n  return Array.isArray(result) ? result : result.items;\n}\n\nfunction positionOf(text, line, needle, offset = 0) {\n  const lines = text.split('\\n');\n  const character = lines[line].indexOf(needle);\n  assert.notEqual(character, -1, `missing ${needle} on line ${line}`);\n  return { line, character: character + offset };\n}\n\ntest('completion is prefix-filtered and function items include signatures', async () => {\n  const uri = 'file:///prefix-completion.mini';\n  const text = [\n    'fn add(left, right) {',\n    '  return left',\n    '}',\n    'fn apply(value) {',\n    '  let apple = value',\n    '  ap',\n    '}',\n  ].join('\\n');\n  const server = new MiniLangServer();\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n\n  const response = await server.handle(request('textDocument/completion', {\n    textDocument: { uri },\n    position: positionOf(text, 5, 'ap', 2),\n  }));\n  const items = completionItems(response);\n  const labels = items.map((item) => item.label);\n\n  assert.deepEqual(labels.sort(), ['apple', 'apply'].sort());\n  const apply = items.find((item) => item.label === 'apply');\n  assert.match(apply?.detail ?? '', /fn apply\\(value\\)/);\n});\n\ntest('parser recovery keeps semantic diagnostics after a missing closing brace', async () => {\n  const uri = 'file:///recover-diagnostics.mini';\n  const text = [\n    'fn first() {',\n    '  let local = 1',\n    'fn second() {',\n    '  return missingValue',\n    '}',\n  ].join('\\n');\n  const server = new MiniLangServer();\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n\n  const messages = server.getDiagnostics(uri).map((diag) => diag.message).join('\\n');\n  assert.match(messages, /missing.*\\}/i);\n  assert.match(messages, /Undefined variable 'missingValue'/);\n});\n\ntest('go-to-definition prefers a local symbol over a same-named global function', async () => {\n  const uri = 'file:///local-definition.mini';\n  const text = [\n    'fn item() {',\n    '  return 1',\n    '}',\n    'fn main() {',\n    '  let item = 2',\n    '  return item',\n    '}',\n  ].join('\\n');\n  const server = new MiniLangServer();\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n\n  const response = await server.handle(request('textDocument/definition', {\n    textDocument: { uri },\n    position: positionOf(text, 5, 'item', 1),\n  }));\n\n  assert.equal(response.result.uri, uri);\n  assert.equal(response.result.range.start.line, 4);\n});\n\ntest('comments do not create symbols, calls, or diagnostics', async () => {\n  const uri = 'file:///comments.mini';\n  const text = [\n    '# fn ghost(param) {',\n    'fn main() {',\n    '  # missingCall(unknownName)',\n    '  return 1 # trailingName',\n    '}',\n  ].join('\\n');\n  const server = new MiniLangServer();\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n\n  assert.deepEqual(server.getDiagnostics(uri), []);\n\n  const response = await server.handle(request('textDocument/completion', {\n    textDocument: { uri },\n    position: { line: 3, character: 9 },\n  }));\n  const labels = completionItems(response).map((item) => item.label);\n  assert.ok(!