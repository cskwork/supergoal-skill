{"type":"item.completed","item":{"id":"item_5","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,220p' src/order.mjs\"","aggregated_output":"function calculateSubtotal(order) {\n  let subtotal = 0;\n  for (let i = 0; i < order.items.length; i++) {\n    subtotal += order.items[i].price * order.items[i].qty;\n  }\n  return subtotal;\n}\n\nfunction calculateDiscount(order, subtotal) {\n  let discount = 0;\n\n  if (order.coupon) {\n    if (order.coupon === 'SAVE10') {\n      discount = subtotal * 0.1;\n    } else if (order.coupon === 'SAVE20') {\n      if (subtotal >= 100) {\n        discount = subtotal * 0.2;\n      } else {\n        discount = subtotal * 0.1;\n      }\n    } else if (order.coupon === 'HALF' && order.vip) {\n      discount = subtotal * 0.5;\n    }\n  }\n\n  if (order.vip && discount < subtotal * 0.05) {\n    discount = subtotal * 0.05;\n  }\n\n  return discount;\n}\n\nfunction calculateTax(order, taxed) {\n  if (order.region === 'US') {\n    return taxed * 0.07;\n  }\n\n  if (order.region === 'EU') {\n    return taxed * 0.2;\n  }\n\n  return taxed * 0.1;\n}\n\nfunction calculateShipping(order, taxed) {\n  let shipping = 0;\n\n  if (taxed < 50) {\n    shipping = 7.5;\n  } else if (taxed < 100) {\n    shipping = 3;\n  }\n\n  if (order.express) {\n    shipping += 12;\n  }\n\n  return shipping;\n}\n\nfunction roundCents(value) {\n  return Math.round(value * 100) / 100;\n}\n\nexport function calculateInvoice(order) {\n  const subtotal = calculateSubtotal(order);\n  const discount = calculateDiscount(order, subtotal);\n  const taxed = subtotal - discount;\n  const tax = calculateTax(order, taxed);\n  const shipping = calculateShipping(order, taxed);\n  const total = taxed + tax + shipping;\n\n  return {\n    subtotal: roundCents(subtotal),\n    discount: roundCents(discount),\n    tax: roundCents(tax),\n    shipping: roundCents(shipping),\n    total: roundCents(total),\n  };\n}\n","exit_code":0,"status":"completed"}}
