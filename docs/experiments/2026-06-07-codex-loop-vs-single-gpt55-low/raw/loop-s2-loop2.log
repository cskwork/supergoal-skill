ontinue;\n    const target = state.functions.get(reference.name);\n    if (!target) continue;\n\n    reference.target = target;\n    state.diagnostics = state.diagnostics.filter(\n      (item) => !(item.message === `Undefined function ${reference.name}` && sameRange(item.range, reference.range)),\n    );\n    if (reference.argsLength !== target.params.length) {\n      state.diagnostics.push(diagFromRange(\n        reference.range,\n        arityMessage(reference.name, target.params.length, reference.argsLength),\n      ));\n    }\n  }\n}\n\nfunction closeScopes(state, raw, lineNo) {\n  for (const char of raw) {\n    if (char === '{') state.braceDepth += 1;\n    if (char !== '}') continue;\n    state.braceDepth = Math.max(0, state.braceDepth - 1);\n    if (state.braceDepth === 0 && state.currentFunction) {\n      state.currentFunction.endLine = lineNo;\n      state.scopes.pop();\n      state.currentFunction = null;\n    }\n  }\n}\n\nfunction applyTextChange(text, change) {\n  const start = offsetAt(text, change.range.start);\n  const end = offsetAt(text, change.range.end);\n  return `${text.slice(0, start)}${change.text}${text.slice(end)}`;\n}\n\nfunction offsetAt(text, position) {\n  const lines = text.split(/\\n/);\n  let offset = 0;\n  for (let line = 0; line < Math.min(position.line, lines.length); line += 1) {\n    offset += lines[line].length + 1;\n  }\n  return offset + Math.min(position.character, lines[position.line]?.length ?? 0);\n}\n\nfunction wordAt(text, position) {\n  const line = text.split(/\\r?\\n/)[position.line] ?? '';\n  const regex = /\\b[A-Za-z_]\\w*\\b/g;\n  for (const match of line.matchAll(regex)) {\n    const start = match.index;\n    const end = start + match[0].length;\n    if (position.character >= start && position.character <= end) {\n      return { text: match[0], range: rangeFor(position.line, start, end) };\n    }\n  }\n  return null;\n}\n\nfunction visibleSymbols(symbols, position) {\n  const activeFunction = symbols.find((symbol) => {\n    if (symbol.kind !== 'function') return false;\n    if (symbol.range.start.line > position.line) return false;\n    return symbol.endLine === undefined || symbol.endLine >= position.line;\n  });\n\n  return symbols.filter((symbol) => {\n    if (symbol.kind === 'function') return true;\n    if (symbol.container && symbol.container !== activeFunction?.name) return false;\n    if (symbol.range.start.line > position.line) return false;\n    return symbol.range.start.line < position.line || symbol.range.start.character <= position.character;\n  });\n}\n\nfunction pushCompletion(items, seen, item) {\n  if (seen.has(item.label)) return;\n  seen.add(item.label);\n  items.push(item);\n}\n\nfunction initializeResult() {\n  return {\n    capabilities: {\n      textDocumentSync: 2,\n      completionProvider: { triggerCharacters: [''] },\n      definitionProvider: true,\n      hoverProvider: true,\n    },\n  };\n}\n\nfunction response(id, result) {\n  return { jsonrpc: '2.0', id, result };\n}\n\nfunction stripComment(line) {\n  return line.split('#')[0];\n}\n\nfunction splitParams(text, line, baseCol, diagnostics) {\n  const params = splitArgs(text);\n  for (const param of params) {\n    if (!/^[A-Za-z_]\\w*$/.test(param)) {\n      diagnostics.push(diag(line, baseCol, baseCol + text.length, `Invalid parameter ${param}`));\n    }\n  }\n  return params.filter((param) => /^[A-Za-z_]\\w*$/.test(param));\n}\n\nfunction splitArgs(text) {\n  const trimmed = text.trim();\n  if (!trimmed) return [];\n  return trimmed.split(',').map((arg) => arg.trim()).filter(Boolean);\n}\n\nfunction lookup(scopes, name) {\n  for (let index = scopes.length - 1; index >= 0; index -= 1) {\n    const found = scopes[index].get(name);\n    if (found) return found;\n  }\n  return null;\n}\n\nfunction makeSymbol(kind, name, line, col, extra = {}) {\n  return {\n    kind,\n    name,\n    range: rangeFor(line, col, col + name.length),\n    selectionRange: rangeFor(line, col, col + name.length),\n    ...e