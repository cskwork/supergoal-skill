rt));\n  return lineStart + column;\n}\n\nfunction offsetToPosition(text, offset) {\n  const safeOffset = Math.max(0, Math.min(offset, text.length));\n  const lines = text.split('\\\\n');\n\n  let remaining = safeOffset;\n  for (let i = 0; i < lines.length; i += 1) {\n    const lineLen = lines[i].length;\n    if (remaining <= lineLen) return { line: i, character: remaining };\n    remaining -= lineLen + 1;\n  }\n  return { line: lines.length - 1, character: lines[lines.length - 1].length };\n}\n\nfunction applyChange(text, change) {\n  if (\"'!change || typeof change.text !== '\"'string') return text;\n  if (\"'!change.range) return change.text;\n\n  const startOffset = positionToOffset(text, change.range.start);\n  const endOffset = positionToOffset(text, change.range.end);\n  return `${text.slice(0, startOffset)}${change.text}${text.slice(endOffset)}`;\n}\n\nfunction identifierAt(text, lineText, line, character) {\n  const lineLen = lineText.length;\n  const pos = Math.max(0, Math.min(character, lineLen));\n  let start = pos;\n\n  while (start > 0 && isIdentifierPart(lineText[start - 1])) {\n    start -= 1;\n  }\n\n  let end = pos;\n  while (end < lineLen && isIdentifierPart(lineText[end])) {\n    end += 1;\n  }\n\n  if (!isIdentifierStart(lineText[start])) return null;\n\n  return {\n    name: lineText.slice(start, end),\n    range: range(line, start, end),\n  };\n}\n\nfunction parseIdentifierListInsideHeader(line, start, end) {\n  const names = [];\n  const text = line.slice(start, end);\n\n  const regex = /([A-Za-z_][A-Za-z0-9_]*)/g;\n  let m;\n  while ((m = regex.exec(text)) !== null) {\n    const name = m[1];\n    names.push({\n      name,\n      start: start + m.index,\n      end: start + m.index + name.length,\n    });\n  }\n\n  return names;\n}\n\nexport function parseMiniLang(text) {\n  const diagnostics = [];\n  const symbols = [];\n  const lines = text.split('\"'\\\\n');\n\n  const rootScope = {\n    kind: 'global',\n    symbols: new Map(),\n    startLi