diff --git a/src/safeRedirect.mjs b/src/safeRedirect.mjs
index 6a5a394765401504c4ae11d5c33a2eea1f82ef3c..729c4730d15501186b9ebae419a9fd1bebb928ae
--- a/src/safeRedirect.mjs
+++ b/src/safeRedirect.mjs
@@ -1,9 +1,167 @@
+import { isIP } from 'node:net';
+
+const ALLOWED_PROTOCOLS = new Set(['http:', 'https:']);
+const CONTROL_CHARS = /[\u0000-\u001f\u007f-\u009f]/u;
+
 export function isSafeRedirect(rawUrl, allowedHosts = ['example.com']) {
+  if (typeof rawUrl !== 'string') return false;
+  if (CONTROL_CHARS.test(rawUrl) || rawUrl.includes('\\')) return false;
+
   try {
     const url = new URL(rawUrl);
-    if (!['http:', 'https:'].includes(url.protocol)) return false;
-    return allowedHosts.some((host) => url.hostname.endsWith(host));
+    if (!ALLOWED_PROTOCOLS.has(url.protocol)) return false;
+    if (hasUserInfo(rawUrl, url)) return false;
+
+    const host = normalizeHost(url.hostname);
+    if (!host || isBlockedHost(host)) return false;
+
+    return normalizeAllowedHosts(allowedHosts).some((allowedHost) =>
+      hostMatchesAllowedHost(host, allowedHost),
+    );
   } catch {
     return false;
   }
 }
+
+function hasUserInfo(rawUrl, url) {
+  if (url.username || url.password) return true;
+
+  const schemeEnd = rawUrl.indexOf(':');
+  const rest = rawUrl.slice(schemeEnd + 1);
+  if (!rest.startsWith('//')) return false;
+
+  const authority = rest.slice(2).split(/[/?#]/, 1)[0];
+  return authority.includes('@');
+}
+
+function normalizeAllowedHosts(allowedHosts) {
+  if (!Array.isArray(allowedHosts)) return [];
+
+  return allowedHosts
+    .filter((host) => typeof host === 'string')
+    .map((host) => normalizeHost(host.trim()))
+    .filter(Boolean);
+}
+
+function normalizeHost(host) {
+  let value = host.toLowerCase();
+  if (value.startsWith('[') && value.endsWith(']')) value = value.slice(1, -1);
+  if (value.endsWith('.')) value = value.slice(0, -1);
+
+  if (isIP(value) === 6) {
+    try {
+      return new URL(`http://[${value}]`).hostname.slice(1, -1).toLowerCase();
+    } catch {
+      return value;
+    }
+  }
+
+  return value;
+}
+
+function hostMatchesAllowedHost(host, allowedHost) {
+  if (isIP(host) || isIP(allowedHost)) return host === allowedHost;
+  return host === allowedHost || host.endsWith(`.${allowedHost}`);
+}
+
+function isBlockedHost(host) {
+  return isLocalhost(host) || isBlockedIPv4(host) || isBlockedIPv6(host);
+}
+
+function isLocalhost(host) {
+  return host === 'localhost' || host.endsWith('.localhost');
+}
+
+function isBlockedIPv4(host) {
+  const octets = parseIPv4Octets(host);
+  return octets ? isBlockedIPv4Octets(octets) : false;
+}
+
+function parseIPv4Octets(host) {
+  if (isIP(host) !== 4) return null;
+
+  const octets = host.split('.').map(Number);
+  if (octets.length !== 4) return null;
+  return octets.every((octet) => Number.isInteger(octet) && octet >= 0 && octet <= 255)
+    ? octets
+    : null;
+}
+
+function isBlockedIPv4Octets([a, b]) {
+  return (
+    a === 0 ||
+    a === 10 ||
+    a === 127 ||
+    (a === 169 && b === 254) ||
+    (a === 172 && b >= 16 && b <= 31) ||
+    (a === 192 && b === 168)
+  );
+}
+
+function isBlockedIPv6(host) {
+  if (isIP(host) !== 6) return false;
+
+  const parts = expandIPv6(host);
+  if (!parts) return false;
+
+  const mappedIPv4 = mappedIPv4Octets(parts);
+  return isIPv6Loopback(parts) || isUniqueLocalIPv6(parts) || Boolean(mappedIPv4?.blocked);
+}
+
+function expandIPv6(host) {
+  const value = replaceEmbeddedIPv4(host.toLowerCase());
+  const halves = value.split('::');
+  if (halves.length > 2) return null;
+
+  const left = halves[0] ? halves[0].split(':') : [];
+  const right = halves[1] ? halves[1].split(':') : [];
+  const missing = halves.length === 2 ? 8 - left.length - right.length : 0;
+  if (missing < 0) return null;
+
+  const pieces = halves.length === 2 ? [...left, ...Array(missing).fill('0'), ...right] : left;
+  if (pieces.length !== 8) return null;
+
+  return pieces.map((piece) => (/^[0-9a-f]{1,4}$/.test(piece) ? parseInt(piece, 16) : NaN));
+}
+
+function replaceEmbeddedIPv4(host) {
+  if (!host.includes('.')) return host;
+
+  const lastColon = host.lastIndexOf(':');
+  const octets = parseDottedIPv4(host.slice(lastColon + 1));
+  if (lastColon === -1 || !octets) return host;
+
+  const high = octets[0] * 256 + octets[1];
+  const low = octets[2] * 256 + octets[3];
+  return `${host.slice(0, lastColon)}:${high.toString(16)}:${low.toString(16)}`;
+}
+
+function parseDottedIPv4(value) {
+  const octets = value.split('.').map(Number);
+  if (octets.length !== 4) return null;
+  return octets.every((octet) => Number.isInteger(octet) && octet >= 0 && octet <= 255)
+    ? octets
+    : null;
+}
+
+function mappedIPv4Octets(parts) {
+  const firstFiveZero = parts.slice(0, 5).every((part) => part === 0);
+  const firstSixZero = firstFiveZero && parts[5] === 0;
+
+  if (firstFiveZero && parts[5] === 0xffff) return mappedIPv4Result(parts);
+  if (firstSixZero && (parts[6] !== 0 || parts[7] !== 0)) return mappedIPv4Result(parts);
+  return null;
+}
+
+function mappedIPv4Result(parts) {
+  const octets = [parts[6] >> 8, parts[6] & 255, parts[7] >> 8, parts[7] & 255];
+  return { octets, blocked: isBlockedIPv4Octets(octets) };
+}
+
+function isIPv6Loopback(parts) {
+  return parts.slice(0, 7).every((part) => part === 0) && parts[7] === 1;
+}
+
+function isUniqueLocalIPv6(parts) {
+  return (parts[0] & 0xfe00) === 0xfc00;
+}
