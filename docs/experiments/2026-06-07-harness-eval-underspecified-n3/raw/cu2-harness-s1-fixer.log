{"type":"item.completed","item":{"id":"item_21","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,120p' src/csv.mjs\"","aggregated_output":"export function parseCsvLine(line) {\n  const fields = [];\n  let field = '';\n  let inQuotes = false;\n  let atFieldStart = true;\n  let afterClosingQuote = false;\n\n  for (let i = 0; i < line.length; i += 1) {\n    const char = line[i];\n\n    if (inQuotes) {\n      if (char === '\"' && line[i + 1] === '\"') {\n        field += '\"';\n        i += 1;\n      } else if (char === '\"') {\n        inQuotes = false;\n        afterClosingQuote = true;\n      } else {\n        field += char;\n      }\n    } else if (afterClosingQuote) {\n      if (char === ',') {\n        fields.push(field);\n        field = '';\n        atFieldStart = true;\n        afterClosingQuote = false;\n      } else {\n        throw new SyntaxError('Unexpected character after closing quote');\n      }\n    } else if (char === ',') {\n      fields.push(field);\n      field = '';\n      atFieldStart = true;\n    } else if (char === '\"' && atFieldStart) {\n      inQuotes = true;\n      atFieldStart = false;\n    } else if (char === '\"') {\n      throw new SyntaxError('Unexpected quote in unquoted field');\n    } else {\n      field += char;\n      atFieldStart = false;\n    }\n  }\n\n  if (inQuotes) {\n    throw new SyntaxError('Unterminated quoted field');\n  }\n\n  fields.push(field);\n  return fields;\n}\n","exit_code":0,"status":"completed"}}
