{"type":"item.started","item":{"id":"item_24","type":"command_execution","command":"/bin/zsh -lc \"node --input-type=module - <<'EOF'\nimport assert from 'node:assert/strict';\nimport { MiniLangServer, MessageBuffer, encodeMessage } from './src/server.mjs';\nconst framed = encodeMessage({jsonrpc:'2.0', id:1, result:'한글'});\nconst b = new MessageBuffer();\nconst split = Buffer.from(framed).indexOf('\\\\r\\\\n\\\\r\\\\n') + 5;\nassert.deepEqual(b.push(Buffer.from(framed).subarray(0, split)), []);\nassert.deepEqual(b.push(Buffer.from(framed).subarray(split)), [{jsonrpc:'2.0', id:1, result:'한글'}]);\nconst server = new MiniLangServer();\nconst uri='file:///range.mini';\nconst open={jsonrpc:'2.0', method:'textDocument/didOpen', params:{textDocument:{uri, version:1, text:'fn main() {\\\\n let value = missing\\\\n return value\\\\n}'}}};\nawait server.handle(open);\nassert.equal(server.getDiagnostics(uri).some(d=>d.message.includes('Undefined')), true);\nawait server.handle({jsonrpc:'2.0', method:'textDocument/didChange', params:{textDocument:{uri, version:2}, contentChanges:[{range:{start:{line:1, character:13}, end:{line:1, character:20}}, text:'value'}]}});\nassert.equal(server.getDiagnostics(uri).some(d=>d.message.includes('Undefined')), false);\nconsole.log('targeted ok');\nEOF\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
