 => {$\n  assert.deepEqual($\n    calculateInvoice({$\n      items: [{ price: 50, qty: 1 }],$\n      region: 'US',$\n      vip: false,$\n    }),$\n    { subtotal: 50, discount: 0, tax: 3.5, shipping: 3, tot\\\nal: 56.5 },$\n  );$\n$\n  assert.deepEqual($\n    calculateInvoice({$\n      items: [{ price: 55.55555555555556, qty: 1 }],$\n      region: 'US',$\n      coupon: 'SAVE10',$\n    }),$\n    { subtotal: 55.56, discount: 5.56, tax: 3.5, shipping: \\\n3, total: 56.5 },$\n  );$\n$\n  assert.deepEqual($\n    calculateInvoice({$\n      items: [{ price: 125, qty: 1 }],$\n      region: 'US',$\n      coupon: 'SAVE20',$\n      express: true,$\n    }),$\n    { subtotal: 125, discount: 25, tax: 7, shipping: 12, to\\\ntal: 119 },$\n  );$\n});$\n$\ntest('cent rounding applies independently to subtotal, disc\\\nount, tax, shipping, and total', () => {$\n  assert.deepEqual($\n    calculateInvoice({$\n      items: [{ price: 0.335, qty: 1 }],$\n      region: 'EU',$\n      coupon: 'SAVE10',$\n      express: true,$\n    }),$\n    { subtotal: 0.34, discount: 0.03, tax: 0.06, shipping: \\\n19.5, total: 19.86 },$\n  );$\n});$\n","exit_code":0,"status":"completed"}}
