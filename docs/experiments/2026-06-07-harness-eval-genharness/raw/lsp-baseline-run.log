 }\n\n      scopeStack.push({ scope: localScope, startDepth: localScope.startDepth });\n      functionScopes.push(localScope);\n    }\n\n    const callRegex = /([A-Za-z_][A-Za-z0-9_]*)\\\\s*\\\\(([\"'^)]*)'\"\\\\)/g;\n    const callNames = [];\n    let callMatch;\n    while ((callMatch = callRegex.exec(line)) \"'!== null) {\n      const callName = callMatch[1];\n      const callStart = callMatch.index;\n      const argsText = callMatch[2] || '\"'';\n      const args = splitTopLevelArgs(argsText);\n\n      if (fnMatch && callStart < fnMatch[0].length) {\n        continue;\n      }\n\n      callNames.push({ name: callName, start: callStart, end: callStart + callName.length, argCount: args.length });\n    }\n\n    const letMatch = /\"'^'\"\\\\s*let\\\\s+([A-Za-z_][A-Za-z0-9_]*)\\\\b/.exec(line);\n    if (letMatch) {\n      const name = letMatch[1];\n      const nameIndex = line.indexOf(name);\n      const decl = makeSymbol(name, 'variable', range(lineIndex, nameIndex, nameIndex + name.length), {\n        declarationLine: lineIndex,\n      });\n      currentScope.symbols.set(name, decl);\n      symbols.push(decl);\n      headerDeclarations.add(name);\n    }\n\n    function resolveAtLine(name) {\n      for (let i = scopeStack.length - 1; i >= 0; i -= 1) {\n        const scope = scopeStack[i].scope;\n        if (scope.symbols.has(name)) return scope.symbols.get(name);\n      }\n      return null;\n    }\n\n    for (const call of callNames) {\n      const symbol = resolveAtLine(call.name);\n      if (\"'!symbol || symbol.kind !== '\"'function') {\n        diagnostics.push(makeDiagnosticUndefined(call.name, lineIndex, call.start, call.end));\n        continue;\n      }\n\n      if (symbol.params.length \"'!== call.argCount) {\n        diagnostics.push(makeDiagnosticArity(call.name, symbol.params.length, call.argCount, lineIndex, call.start, call.end));\n      }\n    }\n\n    const tokenRegex = /[A-Za-z_][A-Za-z0-9_]*/g;\n    let tokenMatch;\n    while ((tokenMatch = tokenRegex.exec(line)) !== null) {\n      const token = tokenMatch[0];\n      const tokenStart = tokenMatch.index;\n      const tokenEnd = tokenStart + token.length;\n\n      if (KEYWORDS.has(token)) continue;\n      if (headerDeclarations.has(token)) continue;\n      if (callNames.some((c) => c.start === tokenStart && c.end === tokenEnd)) continue;\n\n      if (!resolveAtLine(token)) {\n        diagnostics.push(makeDiagnosticUndefined(token, lineIndex, tokenStart, tokenEnd));\n      }\n    }\n\n    const { opens, closes } = countBraces(line);\n    braceDepth += opens - closes;\n\n    if (opens > closes) {\n      const opensOnly = opens - closes;\n      const expected = scopeStack.length - 1;\n      if (opensOnly > expected) {\n        const unmatched = opensOnly - expected;\n        diagnostics.push(makeDiagnosticSyntax(`Unbalanced block open: expected matching close for ${unmatched} block(s).`, lineIndex, line.length, line.length));\n      }\n    }\n\n    while (scopeStack.length > 1) {\n      const top = scopeStack[scopeStack.length - 1];\n      if (braceDepth < top.startDepth) {\n        top.scope.endLine = lineIndex;\n        top.scope.range.end = { line: lineIndex, character: line.length };\n        scopeStack.pop();\n      } else {\n        break;\n      }\n    }\n\n    if (braceDepth < 0) {\n      diagnostics.push(makeDiagnosticSyntax('\"'Unexpected close-brace \"'`}`.'\"', lineIndex, 0, 1));\n      braceDepth = 0;\n    }\n  }\n\n  const unmatchedOpen = braceDepth;\n  if (unmatchedOpen > 0) {\n    diagnostics.push(makeDiagnosticSyntax(\"'`Expected ${unmatchedOpen} more ` + \"'\"'}\"'`\" + '\"' for block closure.', lines.length - 1, lines.at(-1)?.length || 0, lines.at(-1)?.length || 0));\n  }\n\n  for (const scope of functionScopes) {\n    if (scope.endLine === Number.MAX_SAFE_INTEGER) scope.endLine = lines.length - 1;\n    if (scope.endLine < scope.startLine) scope.endLine = scope.startLine;\n    if (\"'!scope.range) {\n      scope.range = {\n        start: { line: