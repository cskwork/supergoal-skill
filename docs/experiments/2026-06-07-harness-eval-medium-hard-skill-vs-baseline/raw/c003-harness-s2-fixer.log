{"type":"item.completed","item":{"id":"item_18","type":"command_execution","command":"/bin/zsh -lc \"node -e \\\"import('node:fs').then(fs=>console.log(fs.readFileSync('src/order.mjs','utf8')))\\\"\"","aggregated_output":"export function calculateInvoice(order) {\n  let subtotal = calculateSubtotal(order.items);\n  let discount = calculateDiscount(order, subtotal);\n  let taxed = subtotal - discount;\n  let tax = calculateTax(order.region, taxed);\n  let shipping = calculateShipping(order, taxed);\n  let total = taxed + tax + shipping;\n\n  return {\n    subtotal: roundCents(subtotal),\n    discount: roundCents(discount),\n    tax: roundCents(tax),\n    shipping: roundCents(shipping),\n    total: roundCents(total),\n  };\n}\n\nfunction calculateSubtotal(items) {\n  let subtotal = 0;\n  for (let i = 0; i < items.length; i++) {\n    subtotal += items[i].price * items[i].qty;\n  }\n  return subtotal;\n}\n\nfunction calculateDiscount(order, subtotal) {\n  let discount = calculateCouponDiscount(order, subtotal);\n  if (order.vip && discount < subtotal * 0.05) {\n    discount = subtotal * 0.05;\n  }\n  return discount;\n}\n\nfunction calculateCouponDiscount(order, subtotal) {\n  if (!order.coupon) {\n    return 0;\n  }\n  if (order.coupon === 'SAVE10') {\n    return subtotal * 0.1;\n  }\n  if (order.coupon === 'SAVE20') {\n    if (subtotal >= 100) {\n      return subtotal * 0.2;\n    }\n    return subtotal * 0.1;\n  }\n  if (order.coupon === 'HALF' && order.vip) {\n    return subtotal * 0.5;\n  }\n  return 0;\n}\n\nfunction calculateTax(region, taxed) {\n  if (region === 'US') {\n    return taxed * 0.07;\n  }\n  if (region === 'EU') {\n    return taxed * 0.2;\n  }\n  return taxed * 0.1;\n}\n\nfunction calculateShipping(order, taxed) {\n  let shipping = 0;\n  if (taxed < 50) {\n    shipping = 7.5;\n  } else if (taxed < 100) {\n    shipping = 3;\n  } else {\n    shipping = 0;\n  }\n  if (order.express) {\n    shipping += 12;\n  }\n  return shipping;\n}\n\nfunction roundCents(amount) {\n  return Math.round(amount * 100) / 100;\n}\n\n","exit_code":0,"status":"completed"}}
