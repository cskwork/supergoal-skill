{"type":"item.started","item":{"id":"item_75","type":"command_execution","command":"/bin/zsh -lc \"cat > src/billing.mjs <<'EOF'\n// MiniBill invoice engine.\nconst RATES = {\n  standard: 2000,\n  reduced: 500,\n  exempt: 0,\n};\n\nfunction roundHalfToEvenDivide(numerator, denominator) {\n  const sign = numerator < 0 ? -1 : 1;\n  const value = Math.abs(numerator);\n  const quotient = Math.floor(value / denominator);\n  const remainder = value - quotient * denominator;\n\n  if (remainder > denominator / 2) {\n    return sign * (quotient + 1);\n  }\n  if (remainder < denominator / 2) {\n    return sign * quotient;\n  }\n\n  return sign * (quotient % 2 === 0 ? quotient : quotient + 1);\n}\n\nexport function computeInvoice(invoice = {}) {\n  const {\n    lines = [],\n    orderDiscountMinor = 0,\n    shippingMinor = 0,\n  } = invoice;\n\n  let subtotal = 0;\n  let totalTax = 0;\n\n  for (const line of lines) {\n    const gross = line.qty * line.unitPriceMinor;\n    const lineDiscount = roundHalfToEvenDivide(\n      gross * (line.lineDiscountBps || 0),\n      10000,\n    );\n    const lineNet = gross - lineDiscount;\n    subtotal += lineNet;\n\n    const rate = RATES[line.category] ?? RATES.standard;\n    const lineTax = roundHalfToEvenDivide(lineNet * rate, 10000);\n    totalTax += lineTax;\n  }\n\n  const taxableSubtotal = Math.max(0, subtotal - orderDiscountMinor);\n  const grandTotal = Math.max(0, taxableSubtotal + totalTax + shippingMinor);\n\n  return {\n    subtotal,\n    totalTax,\n    shipping: shippingMinor,\n    grandTotal,\n  };\n}\n\nexport default computeInvoice;\nEOF\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
