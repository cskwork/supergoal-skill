eNo, nameStart, nameStart + name.length),\n        detail: `let ${name}`,\n      };\n      symbols.push(symbol);\n      variables.set(name, symbol);\n      currentFunction?.locals.set(name, true);\n      continue;\n    }\n\n    if (/^\\s*let\\b/.test(line)) {\n      diagnostics.push(diagnostic(lineNo, indent, line.length, 'Malformed variable declaration'));\n      continue;\n    }\n\n    if (/^\\s*return\\b/.test(line)) {\n      const expr = line.replace(/^\\s*return\\s*/, '');\n      if (!expr.trim()) {\n        diagnostics.push(diagnostic(lineNo, line.indexOf('return'), line.length, 'Return statement is missing an expression'));\n      }\n      continue;\n    }\n\n    if (/^\\s*\\}/.test(line)) {\n      braceDepth = Math.max(0, braceDepth - 1);\n      if (braceDepth === 0) currentFunction = null;\n      continue;\n    }\n\n    if (findCalls(line).length === 0) {\n      diagnostics.push(diagnostic(lineNo, indent, line.length, 'Unrecognized statement'));\n    }\n  }\n\n  const knownVariables = new Set([...variables.keys()]);\n  for (const symbol of symbols) {\n    if (symbol.kind === 'function') {\n      for (const param of symbol.params) knownVariables.add(param);\n    }\n  }\n\n  for (let lineNo = 0; lineNo < lines.length; lineNo++) {\n    const line = stripComment(lines[lineNo]);\n    for (const call of findCalls(line)) {\n      if (KEYWORDS.includes(call.name)) continue;\n      const fn = functions.get(call.name);\n      if (!fn) {\n        diagnostics.push(diagnostic(lineNo, call.index, call.index + call.name.length, `Undefined function '${call.name}'`));\n      } else if (call.args.length !== fn.params.length) {\n        diagnostics.push(diagnostic(\n          lineNo,\n          call.index,\n          call.index + call.name.length,\n          `Function '${call.name}' expected ${fn.params.length} argument(s), got ${call.args.length}`,\n        ));\n      }\n    }\n\n    const identifierPattern = /\\b([A-Za-z_][A-Za-z0-9_]*)\\b/g;\n    let match;\n    while ((match = identifierPattern.exec(line)) !== null) {\n      const name = match[1];\n      const next = line.slice(match.index + name.length).trimStart()[0];\n      if (KEYWORDS.includes(name) || functions.has(name) || knownVariables.has(name) || next === '(') continue;\n      diagnostics.push(diagnostic(lineNo, match.index, match.index + name.length, `Undefined variable '${name}'`));\n    }\n  }\n\n  return { text, diagnostics, symbols };\n}\n\nexport class MiniLangServer {\n  constructor() {\n    this.documents = new Map();\n    this.notifications = [];\n    this.shutdownRequested = false;\n  }\n\n  async handle(message) {\n    if (message.method === 'initialize') return this.response(message.id, this.initializeResult());\n    if (message.method === 'shutdown') {\n      this.shutdownRequested = true;\n      return this.response(message.id, null);\n    }\n    if (message.method === 'exit') return null;\n    if (message.method === 'textDocument/didOpen') return this.didOpen(message.params);\n    if (message.method === 'textDocument/didChange') return this.didChange(message.params);\n    if (message.method === 'textDocument/completion') return this.response(message.id, this.completionItems());\n    if (message.method === 'textDocument/definition') return this.response(message.id, this.definition(message.params));\n    if (message.method === 'textDocument/hover') return this.response(message.id, this.hover(message.params));\n    if (message.id !== undefined) return this.response(message.id, null);\n    return null;\n  }\n\n  response(id, result) {\n    return { jsonrpc: '2.0', id, result };\n  }\n\n  initializeResult() {\n    return {\n      capabilities: {\n        textDocumentSync: 2,\n        completionProvider: { triggerCharacters: ['(', ','] },\n        definitionProvider: true,\n        hoverProvider: true,\n      },\n    };\n  }\n\n  didOpen(params) {\n    const doc = params.textDocument;\n    this.updateDocument(doc.uri, doc.text, doc.version);\n    return null;\n  }\n\n  didChange(params) {\n    const uri = params.textDocument.uri;\n    const existing = this.documents.get(uri);\n    let text = existing?.text ?? '';\n\n    for (const change of params.contentChanges ?? []) {\n      if (!change.range) {\n        text = change.text;\n      } else {\n        text = applyTextChange(text, change);\n      }\n    }\n\n    this.updateDocument(uri, text, params.textDocument.version);\n    return null;\n  }\n\n  updateDocument(uri, text, version) {\n    const parsed = parseMiniLang(text);\n    this.documents.set(uri, { uri, version, text, parsed });\n    this.notifications.push({\n      jsonrpc: '2.0',\n      method: 'textDocument/publishDiagnostics',\n      params: { uri, diagnostics: parsed.diagnostics },\n    });\n  }\n\n  completionItems() {\n    const symbols = [...this.documents.values()].flatMap((doc) => doc.parsed.symbols);\n    return {\n      isIncomplete: false,\n      items: [\n        ...KEYWORDS.map((label) => ({ label, kind: 14 })),\n        ...symbols.map((symbol) => ({\n          label: symbol.name,\n          kind: symbol.kind === 'function' ? 3 : 6,\n          detail: symbol.detail,\n        })),\n      ],\n    };\n  }\n\n  definition(params) {\n    const doc = this.documents.get(params.textDocument.uri);\n    if (!doc) return null;\n    const word = wordAt(doc.text, params.position);\n    if (!word) return null;\n    const symbol = doc.parsed.symbols.find((item) => item.name === word.name);\n    return symbol ? { uri: doc.uri, range: symbol.range } : null;\n  }\n\n  hover(params) {\n    const doc = this.documents.get(params.textDocument.uri);\n    if (!doc) return null;\n    const word = wordAt(doc.text, params.position);\n    if (!word) return null;\n    const symbol = doc.parsed.symbols.find((item) => item.name === word.name);\n    if (!symbol) return null;\n    return {\n      contents: {\n        kind: 'markdown',\n        value: symbol.kind === 'function' ? `\\`${symbol.detail}\\`` : `\\`${symbol.detail}\\``,\n      },\n      range: word.range,\n    };\n  }\n\n  takeNotifications() {\n    const out = this.notifications;\n    this.notifications = [];\n    return out;\n  }\n\n  getDiagnostics(uri) {\n    return this.documents.get(uri)?.parsed.diagnostics ?? [];\n  }\n}\n\nfunction offsetAt(text, position) {\n  const lines = text.split(/\\r?\\n/);\n","exit_code":0,"status":"completed"}}
