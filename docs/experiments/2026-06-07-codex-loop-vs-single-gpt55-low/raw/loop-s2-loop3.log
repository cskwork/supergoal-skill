  }\n   322\t  }\n   323\t}\n   324\t\n   325\tfunction closeScopes(state, raw, lineNo) {\n   326\t  for (const char of raw) {\n   327\t    if (char === '{') state.braceDepth += 1;\n   328\t    if (char !== '}') continue;\n   329\t    state.braceDepth = Math.max(0, state.braceDepth - 1);\n   330\t    if (state.braceDepth === 0 && state.currentFunction) {\n   331\t      state.currentFunction.endLine = lineNo;\n   332\t      state.scopes.pop();\n   333\t      state.currentFunction = null;\n   334\t    }\n   335\t  }\n   336\t}\n   337\t\n   338\tfunction applyTextChange(text, change) {\n   339\t  const start = offsetAt(text, change.range.start);\n   340\t  const end = offsetAt(text, change.range.end);\n   341\t  return `${text.slice(0, start)}${change.text}${text.slice(end)}`;\n   342\t}\n   343\t\n   344\tfunction offsetAt(text, position) {\n   345\t  const lines = text.split(/\\n/);\n   346\t  let offset = 0;\n   347\t  for (let line = 0; line < Math.min(position.line, lines.length); line += 1) {\n   348\t    offset += lines[line].length + 1;\n   349\t  }\n   350\t  return offset + Math.min(position.character, lines[position.line]?.length ?? 0);\n   351\t}\n   352\t\n   353\tfunction wordAt(text, position) {\n   354\t  const line = text.split(/\\r?\\n/)[position.line] ?? '';\n   355\t  const regex = /\\b[A-Za-z_]\\w*\\b/g;\n   356\t  for (const match of line.matchAll(regex)) {\n   357\t    const start = match.index;\n   358\t    const end = start + match[0].length;\n   359\t    if (position.character >= start && position.character <= end) {\n   360\t      return { text: match[0], range: rangeFor(position.line, start, end) };\n   361\t    }\n   362\t  }\n   363\t  return null;\n   364\t}\n   365\t\n   366\tfunction visibleSymbols(symbols, position) {\n   367\t  const activeFunction = symbols.find((symbol) => {\n   368\t    if (symbol.kind !== 'function') return false;\n   369\t    if (symbol.range.start.line > position.line) return false;\n   370\t    return symbol.endLine === undefined || symbol.endLine >= position.line;\n   371\t  });\n   372\t\n   373\t  return symbols.filter((symbol) => {\n   374\t    if (symbol.kind === 'function') return true;\n   375\t    if (symbol.container && symbol.container !== activeFunction?.name) return false;\n   376\t    if (symbol.range.start.line > position.line) return false;\n   377\t    return symbol.range.start.line < position.line || symbol.range.start.character <= position.character;\n   378\t  });\n   379\t}\n   380\t\n   381\tfunction pushCompletion(items, seen, item) {\n   382\t  if (seen.has(item.label)) return;\n   383\t  seen.add(item.label);\n   384\t  items.push(item);\n   385\t}\n   386\t\n   387\tfunction initializeResult() {\n   388\t  return {\n   389\t    capabilities: {\n   390\t      textDocumentSync: 2,\n   391\t      completionProvider: { triggerCharacters: [''] },\n   392\t      definitionProvider: true,\n   393\t      hoverProvider: true,\n   394\t    },\n   395\t  };\n   396\t}\n   397\t\n   398\tfunction response(id, result) {\n   399\t  return { jsonrpc: '2.0', id, result };\n   400\t}\n   401\t\n   402\tfunction errorResponse(id, code, message) {\n   403\t  return { jsonrpc: '2.0', id, error: { code, message } };\n   404\t}\n   405\t\n   406\tfunction stripComment(line) {\n   407\t  return line.split('#')[0];\n   408\t}\n   409\t\n   410\tfunction splitParams(text, line, baseCol, diagnostics) {\n   411\t  const params = splitArgs(text);\n   412\t  for (const param of params) {\n   413\t    if (!/^[A-Za-z_]\\w*$/.test(param)) {\n   414\t      diagnostics.push(diag(line, baseCol, baseCol + text.length, `Invalid parameter ${param}`));\n   415\t    }\n   416\t  }\n   417\t  return params.filter((param) => /^[A-Za-z_]\\w*$/.test(param));\n   418\t}\n   419\t\n   420\tfunction splitArgs(text) {\n   421\t  const trimmed = text.trim();\n   422\t  if (!trimmed) return [];\n   423\t  return trimmed.split(',').map((arg) => arg.trim()).filter(Boolean);\n   424\t}\n   425\t\n   426\tfunction lookup(scopes, name) {\n   427\t  for (let index = scopes.length - 1; index >= 0; index -= 1) {\n   428\t    const found = scopes[index].get(name);\n   429\t    if (found) return found;\n   430\t  }\n   431\t  return null;\n   432\t}\n   433\t\n   434\tfunction makeSymbol(kind, name, line, col, extra = {}) {\n   435\t  return {\n   436\t    kind,\n   437\t    name,\n   438\t    range: rangeFor(line, col, col + name.length),\n   439\t    selectionRange: rangeFor(line, col, col + name.length),\n   440\t    ...extra,\n   441\t  };\n   442\t}\n   443\t\n   444\tfunction rangeFor(line, start, end) {\n   445\t  return {\n   446\t    start: { line, character: Math.max(0, start) },\n   447\t    end: { line, character: Math.max(0, end) },\n   448\t  };\n   449\t}\n   450\t\n   451\tfunction diag(line, start, end, message) {\n   452\t  return diagFromRange(rangeFor(line, start, end), message);\n   453\t}\n   454\t\n   455\tfunction diagFromRange(range, message) {\n   456\t  return { range, severity: 1, source: 'minilang', message };\n   457\t}\n   458\t\n   459\tfunction arityMessage(name, expected, actual) {\n   460\t  return `Function ${name} expected ${expected} argument(s), got ${actual}`;\n   461\t}\n   462\t\n   463\tfunction contains(range, position) {\n   464\t  if (position.line !== range.start.line) return false;\n   465\t  return position.character >= range.start.character && position.character <= range.end.character;\n   466\t}\n   467\t\n   468\tfunction sameRange(left, right) {\n   469\t  return left.start.line === right.start.line\n   470\t    && left.start.character === right.start.character\n   471\t    && left.end.line === right.end.line\n   472\t    && left.end.character === right.end.character;\n   473\t}\n   474\t\n   475\texport default MiniLangServer;\n","exit_code":0,"status":"completed"}}
