{"type":"item.completed","item":{"id":"item_13","type":"command_execution","command":"/bin/zsh -lc 'nl -ba src/server.mjs'","aggregated_output":"     1\texport function encodeMessage(message) {\n     2\t  const payload = JSON.stringify(message);\n     3\t  const length = Buffer.byteLength(payload, 'utf8');\n     4\t  return `Content-Length: ${length}\\r\\n\\r\\n${payload}`;\n     5\t}\n     6\t\n     7\texport class MessageBuffer {\n     8\t  constructor() {\n     9\t    this.buffer = '';\n    10\t  }\n    11\t\n    12\t  push(chunk) {\n    13\t    if (chunk instanceof Buffer) {\n    14\t      chunk = chunk.toString('utf8');\n    15\t    } else if (typeof chunk !== 'string') {\n    16\t      return [];\n    17\t    }\n    18\t\n    19\t    this.buffer += chunk;\n    20\t    const messages = [];\n    21\t\n    22\t    while (true) {\n    23\t      const headerEnd = this.buffer.indexOf('\\r\\n\\r\\n');\n    24\t      if (headerEnd === -1) {\n    25\t        break;\n    26\t      }\n    27\t\n    28\t      const header = this.buffer.slice(0, headerEnd);\n    29\t      const lines = header.split('\\r\\n');\n    30\t      const contentLengthLine = lines.find((line) => line.toLowerCase().startsWith('content-length:'));\n    31\t\n    32\t      if (!contentLengthLine) {\n    33\t        throw new Error('Invalid JSON-RPC framing: missing Content-Length');\n    34\t      }\n    35\t\n    36\t      const contentLength = Number(contentLengthLine.split(':')[1]?.trim());\n    37\t      if (!Number.isFinite(contentLength) || contentLength < 0) {\n    38\t        throw new Error('Invalid JSON-RPC framing: invalid Content-Length');\n    39\t      }\n    40\t\n    41\t      const bodyStart = headerEnd + 4;\n    42\t      const bodyEnd = bodyStart + contentLength;\n    43\t      if (this.buffer.length < bodyEnd) {\n    44\t        break;\n    45\t      }\n    46\t\n    47\t      const body = this.buffer.slice(bodyStart, bodyEnd);\n    48\t      this.buffer = this.buffer.slice(bodyEnd);\n    49\t\n    50\t      messages.push(JSON.parse(body));\n    51\t    }\n    52\t\n    53\t    return messages;\n    54\t  }\n    55\t}\n    56\t\n    57\tconst KEYWORDS = new Set(['fn', 'let', 'return']);\n    58\t\n    59\tfunction parseParams(paramText) {\n    60\t  return paramText\n    61\t    .split(',')\n    62\t    .map((param) => param.trim())\n    63\t    .filter(Boolean)\n    64\t    .map((param) => param.replace(/^([A-Za-z_][A-Za-z0-9_]*)\\b.*$/, '$1'))\n    65\t    .filter(Boolean);\n    66\t}\n    67\t\n    68\tfunction makeRange(lineText, line, start, name) {\n    69\t  return {\n    70\t    start: { line, character: start },\n    71\t    end: { line, character: start + name.length },\n    72\t  };\n    73\t}\n    74\t\n    75\tfunction makeDiagnostic(lineText, line, match, message) {\n    76\t  return {\n    77\t    message,\n    78\t    severity: 1,\n    79\t    range: {\n    80\t      start: { line, character: match.index },\n    81\t      end: { line, character: match.index + match[0].length },\n    82\t    },\n    83\t    source: lineText,\n    84\t  };\n    85\t}\n    86\t\n    87\tfunction symbolKey(line, from, to) {\n    88\t  return `${line}:${from}-${to}`;\n    89\t}\n    90\t\n    91\tfunction countCallArgs(lineText, openParenIndex) {\n    92\t  if (lineText[openParenIndex] !== '(') {\n    93\t    return { count: null, closeIndex: openParenIndex };\n    94\t  }\n    95\t\n    96\t  let count = 0;\n    97\t  let nested = 0;\n    98\t  let closeIndex = -1;\n    99\t  let i = openParenIndex + 1;\n   100\t\n   101\t  // Empty argument list.\n   102\t  while (i < lineText.length && /\\s/.test(lineText[i])) {\n   103\t    i += 1;\n   104\t  }\n   105\t\n   106\t  if (lineText[i] === ')') {\n   107\t    return { count: 0, closeIndex: i };\n   108\t  }\n   109\t\n   110\t  count = 1;\n   111\t\n   112\t  for (; i < lineText.length; i += 1) {\n   113\t    const char = lineText[i];\n   114\t\n   115\t    if (char === '(') {\n   116\t      nested += 1;\n   117\t    } else if (char === ')') {\n   118\t      if (nested === 0) {\n   119\t        closeIndex = i;\n   120\t        break;\n   121\t      }\n   122\t      nested -= 1;\n   123\t    } else if (char === ',' && nested === 0) {\n   124\t      count += 1;\n   125\t    }\n   126\t  }\n   127\t\n   128\t  if (closeIndex === -1) {\n   129\t    return { count: null, closeIndex: lineText.length };\n   130\t  }\n   131\t\n   132\t  return { count, closeIndex };\n   133\t}\n   134\t\n   135\tfunction tokenAt(lineText, column) {\n   136\t  if (!lineText) {\n   137\t    return null;\n   138\t  }\n   139\t\n   140\t  if (!/[A-Za-z_]/.test(lineText[column] || '')) {\n   141\t    return null;\n   142\t  }\n   143\t\n   144\t  let start = column;\n   145\t  while (start > 0 && /[A-Za-z0-9_]/.test(lineText[start - 1])) {\n   146\t    start -= 1;\n   147\t  }\n   148\t\n   149\t  let end = column;\n   150\t  while (end < lineText.length && /[A-Za-z0-9_]/.test(lineText[end])) {\n   151\t    end += 1;\n   152\t  }\n   153\t\n   154\t  if (start === end) {\n   155\t    return null;\n   156\t  }\n   157\t\n   158\t  return {\n   159\t    name: lineText.slice(start, end),\n   160\t    start,\n   161\t    end,\n   162\t  };\n   163\t}\n   164\t\n   165\texport function parseMiniLang(text) {\n   166\t  const lines = text.split('\\n');\n   167\t  const diagnostics = [];\n   168\t  const symbols = [];\n   169\t  const scopes = [];\n   170\t  const declarationTokens = new Set();\n   171\t\n   172\t  const globalScope = {\n   173\t    id: 'global',\n   174\t    startLine: 0,\n   175\t    endLine: Infinity,\n   176\t    depth: 0,\n   177\t    symbols: new Map(),\n   178\t  };\n   179\t\n   180\t  const activeScopes = [globalScope];\n   181\t  scopes.push(globalScope);\n   182\t\n   183\t  let depth = 0;\n   184\t\n   185\t  for (let line = 0; line < lines.length; line += 1) {\n   186\t    const lineText = lines[line];\n   187\t\n   188\t    const fnMatch = lineText.match(/^\\s*fn\\s