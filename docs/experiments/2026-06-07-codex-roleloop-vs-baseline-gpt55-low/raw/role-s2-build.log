es = text.split(/\\r?\\n/);\n  const before = lines.slice(0, change.range.start.line).join('\\n')\n    + (change.range.start.line ? '\\n' : '')\n    + (lines[change.range.start.line] ?? '').slice(0, change.range.start.character);\n  const after = (lines[change.range.end.line] ?? '').slice(change.range.end.character)\n    + (change.range.end.line < lines.length - 1 ? '\\n' + lines.slice(change.range.end.line + 1).join('\\n') : '');\n  return before + change.text + after;\n}\n\nfunction functionAt(parsed, position) {\n  return [...parsed.functions.values()].find((fn) => {\n    const endLine = fn.endLine ?? Number.MAX_SAFE_INTEGER;\n    return fn.range.start.line <= position.line && position.line <= endLine;\n  })?.name;\n}\n\nexport class MiniLangServer {\n  constructor() {\n    this.documents = new Map();\n    this.notifications = [];\n    this.shutdownRequested = false;\n  }\n\n  async handle(message) {\n    if (message.method === 'initialize') return this.respond(message.id, this.initializeResult());\n    if (message.method === 'shutdown') {\n      this.shutdownRequested = true;\n      return this.respond(message.id, null);\n    }\n    if (message.method === 'exit') return null;\n    if (message.method === 'textDocument/didOpen') return this.didOpen(message.params.textDocument);\n    if (message.method === 'textDocument/didChange') return this.didChange(message.params);\n    if (message.method === 'textDocument/completion') return this.respond(message.id, this.completion(message.params));\n    if (message.method === 'textDocument/definition') return this.respond(message.id, this.definition(message.params));\n    if (message.method === 'textDocument/hover') return this.respond(message.id, this.hover(message.params));\n    if ('id' in message) return { jsonrpc: '2.0', id: message.id, error: { code: -32601, message: 'Method not found' } };\n    return null;\n  }\n\n  respond(id, result) {\n    return { jsonrpc: '2.0', id, result };\n  }\n\n  initializeResult() {\n    return {\n      capabilities: {\n        textDocumentSync: 2,\n        completionProvider: { triggerCharacters: [' ', '('] },\n        definitionProvider: true,\n        hoverProvider: true,\n      },\n    };\n  }\n\n  didOpen(document) {\n    this.setDocument(document.uri, document.text, document.version);\n    return null;\n  }\n\n  didChange(params) {\n    const doc = this.documents.get(params.textDocument.uri);\n    let text = doc?.text ?? '';\n    for (const change of params.contentChanges ?? []) text = applyChange(text, change);\n    this.setDocument(params.textDocument.uri, text, params.textDocument.version);\n    return null;\n  }\n\n  setDocument(uri, text, version) {\n    const parsed = parseMiniLang(text);\n    this.documents.set(uri, { uri, text, version, parsed });\n    this.notifications.push({ jsonrpc: '2.0', method: 'textDocument/publishDiagnostics', params: { uri, diagnostics: parsed.diagnostics } });\n  }\n\n  takeNotifications() {\n    const out = this.notifications;\n    this.notifications = [];\n    return out;\n  }\n\n  getDiagnostics(uri) {\n    return this.documents.get(uri)?.parsed.diagnostics ?? [];\n  }\n\n  completion(params) {\n    const doc = this.documents.get(params.textDocument.uri);\n    const names = doc ? doc.parsed.symbols.map((symbol) => symbol.name) : [];\n    const labels = [...new Set([...KEYWORDS, ...names])];\n    return { isIncomplete: false, items: labels.map((label) => ({ label, kind: KEYWORDS.includes(label) ? 14 : 6 })) };\n  }\n\n  definition(params) {\n    const symbol = this.resolveSymbol(params);\n    return symbol ? { uri: params.textDocument.uri, range: symbol.range } : null;\n  }\n\n  hover(params) {\n    const symbol = this.resolveSymbol(params);\n    if (!symbol) return null;\n    const contents = symbol.kind === 'function'\n      ? `fn ${symbol.name}(${symbol.params.join(', ')})`\n      : `${symbol.kind} ${symbol.name}`;\n    return { contents, range: symbol.range };\n  }\n\n  resolveSymbol(params) {\n    con