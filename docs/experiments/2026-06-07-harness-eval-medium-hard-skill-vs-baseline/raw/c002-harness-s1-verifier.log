{"type":"item.completed","item":{"id":"item_2","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' test/spec.gen.test.mjs\"","aggregated_output":"import assert from 'node:assert/strict';\nimport test from 'node:test';\nimport AsyncCache from '../src/cache.mjs';\n\nfunction deferred() {\n  let resolve;\n  let reject;\n  const promise = new Promise((res, rej) => {\n    resolve = res;\n    reject = rej;\n  });\n  return { promise, resolve, reject };\n}\n\ntest('clear() prevents an older in-flight load from repopulating the cache', async () => {\n  const cache = new AsyncCache();\n  const pending = deferred();\n\n  const load = cache.get('a', async () => pending.promise);\n\n  assert.equal(cache.has('a'), false);\n  cache.clear();\n\n  pending.resolve('stale');\n  assert.equal(await load, 'stale');\n\n  assert.equal(cache.has('a'), false);\n\n  let calls = 0;\n  const fresh = await cache.get('a', async () => {\n    calls += 1;\n    return 'fresh';\n  });\n\n  assert.equal(fresh, 'fresh');\n  assert.equal(calls, 1);\n});\n\ntest('get() after clear() starts a new load instead of joining a stale in-flight load', async () => {\n  const cache = new AsyncCache();\n  const staleLoad = deferred();\n  const freshLoad = deferred();\n  const values = [];\n\n  const first = cache.get('a', async () => staleLoad.promise);\n  cache.clear();\n\n  const second = cache.get('a', async () => freshLoad.promise);\n\n  staleLoad.resolve('stale');\n  freshLoad.resolve('fresh');\n\n  values.push(await first);\n  values.push(await second);\n\n  assert.deepEqual(values, ['stale', 'fresh']);\n  assert.equal(cache.has('a'), true);\n  assert.equal(await cache.get('a', async () => 'unexpected'), 'fresh');\n});\n","exit_code":0,"status":"completed"}}
