{"type":"item.completed","item":{"id":"item_3","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' test/spec.gen.test.mjs\"","aggregated_output":"import assert from 'node:assert/strict';\nimport test from 'node:test';\nimport * as orderModule from '../src/order.mjs';\n\nconst { calculateInvoice } = orderModule;\n\ntest('public API exports only calculateInvoice as a function', () => {\n  assert.deepEqual(Object.keys(orderModule).sort(), ['calculateInvoice']);\n  assert.equal(typeof calculateInvoice, 'function');\n});\n\ntest('invoice result keeps the required field order and rounds half cents up', () => {\n  const invoice = calculateInvoice({\n    items: [{ price: 1.005, qty: 1 }],\n    region: 'US',\n  });\n\n  assert.deepEqual(Object.keys(invoice), ['subtotal', 'discount', 'tax', 'shipping', 'total']);\n  assert.deepEqual(invoice, {\n    subtotal: 1.01,\n    discount: 0,\n    tax: 0.07,\n    shipping: 7.5,\n    total: 8.58,\n  });\n});\n\ntest('VIP floor never reduces a larger small SAVE10 coupon discount', () => {\n  assert.deepEqual(calculateInvoice({\n    items: [{ price: 0.1, qty: 3 }],\n    region: 'APAC',\n    coupon: 'SAVE10',\n    vip: true,\n  }), {\n    subtotal: 0.3,\n    discount: 0.03,\n    tax: 0.03,\n    shipping: 7.5,\n    total: 7.8,\n  });\n});\n\ntest('SAVE20 uses 10 percent below the exact 100 subtotal threshold', () => {\n  assert.deepEqual(calculateInvoice({\n    items: [{ price: 99.99, qty: 1 }],\n    region: 'EU',\n    coupon: 'SAVE20',\n  }), {\n    subtotal: 99.99,\n    discount: 10,\n    tax: 18,\n    shipping: 3,\n    total: 110.99,\n  });\n});\n\ntest('shipping tier is based on subtotal minus discount at the 50 boundary', () => {\n  assert.deepEqual(calculateInvoice({\n    items: [{ price: 50, qty: 1 }],\n    region: 'US',\n  }), {\n    subtotal: 50,\n    discount: 0,\n    tax: 3.5,\n    shipping: 3,\n    total: 56.5,\n  });\n});\n\ntest('discounted amount below 50 uses the lowest shipping tier plus express fee', () => {\n  assert.deepEqual(calculateInvoice({\n    items: [{ price: 55, qty: 1 }],\n    region: 'US',\n    coupon: 'SAVE10',\n    express: true,\n  }), {\n    subtotal: 55,\n    discount: 5.5,\n    tax: 3.47,\n    shipping: 19.5,\n    total: 72.47,\n  });\n});\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_2","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,240p' src/order.mjs\"","aggregated_output":"function calculateSubtotal(order) {\n  let subtotal = 0;\n  for (let i = 0; i < order.items.length; i++) {\n    subtotal += order.items[i].price * order.items[i].qty;\n  }\n  return subtotal;\n}\n\nfunction calculateDiscount(order, subtotal) {\n  let discount = 0;\n\n  if (order.coupon) {\n    if (order.coupon === 'SAVE10') {\n      discount = subtotal * 0.1;\n    } else if (order.coupon === 'SAVE20') {\n      if (subtotal >= 100) {\n        discount = subtotal * 0.2;\n      } else {\n        discount = subtotal * 0.1;\n      }\n    } else if (order.coupon === 'HALF' && order.vip) {\n      discount = subtotal * 0.5;\n    }\n  }\n\n  if (order.vip && discount < subtotal * 0.05) {\n    discount = subtotal * 0.05;\n  }\n\n  return discount;\n}\n\nfunction calculateTax(order, taxed) {\n  if (order.region === 'US') {\n    return taxed * 0.07;\n  }\n\n  if (order.region === 'EU') {\n    return taxed * 0.2;\n  }\n\n  return taxed * 0.1;\n}\n\nfunction calculateShipping(order, taxed) {\n  let shipping = 0;\n\n  if (taxed < 50) {\n    shipping = 7.5;\n  } else if (taxed < 100) {\n    shipping = 3;\n  }\n\n  if (order.express) {\n    shipping += 12;\n  }\n\n  return shipping;\n}\n\nfunction roundCents(value) {\n  return Math.round(value * 100) / 100;\n}\n\nexport function calculateInvoice(order) {\n  const subtotal = calculateSubtotal(order);\n  const discount = calculateDiscount(order, subtotal);\n  const taxed = subtotal - discount;\n  const tax = calculateTax(order, taxed);\n  const shipping = calculateShipping(order, taxed);\n  const total = taxed + tax + shipping;\n\n  return {\n    subtotal: roundCents(subtotal),\n    discount: roundCents(discount),\n    tax: roundCents(tax),\n    shipping: roundCents(shipping),\n    total: roundCents(total),\n  };\n}\n","exit_code":0,"status":"completed"}}
