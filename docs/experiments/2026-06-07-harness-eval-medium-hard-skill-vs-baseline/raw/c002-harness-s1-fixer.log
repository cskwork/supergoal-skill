{"type":"item.completed","item":{"id":"item_4","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,220p' src/cache.mjs\"","aggregated_output":"// AsyncCache memoizes async loader results by key.\nexport class AsyncCache {\n  constructor() {\n    this.values = new Map();\n    this.inflight = new Map();\n  }\n\n  // Returns cached value for key, or loads + caches it via loader(key).\n  async get(key, loader) {\n    if (this.values.has(key)) {\n      return this.values.get(key);\n    }\n\n    if (!this.inflight.has(key)) {\n      const load = (async () => {\n        const value = await loader(key);\n        this.values.set(key, value);\n        return value;\n      })().finally(() => {\n        this.inflight.delete(key);\n      });\n\n      this.inflight.set(key, load);\n    }\n\n    return this.inflight.get(key);\n  }\n\n  has(key) {\n    return this.values.has(key);\n  }\n\n  clear() {\n    this.values.clear();\n    this.inflight.clear();\n  }\n}\n\nexport default AsyncCache;\n","exit_code":0,"status":"completed"}}
