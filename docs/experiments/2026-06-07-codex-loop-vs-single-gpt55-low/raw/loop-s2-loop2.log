  if (message.id === undefined) return null;\"\n 86: \"    return response(message.id, null);\"\n 87: \"  }\"\n 88: \"\"\n 89: \"  takeNotifications() {\"\n 90: \"    const out = this.notifications;\"\n 91: \"    this.notifications = [];\"\n 92: \"    return out;\"\n 93: \"  }\"\n 94: \"\"\n 95: \"  getDiagnostics(uri) {\"\n 96: \"    return this.diagnostics.get(uri) ?? [];\"\n 97: \"  }\"\n 98: \"\"\n 99: \"  didOpen(params) {\"\n100: \"    const doc = params.textDocument;\"\n101: \"    this.setDocument(doc.uri, doc.text ?? '', doc.version);\"\n102: \"    return null;\"\n103: \"  }\"\n104: \"\"\n105: \"  didChange(params) {\"\n106: \"    const uri = params.textDocument.uri;\"\n107: \"    const oldText = this.documents.get(uri)?.text ?? '';\"\n108: \"    let text = oldText;\"\n109: \"\"\n110: \"    for (const change of params.contentChanges ?? []) {\"\n111: \"      text = change.range ? applyTextChange(text, change) : change.text;\"\n112: \"    }\"\n113: \"\"\n114: \"    this.setDocument(uri, text, params.textDocument.version);\"\n115: \"    return null;\"\n116: \"  }\"\n117: \"\"\n118: \"  setDocument(uri, text, version) {\"\n119: \"    const parsed = parseMiniLang(text);\"\n120: \"    this.documents.set(uri, { uri, text, version, parsed });\"\n121: \"    this.diagnostics.set(uri, parsed.diagnostics);\"\n122: \"    this.notifications.push({\"\n123: \"      jsonrpc: '2.0',\"\n124: \"      method: 'textDocument/publishDiagnostics',\"\n125: \"      params: { uri, diagnostics: parsed.diagnostics },\"\n126: \"    });\"\n127: \"  }\"\n128: \"\"\n129: \"  completion(params) {\"\n130: \"    const doc = this.documents.get(params.textDocument.uri);\"\n131: \"    const visible = visibleSymbols(doc?.parsed.symbols ?? [], params.position);\"\n132: \"    const seen = new Set();\"\n133: \"    const items = [];\"\n134: \"\"\n135: \"    for (const label of KEYWORDS) pushCompletion(items, seen, { label, kind: 14 });\"\n136: \"    for (const label of BUILTINS) pushCompletion(items, seen, { label, kind: 3, detail: 'builtin function' });\"\n137: \"    for (const symbol of visible) {\"\n138: \"      pushCompletion(items, seen, {\"\n139: \"        label: symbol.name,\"\n140: \"        kind: symbol.kind === 'function' ? 3 : 6,\"\n141: \"        detail: symbol.detail ?? symbol.kind,\"\n142: \"      });\"\n143: \"    }\"\n144: \"\"\n145: \"    return { isIncomplete: false, items };\"\n146: \"  }\"\n147: \"\"\n148: \"  definition(params) {\"\n149: \"    const found = this.symbolAt(params.textDocument.uri, params.position);\"\n150: \"    if (!found) return null;\"\n151: \"    return { uri: params.textDocument.uri, range: found.range };\"\n152: \"  }\"\n153: \"\"\n154: \"  hover(params) {\"\n155: \"    const found = this.symbolAt(params.textDocument.uri, params.position);\"\n156: \"    if (!found) return null;\"\n157: \"    const value = found.detail ?? `${found.kind} ${found.name}`;\"\n158: \"    return { contents: { kind: 'markdown', value: `\\\\`${value}\\\\`` }, range: found.range };\"\n159: \"  }\"\n160: \"\"\n161: \"  symbolAt(uri, position) {\"\n162: \"    const doc = this.documents.get(uri);\"\n163: \"    if (!doc) return null;\"\n164: \"    const word = wordAt(doc.text, position);\"\n165: \"    if (!word) return null;\"\n166: \"\"\n167: \"    const reference = doc.parsed.references.find(\"\n168: \"      (item) => item.name === word.text && contains(item.range, position),\"\n169: \"    );\"\n170: \"    if (reference?.target) return reference.target;\"\n171: \"\"\n172: \"    return doc.parsed.symbols.find(\"\n173: \"      (symbol) => symbol.name === word.text && contains(symbol.range, position),\"\n174: \"    ) ?? null;\"\n175: \"  }\"\n176: \"}\"\n177: \"\"\n178: \"function parseLine(state, raw, lineNo) {\"\n179: \"  const code = stripComment(raw);\"\n180: \"  const trimmed = code.trim();\"\n181: \"  if (!trimmed) return closeScopes(state, raw, lineNo);\"\n182: \"\"\n183: \"  const first = code.search(/\\\\S/);\"\n184: \"  const fn = /^fn\\\\s+([A-Za-z_]\\\\w*)\\\\s*\\\\(([^)]*)\\\\)\\\\s*\\\\{?/.exec(trimmed);\"\n185: \"  if (fn) {\"\n186: \"    addFunction(state, raw, lineNo, fn);\"\n187: \"    parseInlineFunctionBody(state, code, lineNo);\"\n188: \"  } else if (trimmed.startsWith('fn ')) {\"\n189: \"    state.diagnostics.push(diag(lineNo, first, code.length, 'Malformed function declaration'));\"\n190: \"  } else {\"\n191: \"    parseStatement(state, code, trimmed, first, lineNo);\"\n192: \"  }\"\n193: \"\"\n194: \"  closeScopes(state, code, lineNo);\"\n195: \"}\"\n196: \"\"\n197: \"function parseInlineFunctionBody(state, raw, lineNo) {\"\n198: \"  const open = raw.indexOf('{');\"\n199: \"  if (open < 0) return;\"\n200: \"  const close = raw.lastIndexOf('}');\"\n201: \"  const body = raw.slice(open + 1, close > open ? close : undefined).trim();\"\n202: \"  if (!body) return;\"\n203: \"  parseStatement(state, body, body, raw.indexOf(body), lineNo);\"\n204: \"}\"\n205: \"\"\n206: \"function addFunction(state, raw, lineNo, fn) {\"\n207: \"  if (state.currentFunction) {\"\n208: \"    state.diagnostics.push(diag(lineNo, 0, raw.length, 'Nested function declarations are not supported'));\"\n209: \"  }\"\n210: \"\"\n211: \"  const nameCol = raw.indexOf(fn[1]);\"\n212: \"  const params = splitParams(fn[2], lineNo, raw.indexOf('(') + 1, state.diagnostics);\"\n213: \"  const symbol = makeSymbol('function', fn[1], lineNo, nameCol, {\"\n214: \"    params,\"\n215: \"    detail: `fn ${fn[1]}(${params.join(', ')})`,\"\n216: \"  });\"\n217: \"\"\n218: \"  state.symbols.push(symbol);\"\n219: \"  state.functions.set(symbol.name, symbol);\"\n220: \"  state.scopes[0].set(symbol.name, symbol);\"\n221: \"  state.currentFunction = symbol;\"\n222: \"\"\n223: \"  const scope = new Map();\"\n224: \"  for (const param of params) {\"\n225: \"    const col = raw.indexOf(param, raw.indexOf('('));\"\n226: \"    const paramSymbol = makeSymbol('parameter', param, lineNo, col, { container: symbol.name });\"\n227: \"    state.symbols.push(paramSymbol);\"\n228: \"    scope.set(param, paramSymbol);\"\n229: \"  }\"\n230: \"  state.scopes.push(scope);\"\n231: \"}\"\n232: \"\"\n233: \"function parseStatement(state, raw, trimmed, first, lineNo) {\"\n234: \"  const variable = /^let\\\\s+([A-Za-z_]\\\\w*)\\\\s*=\\\\s*(.*)$/.exec(trimmed);\"\n235: \"  if (variable) return addVariable(state, raw, lineNo, variable);\"\n236: \"\"\n237: \"  if (trimmed.startsWith('let ')) {\"\n238: \"    state.diagnostics.push(diag(lineNo, first, raw.length, 'Malformed variable declaration'));\"\n239: \"    return;\"\n240: \"  }\"\n241: \"\"\n242: \"  if (trimmed.startsWith('return')) {\"\n243: \"    const expression = trimmed.slice('return'.length).trim();\"\n244: \"    if (!state.currentFunction) {\"\n245: \"      state.diagnostics.push(diag(lineNo, first, first + 6, 'Return statement outside function'));\"\n246: \"    }\"\n247: \"    if (expression) scanExpression(expression, lineNo, raw.indexOf(expression), state);\"\n248: \"    return;\"\n249: \"  }\"\n250: \"\"\n251: \"  scanExpression(trimmed, lineNo, first, state);\"\n252: \"}\"\n253: \"\"\n254: \"function addVariable(state, raw, lineNo, variable) {\"\n255: \"  const name = variable[1];\"\n256: \"  const nameCol = raw.indexOf(name);\"\n257: \"  const symbol = makeSymbol('variable', name, lineNo, nameCol, { detail: `let ${name}` });\"\n258: \"  if (state.currentFunction) symbol.container = state.currentFunction.name;\"\n259: \"  const scope = state.scopes[state.scopes.length - 1];\"\n260: \"\"\n261: \"  state.symbols.push(symbol);\"\n262: \"  scope.set(name, symbol);\"\n263: \"  if (variable[2]) scanExpression(variable[2], lineNo, raw.indexOf(variable[2]), state);\"\n264: \"}\"\n265: \"\"\n266: \"function scanExpression(expression, line, baseCol, state) {\"\n267: \"  const callRanges = [];\"\n268: \"  const callRegex = /\\\\b([A-Za-z_]\\\\w*)\\\\s*\\\\(([^)]*)\\\\)/g;\"\n269: \"\"\n270: \"  for (const match of expression.matchAll(callRegex)) {\"\n271: \"    const name = match[1];\"\n272: \"    const start = baseCol + match.index;\"\n273: \"    const target = state.functions.get(name);\"\n274: \"    const args = splitArgs(match[2]);\"\n275: \"    const range = rangeFor(line, start, start + name.length);\"\n276: \"\"\n277: \"    state.references.push({ name, range, target, isCall: true, argsLength: args.length });\"\n278: \"    callRanges.push([match.index, match.index + name.length]);\"\n279: \"\"\n280: \"    if (!target && !BUILTINS.has(name)) {\"\n281: \"      state.diagnostics.push(diagFromRange(range, `Undefined function ${name}`));\"\n282: \"    } else if (target && args.length !== target.params.length) {\"\n283: \"      state.diagnostics.push(diagFromRange(range, arityMessage(name, target.params.length, args.length)));\"\n284: \"    }\"\n285: \"  }\"\n286: \"\"\n287: \"  const identifierRegex = /\\\\b[A-Za-z_]\\\\w*\\\\b/g;\"\n288: \"  for (const match of expression.matchAll(identifierRegex)) {\"\n289: \"    const name = match[0];\"\n290: \"    if (KEYWORDS.includes(name) || BUILTINS.has(name)) continue;\"\n291: \"    if (callRanges.some(([start, end]) => match.index >= start && match.index < end)) continue;\"\n292: \"\"\n293: \"    const start = baseCol + match.index;\"\n294: \"    const target = lookup(state.scopes, name);\"\n295: \"    const range = rangeFor(line, start, start + name.length);\"\n296: \"    state.references.push({ name, range, target });\"\n297: \"    if (!target) state.diagnostics.push(diagFromRange(range, `Undefined symbol ${name}`));\"\n298: \"  }\"\n299: \"}\"\n300: \"\"\n301: \"function reconcileForwardFunctions(state) {\"\n302: \"  for (const reference of state.references) {\"\n303: \"    if (!reference.isCall || reference.target || BUILTINS.has(reference.name)) continue;\"\n304: \"    const target = state.functions.get(reference.name);\"\n305: \"    if (!target) continue;\"\n306: \"\"\n307: \"    reference.target = target;\"\n308: \"    state.diagnostics = state.diagnostics.filter(\"\n309: \"      (item) => !(item.message === `Undefined function ${reference.name}` && sameRange(item.range, reference.range)),\"\n310: \"    );\"\n311: \"    if (reference.argsLength !== target.params.length) {\"\n312: \"      state.diagnostics.push(diagFromRange(\"\n313: \"        reference.range,\"\n314: \"        arityMessage(reference.name, target.params.length, reference.argsLength),\"\n315: \"      ));\"\n316: \"    }\"\n317: \"  }\"\n318: \"}\"\n319: \"\"\n320: \"function closeScopes(state, raw, lineNo) {\"\n321: \"  for (const char of raw) {\"\n322: \"    if (char === '{') state.braceDepth += 1;\"\n323: \"    if (char !== '}') continue;\"\n324: \"    state.braceDepth = Math.max(0, state.braceDepth - 1);\"\n325: \"    if (state.braceDepth === 0 && state.currentFunction) {\"\n326: \"      state.currentFunction.endLine = lineNo;\"\n327: \"      state.scopes.pop();\"\n328: \"      state.currentFunction = null;\"\n329: \"    }\"\n330: \"  }\"\n331: \"}\"\n332: \"\"\n333: \"function applyTextChange(text, change) {\"\n334: \"  const start = offsetAt(text, change.range.start);\"\n335: \"  const end = offsetAt(text, change.range.end);\"\n336: \"  return `${text.slice(0, start)}${change.text}${text.slice(end)}`;\"\n337: \"}\"\n338: \"\"\n339: \"function offsetAt(text, position) {\"\n340: \"  const lines = text.split(/\\\\n/);\"\n341: \"  let offset = 0;\"\n342: \"  for (let line = 0; line < Math.min(position.line, lines.length); line += 1) {\"\n343: \"    offset += lines[line].length + 1;\"\n344: \"  }\"\n345: \"  return offset + Math.min(position.character, lines[position.line]?.length ?? 0);\"\n346: \"}\"\n347: \"\"\n348: \"function wordAt(text, position) {\"\n349: \"  const line = text.split(/\\\\r?\\\\n/)[position.line] ?? '';\"\n350: \"  const regex = /\\\\b[A-Za-z_]\\\\w*\\\\b/g;\"\n351: \"  for (const match of line.matchAll(regex)) {\"\n352: \"    const start = match.index;\"\n353: \"    const end = start + match[0].length;\"\n354: \"    if (position.character >= start && position.character <= end) {\"\n355: \"      return { text: match[0], range: rangeFor(position.line, start, end) };\"\n356: \"    }\"\n357: \"  }\"\n358: \"  return null;\"\n359: \"}\"\n360: \"\"\n361: \"function visibleSymbols(symbols, position) {\"\n362: \"  const activeFunction = symbols.find((symbol) => {\"\n363: \"    if (symbol.kind !== 'function') return false;\"\n364: \"    if (symbol.range.start.line > position.line) return false;\"\n365: \"    return symbol.endLine === undefined || symbol.endLine >= position.line;\"\n366: \"  });\"\n367: \"\"\n368: \"  return symbols.filter((symbol) => {\"\n369: \"    if (symbol.kind === 'function') return true;\"\n370: \"    if (symbol.container && symbol.container !== activeFunction?.name) return false;\"\n371: \"    if (symbol.range.start.line > position.line) return false;\"\n372: \"    return symbol.range.start.line < position.line || symbol.range.start.character <= position.character;\"\n373: \"  });\"\n374: \"}\"\n375: \"\"\n376: \"function pushCompletion(items, seen, item) {\"\n377: \"  if (seen.has(item.label)) return;\"\n378: \"  seen.add(item.label);\"\n379: \"  items.push(item);\"\n380: \"}\"\n381: \"\"\n382: \"function initializeResult() {\"\n383: \"  return {\"\n384: \"    capabilities: {\"\n385: \"      textDocumentSync: 2,\"\n386: \"      completionProvider: { triggerCharacters: [''] },\"\n387: \"      definitionProvider: true,\"\n388: \"      hoverProvider: true,\"\n389: \"    },\"\n390: \"  };\"\n391: \"}\"\n392: \"\"\n393: \"function response(id, result) {\"\n394: \"  return { jsonrpc: '2.0', id, result };\"\n395: \"}\"\n396: \"\"\n397: \"function stripComment(line) {\"\n398: \"  return line.split('#')[0];\"\n399: \"}\"\n400: \"\"\n401: \"function splitParams(text, line, baseCol, diagnostics) {\"\n402: \"  const params = splitArgs(text);\"\n403: \"  for (const param of params) {\"\n404: \"    if (!/^[A-Za-z_]\\\\w*$/.test(param)) {\"\n405: \"      diagnostics.push(diag(line, baseCol, baseCol + text.length, `Invalid parameter ${param}`));\"\n406: \"    }\"\n407: \"  }\"\n408: \"  return params.filter((param) => /^[A-Za-z_]\\\\w*$/.test(param));\"\n409: \"}\"\n410: \"\"\n411: \"function splitArgs(text) {\"\n412: \"  const trimmed = text.trim();\"\n413: \"  if (!trimmed) return [];\"\n414: \"  return trimmed.split(',').map((arg) => arg.trim()).filter(Boolean);\"\n415: \"}\"\n416: \"\"\n417: \"function lookup(scopes, name) {\"\n418: \"  for (let index = scopes.length - 1; index >= 0; index -= 1) {\"\n419: \"    const found = scopes[index].get(name);\"\n420: \"    if (found) return found;\"\n421: \"  }\"\n422: \"  return null;\"\n423: \"}\"\n424: \"\"\n425: \"function makeSymbol(kind, name, line, col, extra = {}) {\"\n426: \"  return {\"\n427: \"    kind,\"\n428: \"    name,\"\n429: \"    range: rangeFor(line, col, col + name.length),\"\n430: \"    selectionRange: rangeFor(line, col, col + name.length),\"\n431: \"    ...extra,\"\n432: \"  };\"\n433: \"}\"\n434: \"\"\n435: \"function rangeFor(line, start, end) {\"\n436: \"  return {\"\n437: \"    start: { line, character: Math.max(0, start) },\"\n438: \"    end: { line, character: Math.max(0, end) },\"\n439: \"  };\"\n440: \"}\"\n441: \"\"\n442: \"function diag(line, start, end, message) {\"\n443: \"  return diagFromRange(rangeFor(line, start, end), message);\"\n444: \"}\"\n445: \"\"\n446: \"function diagFromRange(range, message) {\"\n447: \"  return { range, severity: 1, source: 'minilang', message };\"\n448: \"}\"\n449: \"\"\n450: \"function arityMessage(name, expected, actual) {\"\n451: \"  return `Function ${name} expected ${expected} argument(s), got ${actual}`;\"\n452: \"}\"\n453: \"\"\n454: \"function contains(range, position) {\"\n455: \"  if (position.line !== range.start.line) return false;\"\n456: \"  return position.character >= range.start.character && position.character <= range.end.character;\"\n457: \"}\"\n458: \"\"\n459: \"function sameRange(left, right) {\"\n460: \"  return left.start.line === right.start.line\"\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_21","type":"agent_message","text":"I found a concrete parser recovery bug: same-line function bodies like `fn f() { return missing }` do not get scanned, so hidden diagnostics/features can be skipped. I’m going to patch that path and harden full-document `didChange` handling, both dependency-free."}}
{"type":"item.started","item":{"id":"item_22","type":"command_execution","command":"/bin/zsh -lc \"node --input-type=module - <<'NODE'\nimport { parseMiniLang, MiniLangServer } from './src/server.mjs';\nconst cases = [\n ['inline missing', 'fn f() { return missing }'],\n ['inline call', 'fn g(a) { return a }\\\\nfn f() { return g() }'],\n ['full change', null]\n];\nfor (const [name,text] of cases) {\n if (\"'!text) continue;\n const p = parseMiniLang(text);\n console.log(name, p.diagnostics.map(d=>d.message));\n console.log('\"'refs', p.references.map(r=>[r.name, \"'!!r.target, r.argsLength]));\n}\nconst server = new MiniLangServer();\nconst uri='\"'file:///x.mini';\nawait server.handle({jsonrpc:'2.0',method:'textDocument/didOpen',params:{textDocument:{uri,text:'fn f(){\\\\n return ok\\\\n}',version:1}}});\nawait server.handle({jsonrpc:'2.0',method:'textDocument/didChange',params:{textDocument:{uri,version:2},contentChanges:[{text:'fn ok(){ }\\\\nfn f(){ return ok() }'}]}});\nconsole.log('after full change', server.getDiagnostics(uri).map(d=>d.message));\nNODE\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_22","type":"command_execution","command":"/bin/zsh -lc \"node --input-type=module - <<'NODE'\nimport { parseMiniLang, MiniLangServer } from './src/server.mjs';\nconst cases = [\n ['inline missing', 'fn f() { return missing }'],\n ['inline call', 'fn g(a) { return a }\\\\nfn f() { return g() }'],\n ['full change', null]\n];\nfor (const [name,text] of cases) {\n if (\"'!text) continue;\n const p = parseMiniLang(text);\n console.log(name, p.diagnostics.map(d=>d.message));\n console.log('\"'refs', p.references.map(r=>[r.name, \"'!!r.target, r.argsLength]));\n}\nconst server = new MiniLangServer();\nconst uri='\"'file:///x.mini';\nawait server.handle({jsonrpc:'2.0',method:'textDocument/didOpen',params:{textDocument:{uri,text:'fn f(){\\\\n return ok\\\\n}',version:1}}});\nawait server.handle({jsonrpc:'2.0',method:'textDocument/didChange',params:{textDocument:{uri,version:2},contentChanges:[{text:'fn ok(){ }\\\\nfn f(){ return ok() }'}]}});\nconsole.log('after full change', server.getDiagnostics(uri).map(d=>d.message));\nNODE\"","aggregated_output":"inline missing [ 'Undefined symbol missing' ]\nrefs [ [ 'missing', false, undefined ] ]\ninline call [ 'Function g expected 1 argument(s), got 0' ]\nrefs [ [ 'a', true, undefined ], [ 'g', true, 0 ] ]\nafter full change []\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_23","type":"agent_message","text":"The inline-body and full-change probes already pass, so those suspected gaps were covered by the draft. I’m moving to less visible protocol/parser edge cases now: message framing variants, malformed syntax recovery, definition/hover around declarations and forward calls, and multi-change edits."}}
