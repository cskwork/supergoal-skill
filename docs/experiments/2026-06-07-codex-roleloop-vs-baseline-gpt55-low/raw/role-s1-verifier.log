)[0];\n    return symbol ? { uri: doc.uri, range: symbol.range } : null;\n  }\n\n  hover(params) {\n    const doc = this.documents.get(params.textDocument.uri);\n    if (!doc) return null;\n    const word = wordAt(doc.text, params.position);\n    if (!word) return null;\n    const symbol = doc.parsed.symbols.find((item) => item.name === word.name);\n    if (!symbol) return null;\n    return {\n      contents: {\n        kind: 'markdown',\n        value: symbol.kind === 'function' ? `\\`${symbol.detail}\\`` : `\\`${symbol.detail}\\``,\n      },\n      range: word.range,\n    };\n  }\n\n  takeNotifications() {\n    const out = this.notifications;\n    this.notifications = [];\n    return out;\n  }\n\n  getDiagnostics(uri) {\n    return this.documents.get(uri)?.parsed.diagnostics ?? [];\n  }\n}\n\nfunction offsetAt(text, position) {\n  const lines = text.split(/\\r?\\n/);\n  let offset = 0;\n  for (let index = 0; index < position.line; index++) offset += (lines[index] ?? '').length + 1;\n  return offset + position.character;\n}\n\nfunction applyTextChange(text, change) {\n  const start = offsetAt(text, change.range.start);\n  const end = offsetAt(text, change.range.end);\n  return text.slice(0, start) + change.text + text.slice(end);\n}\n","exit_code":0,"status":"completed"}}
