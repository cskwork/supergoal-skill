x + match[0].length });\n  return names;\n}\n\nfunction parseCall(expr, baseColumn) {\n  const match = /^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*\\((.*)\\)\\s*$/.exec(expr);\n  if (!match) return null;\n  const before = expr.indexOf(match[1]);\n  const args = match[2].trim() ? match[2].split(',').map((arg) => arg.trim()).filter(Boolean) : [];\n  return { name: match[1], args, start: baseColumn + before, end: baseColumn + before + match[1].length };\n}\n\nfunction expressionUses(expr, baseColumn, scope) {\n  const call = parseCall(expr, baseColumn);\n  const names = scanNames(expr).filter((item) => !KEYWORDS.includes(item.name));\n  const scoped = (item) => ({ ...item, scope, start: item.start + baseColumn, end: item.end + baseColumn, line: null });\n  return { call: call ? { ...call, scope } : null, names: names.map(scoped) };\n}\n\nexport function parseMiniLang(text) {\n  const diagnostics = [];\n  const functions = new Map();\n  const symbols = [];\n  const references = [];\n  let current = null;\n\n  const lines = text.split(/\\r?\\n/);\n  lines.forEach((raw, lineNo) => {\n    const line = stripComment(raw);\n    const trimmed = line.trim();\n    const indent = line.length - line.trimStart().length;\n    if (!trimmed) return;\n\n    const fn = /^fn\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^)]*)\\)\\s*\\{\\s*$/.exec(trimmed);\n    if (fn) {\n      const nameStart = line.indexOf(fn[1]);\n      current = { name: fn[1], params: [], locals: new Map(), range: range(lineNo, nameStart, nameStart + fn[1].length) };\n      const params = fn[2].trim() ? fn[2].split(',').map((p) => p.trim()).filter(Boolean) : [];\n      current.params = params.map((name) => {\n        const start = line.indexOf(name, line.indexOf('('));\n        return { name, kind: 'param', range: range(lineNo, start, start + name.length), container: current.name };\n      });\n      const symbol = { name: current.name, kind: 'function', range: current.range, params, locals: current.locals };\n      functions.set(current.name, symbol);\n      symbols.push(symbol, ...current.params);\n      return;\n    }\n\n    if (trimmed === '}') {\n      if (current) functions.get(current.name).endLine = lineNo;\n      current = null;\n      return;\n    }\n\n    if (!current) {\n      diagnostics.push(diag(lineNo, indent, line.length, 'Expected function declaration'));\n      return;\n    }\n\n    const letDecl = /^let\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.+)$/.exec(trimmed);\n    if (letDecl) {\n      const nameStart = line.indexOf(letDecl[1]);\n      const symbol = { name: letDecl[1], kind: 'variable', range: range(lineNo, nameStart, nameStart + letDecl[1].length), container: current.name };\n      current.locals.set(symbol.name, symbol);\n      symbols.push(symbol);\n      const exprStart = line.indexOf(letDecl[2]);\n      const uses = expressionUses(letDecl[2], exprStart, current.name);\n      references.push(...uses.names.map((item) => ({ ...item, line: lineNo })), uses.call ? { ...uses.call, line: lineNo } : null);\n      return;\n    }\n\n    const ret = /^return(?:\\s+(.+))?$/.exec(trimmed);\n    if (ret) {\n      if (!ret[1]) diagnostics.push(diag(lineNo, indent, line.length, 'Return statement expects an expression'));\n      else {\n        const exprStart = line.indexOf(ret[1]);\n        const uses = expressionUses(ret[1], exprStart, current.name);\n        references.push(...uses.names.map((item) => ({ ...item, line: lineNo })), uses.call ? { ...uses.call, line: lineNo } : null);\n      }\n      return;\n    }\n\n    const call = parseCall(trimmed, indent);\n    if (call) {\n      references.push({ ...call, scope: current.name, line: lineNo });\n      return;\n    }\n\n    diagnostics.push(diag(lineNo, indent, line.length, 'Unrecognized statement'));\n  });\n\n  for (const ref of references.filter(Boolean)) {\n    const fn = functions.get(ref.name);\n    if (fn && ref.args && ref.args.length !== fn.params.length) {\n      diagnostics.push(diag(ref.line ?? 0, ref.start, ref.end, `Fu