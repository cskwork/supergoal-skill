ait server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, withErrors, 1) }));\n   190\t    const first = publishFrom(server);\n   191\t    assert.ok(first.diagnostics.length > 0, 'expected initial diagnostics for stale-state setup');\n   192\t\n   193\t    await server.handle(notification('textDocument/didChange', {\n   194\t      textDocument: { uri, version: 2 },\n   195\t      contentChanges: [{ text: fixed }],\n   196\t    }));\n   197\t\n   198\t    const second = publishFrom(server);\n   199\t    const fixedMessages = asText(second.diagnostics.map((d) => d.message)).toLowerCase();\n   200\t    assert.equal(second.uri, uri);\n   201\t    assert.ok(second.diagnostics.length < first.diagnostics.length);\n   202\t    assert.equal(server.getDiagnostics(uri).length, second.diagnostics.length);\n   203\t    assert.equal(server.getDiagnostics(uri).length, second.diagnostics.length);\n   204\t    assert.ok(!/missing|undefined|arity|argument/i.test(fixedMessages));\n   205\t  });\n   206\t\n   207\t  await runRule('R6 completion filters by prefix and scope and exposes signatures', async () => {\n   208\t    const server = new MiniLangServer();\n   209\t    const uri = 'file:///selftest-completion.mini';\n   210\t    const text = [\n   211\t      'fn add(a, b) {',\n   212\t      '  return a + b',\n   213\t      '}',\n   214\t      'fn main() {',\n   215\t      '  let localOnly = 1',\n   216\t      '  ad',\n   217\t      '}',\n   218\t      'fn other() {',\n   219\t      '  lo',\n   220\t      '}',\n","exit_code":0,"status":"completed"}}
