{"type":"item.started","item":{"id":"item_23","type":"command_execution","command":"/bin/zsh -lc \"cat > src/shipping.mjs <<'EOF'\nconst ZONES = {\n  A: { base: 500, perKg: 200 },\n  B: { base: 800, perKg: 350 },\n  C: { base: 1200, perKg: 500 },\n};\n\nexport function computeShipping(parcel) {\n  const {\n    weightGrams,\n    dims: { l, w, h },\n    zone,\n    declaredValueMinor = 0,\n  } = parcel;\n\n  const zoneRate = ZONES[zone] ?? ZONES.A;\n  const volumetricGrams = Math.ceil((l * w * h) / 5);\n  const billableGrams = Math.max(weightGrams, volumetricGrams);\n  const kg = Math.max(1, Math.ceil(billableGrams / 1000));\n\n  const baseAndWeight = zoneRate.base + zoneRate.perKg * kg;\n  const oversizeSurcharge = l > 100 || w > 100 || h > 100 ? 1500 : 0;\n  const insuranceSurcharge = declaredValueMinor > 10000 ? Math.ceil((declaredValueMinor * 100) / 10000) : 0;\n  const waivedBaseAndWeight = declaredValueMinor >= 50000 ? 0 : baseAndWeight;\n\n  return {\n    billableGrams,\n    totalMinor: waivedBaseAndWeight + oversizeSurcharge + insuranceSurcharge,\n  };\n}\nEOF\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
