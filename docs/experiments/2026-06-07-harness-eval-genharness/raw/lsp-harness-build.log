             end: { line: lineIndex, character: tokenMatch.index + name.length },\n            },\n            message: `Undefined symbol: ${name}`,\n            severity: 1,\n          });\n        }\n      }\n    }\n\n    if (scopeToOpen && scopeToOpen.kind === '\"'function') {\n      scopeToOpen.startLine = lineIndex;\n    }\n\n    for (let i = 0; i < lineText.length; i += 1) {\n      const char = lineText[i];\n      if (char === '{') {\n        if (scopeToOpen) {\n          scopeStack.push(scopeToOpen);\n          scopeToOpen = null;\n        } else {\n          scopeStack.push(createScope(scopes.length + 1, 'block', scopeStack.at(-1), null));\n        }\n      } else if (char === '}') {\n        const top = scopeStack.pop();\n        if (top?.startLine === null) {\n          // keep defensive, all non-global scopes have starts\n        }\n        if (top && top.kind \"'!== '\"'global') {\n          top.endLine = lineIndex;\n        }\n        if (scopeStack.length < 1) {\n          scopeStack.push(globalScope);\n        }\n      }\n    }\n\n    if (scopeStack[0].kind \"'!== '\"'global') {\n      scopeStack.unshift(globalScope);\n    }\n    lineScopes.push([...scopeStack]);\n  }\n\n  return {\n    text,\n    diagnostics,\n    scopes,\n    lineScopes,\n  };\n}\n\nfunction completionItemsFromScopes(scopesAtLine, prefix) {\n  const items = [];\n  const seen = new Set();\n  const orderedScopes = [...scopesAtLine];\n\n  for (let i = orderedScopes.length - 1; i >= 0; i -= 1) {\n    const scope = orderedScopes[i];\n    for (const [name, symbols] of scope.symbols.entries()) {\n      if (seen.has(name)) continue;\n      const symbol = symbols.at(-1);\n      if (\"'!symbol) continue;\n\n      if (!prefix && !['\"'fn', 'let', 'return'].includes(name) && \"'!['\"'f', 'l', 'r'].includes(prefix)) {\n        // keep behavior simple for no-prefix case\n      }\n\n      if (prefix && name \"'!== '\"'fn' && name \"'!== '\"'let' && \"'!name.startsWith(prefix)) {\n        continue;\n      }\n\n      seen.add(name);\n\n      if (symbol.kind === '\"'function') {\n        const signature = \"'`fn ${name}(${(symbol.params || []).join('\"', ')})\"'`;\n        items.push({\n          label: name,\n          kind: 3,\n          detail: signature,\n          insertText: `${name}(${(symbol.params || []).map((param, idx) => `'\"\\\\\"'${idx + 1}:${param}`).join('\"', ')})\"'`,\n          documentation: signature,\n        });\n      } else {\n        items.push({\n          label: name,\n          kind: 6,\n          detail: name,\n          insertText: name,\n          documentation: `variable ${name}`,\n        });\n      }\n    }\n  }\n\n  for (const keyword of ['\"'fn', 'let', 'return']) {\n    if (seen.has(keyword)) continue;\n    if (prefix && keyword \"'!== '\"'fn' && keyword \"'!== '\"'let' && \"'!keyword.startsWith(prefix)) {\n      continue;\n    }\n    seen.add(keyword);\n    items.push({\n      label: keyword,\n      kind: 14,\n      detail: keyword,\n      insertText: `${keyword} `,\n      documentation: `${keyword} keyword`,\n    });\n  }\n\n  return items;\n}\n\nexport class MiniLangServer {\n  constructor() {\n    this.documents = new Map();\n    this.notifications = [];\n  }\n\n  getDiagnostics(uri) {\n    return this.documents.get(uri)?.diagnostics || [];\n  }\n\n  takeNotifications() {\n    const all = this.notifications;\n    this.notifications = [];\n    return all;\n  }\n\n  async handle(message) {\n    const method = message?.method;\n\n    if (method === '\"'initialize') {\n      return {\n        jsonrpc: '2.0',\n        id: message.id,\n        result: {\n          capabilities: {\n            textDocumentSync: 2,\n            completionProvider: { triggerCharacters: ['.'] },\n            definitionProvider: true,\n            hoverProvider: true,\n          },\n        },\n      };\n    }\n\n    if (method === 'shutdown') {\n      return { jsonrpc: '2.0', id: message.id, result: null };\n    }\n\n    if (method === 'exit') {\n      return null;\n    }\n\n    if (method === 'textDocument/didOpen' || method === 'textDocument/didChange') {\n      const uri = message.params?.textDocument?.uri;\n      const text = message.params?.textDocument?.text\n        || message.params?.contentChanges?.[0]?.text\n        || '';\n      const parsed = parseMiniLang(text);\n      this.documents.set(uri, { ...parsed, uri, text });\n      this.notifications.push({\n        jsonrpc: '2.0',\n        method: 'textDocument/publishDiagnostics',\n        params: { uri, diagnostics: parsed.diagnostics },\n      });\n      return null;\n    }\n\n    if (method === 'textDocument/completion') {\n      const uri = message.params?.textDocument?.uri;\n      const position = message.params?.position || { line: 0, character: 0 };\n      const doc = this.documents.get(uri);\n      if (\"'!doc) {\n        return { jsonrpc: '\"'2.0', id: message.id, result: { isIncomplete: false, items: [] } };\n      }\n\n      const line = doc.text.split('\\\\n')[position.line] || '';\n      const prefix = completionPrefix(line, position.character);\n      const scopesAtLine = doc.lineScopes?.[position.line] || doc.lineScopes || [doc.scopes[0]];\n      const items = completionItemsFromScopes(scopesAtLine, prefix);\n      return { jsonrpc: '2.0', id: message.id, result: items };\n    }\n\n    if (method === 'textDocument/definition' || method === 'textDocument/hover') {\n      const uri = message.params?.textDocument?.uri;\n      const position = message.params?.position || { line: 0, character: 0 };\n      const doc = this.documents.get(uri);\n      if (\"'!doc) {\n        return method === '\"'textDocument/definition'\n          ? { jsonrpc: '2.0', id: message.id, result: null }\n          : { jsonrpc: '2.0', id: message.id, result: null };\n      }\n\n      const line = doc.text.split('\\\\n')[position.line] || '';\n      const token = tokenAtPosition(line, position.character);\n      if (\"'!token) {\n        return method === '\"'textDocument/definition'\n          ? { jsonrpc: '2.0', id: message.id, result: null }\n          : { jsonrpc: '2.0', id: message.id, result: null };\n      }\n\n      const activeScopes = doc.lineScopes?.[position.line] || [doc.scopes[0]];\n      const found = findSymbolInScopes(token.text, activeScopes);\n\n      if (method === 'textDocument/definition') {\n        if (\"'!found) {\n          return { jsonrpc: '\"'2.0', id: message.id, result: null };\n        }\n\n        return {\n          jsonrpc: '2.0',\n          id: message.id,\n          result: {\n            uri,\n            range: found.range,\n          },\n        };\n      }\n\n      let hoverSymbol = found;\n      if (\"'!hoverSymbol || hoverSymbol.kind !== '\"'function') {\n        hoverSymbol = findSymbolInScopes(token.text, doc.scopes, 'function');\n      }\n\n      if (\"'!hoverSymbol) {\n        return { jsonrpc: '\"'2.0', id: message.id, result: null };\n      }\n\n      if (hoverSymbol.kind === 'function') {\n        const signature = \"'`fn ${hoverSymbol.name}(${(hoverSymbol.params || []).join('\"', ')})\"'`;\n        return {\n          jsonrpc: '\"'2.0',\n          id: message.id,\n          result: {\n            contents: {\n              kind: 'markdown',\n              value: signature,\n            },\n          },\n        };\n      }\n\n      return {\n        jsonrpc: '2.0',\n        id: message.id,\n        result: {\n          contents: {\n            kind: 'markdown',\n            value: \"'`${hoverSymbol.name}`,\n          },\n        },\n      };\n    }\n\n    return null;\n  }\n}\nEOF'","aggregated_output":"","exit_code":0,"status":"completed"}}
