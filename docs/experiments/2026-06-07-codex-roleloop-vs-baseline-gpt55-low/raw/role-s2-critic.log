{"type":"item.completed","item":{"id":"item_32","type":"command_execution","command":"/bin/zsh -lc \"nl -ba test/spec.gen.test.mjs | sed -n '1,220p'\"","aggregated_output":"     1\timport assert from 'node:assert/strict';\n     2\timport test from 'node:test';\n     3\timport { MiniLangServer, parseMiniLang } from '../src/server.mjs';\n     4\t\n     5\tfunction request(method, params = {}, id = 1) {\n     6\t  return { jsonrpc: '2.0', id, method, params };\n     7\t}\n     8\t\n     9\tfunction notification(method, params = {}) {\n    10\t  return { jsonrpc: '2.0', method, params };\n    11\t}\n    12\t\n    13\tfunction textDocument(uri, text, version = 1) {\n    14\t  return { uri, languageId: 'minilang', version, text };\n    15\t}\n    16\t\n    17\tfunction itemsFrom(response) {\n    18\t  const result = response.result;\n    19\t  return Array.isArray(result) ? result : result.items;\n    20\t}\n    21\t\n    22\tfunction positionOf(text, line, needle, offset = 0) {\n    23\t  const lines = text.split('\\n');\n    24\t  const character = lines[line].indexOf(needle);\n    25\t  assert.notEqual(character, -1, `missing ${needle} on line ${line}`);\n    26\t  return { line, character: character + offset };\n    27\t}\n    28\t\n    29\tfunction diagnosticText(diagnostics) {\n    30\t  return diagnostics.map((diag) => diag.message).join('\\n').toLowerCase();\n    31\t}\n    32\t\n    33\ttest('completion filters by typed prefix and exposes function signatures', async () => {\n    34\t  const server = new MiniLangServer();\n    35\t  const uri = 'file:///completion-prefix.mini';\n    36\t  const text = [\n    37\t    'fn add(left, right) {',\n    38\t    '  return left',\n    39\t    '}',\n    40\t    'fn adjust(value) {',\n    41\t    '  return value',\n    42\t    '}',\n    43\t    'fn main() {',\n    44\t    '  ad',\n    45\t    '}',\n    46\t  ].join('\\n');\n    47\t\n    48\t  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n    49\t  const response = await server.handle(request('textDocument/completion', {\n    50\t    textDocument: { uri },\n    51\t    position: { line: 7, character: 4 },\n    52\t  }));\n    53\t\n    54\t  const items = itemsFrom(response);\n    55\t  const labels = items.map((item) => item.label);\n    56\t  assert.deepEqual(labels.sort(), ['add', 'adjust']);\n    57\t\n    58\t  for (const item of items) {\n    59\t    const rendered = JSON.stringify(item);\n    60\t    assert.match(rendered, new RegExp(`fn ${item.label}\\\\(`));\n    61\t  }\n    62\t});\n    63\t\n    64\ttest('parser recovers from a missing brace and still reports later semantic diagnostics', () => {\n    65\t  const text = [\n    66\t    'fn broken(value) {',\n    67\t    '  let local = value',\n    68\t    'fn later() {',\n    69\t    '  missing(1)',\n    70\t    '  broken(1, 2)',\n    71\t    '}',\n    72\t  ].join('\\n');\n    73\t\n    74\t  const parsed = parseMiniLang(text);\n    75\t  const messages = diagnosticText(parsed.diagnostics);\n    76\t  assert.match(messages, /missing closing brace|closing brace/);\n    77\t  assert.match(messages, /undefined.*missing|missing.*undefined/);\n    78\t  assert.match(messages, /arity|argument|expected 1/);\n    79\t});\n    80\t\n    81\ttest('definition prefers the local binding over a same-named function', async () => {\n    82\t  const server = new MiniLangServer();\n    83\t  const uri = 'file:///definition-local-scope.mini';\n    84\t  const text = [\n    85\t    'fn value() {',\n    86\t    '  return 1',\n    87\t    '}',\n    88\t    'fn main(value) {',\n    89\t    '  let other = value',\n    90\t    '  return value',\n    91\t    '}',\n    92\t  ].join('\\n');\n    93\t\n    94\t  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n    95\t  const definition = await server.handle(request('textDocument/definition', {\n    96\t    textDocument: { uri },\n    97\t    position: positionOf(text, 5, 'value', 1),\n    98\t  }));\n    99\t\n   100\t  assert.equal(definition.result.uri, uri);\n   101\t  assert.deepEqual(definition.result.range.start, { line: 3, character: 8 });\n   102\t});\n   103\t\n   104\ttest('comments are ignored for diagnostics and completion prefixes', async () => {\n   105\t  const server = new MiniLangServer();\n   106\t  const uri = 'file:///comments.mini';\n   107\t  const text = [\n   108\t    'fn real() {',\n   109\t    '  return 1',\n   110\t    '}',\n   111\t    '# fn fake(unclosed',\n   112\t    '# missing(1)',\n   113\t    'fn main() {',\n   114\t    '  re # missing(2)',\n   115\t    '}',\n   116\t  ].join('\\n');\n   117\t\n   118\t  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n   119\t  assert.equal(server.getDiagnostics(uri).length, 0);\n   120\t\n   121\t  const response = await server.handle(request('textDocument/completion', {\n   122\t    textDocument: { uri },\n   123\t    position: { line: 6, character: 4 },\n   124\t  }));\n   125\t  const labels = itemsFrom(response).map((item) => item.label);\n   126\t  assert.deepEqual(labels, ['real']);\n   127\t});\n   128\t\n   129\ttest('didChange replaces stale diagnostics and is idempotent for the same full text', async () => {\n   130\t  const server = new MiniLangServer();\n   131\t  const uri = 'file:///change-diagnostics.mini';\n   132\t  const badText = [\n   133\t    'fn takesOne(value) {',\n   134\t    '  return value',\n   135\t    '}',\n   136\t    'fn main() {',\n   137\t    '  missing(1)',\n   138\t    '  takesOne(1, 2)',\n   139\t    '}',\n   140\t  ].join('\\n');\n   141\t  const goodText = [\n   142\t    'fn takesOne(value) {',\n   143\t    '  return value',\n   144\t    '}',\n   145\t    'fn main() {',\n   146\t    '  takesOne(1)',\n   147\t    '}',\n   148\t  ].join('\\n');\n   149\t\n   150\t  await server.handle(notification('textDocument/didOpen', { textDocument: textDocumen