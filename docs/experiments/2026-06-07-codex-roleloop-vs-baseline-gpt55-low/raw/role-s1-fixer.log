}\n   222\t    }\n   223\t\n   224\t    const identifierPattern = /\\b([A-Za-z_][A-Za-z0-9_]*)\\b/g;\n   225\t    let match;\n   226\t    while ((match = identifierPattern.exec(line)) !== null) {\n   227\t      const name = match[1];\n   228\t      const next = line.slice(match.index + name.length).trimStart()[0];\n   229\t      if (KEYWORDS.includes(name) || functions.has(name) || knownVariables.has(name) || next === '(') continue;\n   230\t      diagnostics.push(diagnostic(lineNo, match.index, match.index + name.length, `Undefined variable '${name}'`));\n   231\t    }\n   232\t  }\n   233\t\n   234\t  return { text, diagnostics, symbols };\n   235\t}\n   236\t\n   237\texport class MiniLangServer {\n   238\t  constructor() {\n   239\t    this.documents = new Map();\n   240\t    this.notifications = [];\n   241\t    this.shutdownRequested = false;\n   242\t  }\n   243\t\n   244\t  async handle(message) {\n   245\t    if (message.method === 'initialize') return this.response(message.id, this.initializeResult());\n   246\t    if (message.method === 'shutdown') {\n   247\t      this.shutdownRequested = true;\n   248\t      return this.response(message.id, null);\n   249\t    }\n   250\t    if (message.method === 'exit') return null;\n   251\t    if (message.method === 'textDocument/didOpen') return this.didOpen(message.params);\n   252\t    if (message.method === 'textDocument/didChange') return this.didChange(message.params);\n   253\t    if (message.method === 'textDocument/completion') return this.response(message.id, this.completionItems());\n   254\t    if (message.method === 'textDocument/definition') return this.response(message.id, this.definition(message.params));\n   255\t    if (message.method === 'textDocument/hover') return this.response(message.id, this.hover(message.params));\n   256\t    if (message.id !== undefined) return this.response(message.id, null);\n   257\t    return null;\n   258\t  }\n   259\t\n   260\t  response(id, result) {\n   261\t    return { jsonrpc: '2.0', id, result };\n   262\t  }\n   263\t\n   264\t  initializeResult() {\n   265\t    return {\n   266\t      capabilities: {\n   267\t        textDocumentSync: 2,\n   268\t        completionProvider: { triggerCharacters: ['(', ','] },\n   269\t        definitionProvider: true,\n   270\t        hoverProvider: true,\n   271\t      },\n   272\t    };\n   273\t  }\n   274\t\n   275\t  didOpen(params) {\n   276\t    const doc = params.textDocument;\n   277\t    this.updateDocument(doc.uri, doc.text, doc.version);\n   278\t    return null;\n   279\t  }\n   280\t\n   281\t  didChange(params) {\n   282\t    const uri = params.textDocument.uri;\n   283\t    const existing = this.documents.get(uri);\n   284\t    let text = existing?.text ?? '';\n   285\t\n   286\t    for (const change of params.contentChanges ?? []) {\n   287\t      if (!change.range) {\n   288\t        text = change.text;\n   289\t      } else {\n   290\t        text = applyTextChange(text, change);\n   291\t      }\n   292\t    }\n   293\t\n   294\t    this.updateDocument(uri, text, params.textDocument.version);\n   295\t    return null;\n   296\t  }\n   297\t\n   298\t  updateDocument(uri, text, version) {\n   299\t    const parsed = parseMiniLang(text);\n   300\t    this.documents.set(uri, { uri, version, text, parsed });\n   301\t    this.notifications.push({\n   302\t      jsonrpc: '2.0',\n   303\t      method: 'textDocument/publishDiagnostics',\n   304\t      params: { uri, diagnostics: parsed.diagnostics },\n   305\t    });\n   306\t  }\n   307\t\n   308\t  completionItems() {\n   309\t    const symbols = [...this.documents.values()].flatMap((doc) => doc.parsed.symbols);\n   310\t    return {\n   311\t      isIncomplete: false,\n   312\t      items: [\n   313\t        ...KEYWORDS.map((label) => ({ label, kind: 14 })),\n   314\t        ...symbols.map((symbol) => ({\n   315\t          label: symbol.name,\n   316\t          kind: symbol.kind === 'function' ? 3 : 6,\n   317\t          detail: symbol.detail,\n   318\t        })),\n   319\t      ],\n   320\t    };\n   321\t  }\n   322\t\n   323\t  definition(params) {\n   324\t    const doc = this.documents.get(params.textDocument.uri);\n   325\t    if (!doc) return null;\n   326\t    const word = wordAt(doc.text, params.position);\n   327\t    if (!word) return null;\n   328\t    const symbol = doc.parsed.symbols.find((item) => item.name === word.name);\n   329\t    return symbol ? { uri: doc.uri, range: symbol.range } : null;\n   330\t  }\n   331\t\n   332\t  hover(params) {\n   333\t    const doc = this.documents.get(params.textDocument.uri);\n   334\t    if (!doc) return null;\n   335\t    const word = wordAt(doc.text, params.position);\n   336\t    if (!word) return null;\n   337\t    const symbol = doc.parsed.symbols.find((item) => item.name === word.name);\n   338\t    if (!symbol) return null;\n   339\t    return {\n   340\t      contents: {\n   341\t        kind: 'markdown',\n   342\t        value: symbol.kind === 'function' ? `\\`${symbol.detail}\\`` : `\\`${symbol.detail}\\``,\n   343\t      },\n   344\t      range: word.range,\n   345\t    };\n   346\t  }\n   347\t\n   348\t  takeNotifications() {\n   349\t    const out = this.notifications;\n   350\t    this.notifications = [];\n   351\t    return out;\n   352\t  }\n   353\t\n   354\t  getDiagnostics(uri) {\n   355\t    return this.documents.get(uri)?.parsed.diagnostics ?? [];\n   356\t  }\n   357\t}\n   358\t\n   359\tfunction offsetAt(text, position) {\n   360\t  const lines = text.split(/\\r?\\n/);\n   361\t  let offset = 0;\n   362\t  for (let index = 0; index < position.line; index++) offset += (lines[index] ?? '').length + 1;\n   363\t  return offset + position.character;\n   364\t}\n   365\t\n   366\tfunction applyTextChange(text, change) {\n   367\t  const start = offsetAt(text, change.range.start);\n   368\t  const end = offsetAt(text, change.range.end);\n   369\t  return text.slice(0, start) + change.text + text.slice(end);\n   370\t}\n   371\t\n   372\texport default {\n   373\t  encodeMessage,\n   374\t  MessageBuffer,\n   375\t  parseMiniLang,\n   376\t  MiniLangServer,\n   377\t};\n","exit_code":0,"status":"completed"}}
