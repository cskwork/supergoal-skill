{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"/bin/zsh -lc 'nl -ba src/order.mjs'","aggregated_output":"     1\texport function calculateInvoice(order) {\n     2\t  let subtotal = calculateSubtotal(order.items);\n     3\t  let discount = calculateDiscount(order, subtotal);\n     4\t  let taxableAmount = subtotal - discount;\n     5\t  let tax = calculateTax(order.region, taxableAmount);\n     6\t  let shipping = calculateShipping(order, taxableAmount);\n     7\t  let total = taxableAmount + tax + shipping;\n     8\t\n     9\t  return {\n    10\t    subtotal: roundCents(subtotal),\n    11\t    discount: roundCents(discount),\n    12\t    tax: roundCents(tax),\n    13\t    shipping: roundCents(shipping),\n    14\t    total: roundCents(total),\n    15\t  };\n    16\t}\n    17\t\n    18\tfunction calculateSubtotal(items) {\n    19\t  let subtotal = 0;\n    20\t  for (let i = 0; i < items.length; i++) {\n    21\t    subtotal += items[i].price * items[i].qty;\n    22\t  }\n    23\t  return subtotal;\n    24\t}\n    25\t\n    26\tfunction calculateDiscount(order, subtotal) {\n    27\t  let discount = calculateCouponDiscount(order, subtotal);\n    28\t  if (order.vip && discount < subtotal * 0.05) {\n    29\t    discount = subtotal * 0.05;\n    30\t  }\n    31\t  return discount;\n    32\t}\n    33\t\n    34\tfunction calculateCouponDiscount(order, subtotal) {\n    35\t  if (!order.coupon) {\n    36\t    return 0;\n    37\t  }\n    38\t  if (order.coupon === 'SAVE10') {\n    39\t    return subtotal * 0.1;\n    40\t  }\n    41\t  if (order.coupon === 'SAVE20') {\n    42\t    if (subtotal >= 100) {\n    43\t      return subtotal * 0.2;\n    44\t    }\n    45\t    return subtotal * 0.1;\n    46\t  }\n    47\t  if (order.coupon === 'HALF' && order.vip) {\n    48\t    return subtotal * 0.5;\n    49\t  }\n    50\t  return 0;\n    51\t}\n    52\t\n    53\tfunction calculateTax(region, taxableAmount) {\n    54\t  if (region === 'US') {\n    55\t    return taxableAmount * 0.07;\n    56\t  }\n    57\t  if (region === 'EU') {\n    58\t    return taxableAmount * 0.2;\n    59\t  }\n    60\t  return taxableAmount * 0.1;\n    61\t}\n    62\t\n    63\tfunction calculateShipping(order, taxableAmount) {\n    64\t  let shipping = 0;\n    65\t  if (taxableAmount < 50) {\n    66\t    shipping = 7.5;\n    67\t  } else if (taxableAmount < 100) {\n    68\t    shipping = 3;\n    69\t  } else {\n    70\t    shipping = 0;\n    71\t  }\n    72\t  if (order.express) {\n    73\t    shipping += 12;\n    74\t  }\n    75\t  return shipping;\n    76\t}\n    77\t\n    78\tfunction roundCents(amount) {\n    79\t  return Math.round(amount * 100) / 100;\n    80\t}\n","exit_code":0,"status":"completed"}}
