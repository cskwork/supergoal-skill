+package etree
+
+import "testing"
+
+func TestDiffEqualityAndPatchRoundTrip(t *testing.T) {
+	var nilElement *Element
+	if !nilElement.DeepEqual(nil) || nilElement.DeepEqual(NewElement("x")) {
+		t.Fatal("nil equality is not safe")
+	}
+	base := NewDocument()
+	root := base.CreateElement("root")
+	root.CreateElement("item").SetText("old")
+	target := NewDocument()
+	tr := target.CreateElement("root")
+	tr.CreateElement("item").SetText("new")
+	tr.CreateElement("extra").SetText("x")
+	ops, err := Diff(base, target, DefaultDiffOptions())
+	if err != nil || len(ops) != 2 {
+		t.Fatalf("diff: %v %#v", err, ops)
+	}
+	copy := base.Copy()
+	if err := ApplyPatch(copy, GeneratePatch(ops)); err != nil {
+		t.Fatal(err)
+	}
+	if !ElementsDeepEqual(copy.Root(), target.Root()) {
+		t.Fatalf("patched tree differs: %s", mustString(copy))
+	}
+}
+
+func TestPatchAttributesReverseSummaryAndMergeMetadata(t *testing.T) {
+	base := NewDocument()
+	b := base.CreateElement("root")
+	b.CreateAttr("a", "1")
+	target := base.Copy()
+	target.Root().CreateAttr("a", "2")
+	target.Root().CreateAttr("b", "3")
+	ops, err := Diff(base, target, DefaultDiffOptions())
+	if err != nil {
+		t.Fatal(err)
+	}
+	s := NewDiffSummary(ops)
+	if s.Modifications() != 2 || s.Additions() != 0 || !s.HasChanges() {
+		t.Fatalf("summary: %s", s)
+	}
+	patch := GeneratePatch(ops)
+	if _, err := ReversePatch(patch); err != nil {
+		t.Fatal(err)
+	}
+	merged, conflicts, err := Merge3Way(base, target, base.Copy(), DefaultMergeOptions())
+	if err != nil || len(conflicts) != 0 {
+		t.Fatalf("merge: %v %#v", err, conflicts)
+	}
+	if merged.Metadata["merge.base"] != "root" || merged.Metadata["merge.ours"] != "root" || merged.Metadata["merge.theirs"] != "root" {
+		t.Fatalf("metadata: %#v", merged.Metadata)
+	}
+}
+
+func TestDiffHandlesRootAddAndAttributeRemoval(t *testing.T) {
+	empty := NewDocument()
+	target := NewDocument()
+	target.CreateElement("root").CreateAttr("gone", "value")
+	ops, err := Diff(empty, target, DefaultDiffOptions())
+	if err != nil {
+		t.Fatal(err)
+	}
+	patched := empty.Copy()
+	if err := ApplyPatch(patched, GeneratePatch(ops)); err != nil {
+		t.Fatal(err)
+	}
+	if !ElementsDeepEqual(patched.Root(), target.Root()) {
+		t.Fatalf("root add failed: %s", mustString(patched))
+	}
+
+	base := NewDocument()
+	base.CreateElement("root").CreateAttr("gone", "value")
+	without := NewDocument()
+	without.CreateElement("root")
+	ops, err = Diff(base, without, DefaultDiffOptions())
+	if err != nil {
+		t.Fatal(err)
+	}
+	patched = base.Copy()
+	if err := ApplyPatch(patched, GeneratePatch(ops)); err != nil {
+		t.Fatal(err)
+	}
+	if !ElementsDeepEqual(patched.Root(), without.Root()) {
+		t.Fatalf("attribute removal failed: %s", mustString(patched))
+	}
+}
+
+func TestDiffIdentityContentHashAndIgnoreOrder(t *testing.T) {
+	base := NewDocument()
+	br := base.CreateElement("root")
+	br.CreateElement("a").SetText("one")
+	br.CreateElement("b").SetText("two")
+	target := NewDocument()
+	tr := target.CreateElement("root")
+	tr.CreateElement("b").SetText("two")
+	tr.CreateElement("a").SetText("one")
+
+	opts := DefaultDiffOptions()
+	opts.IgnoreOrder = true
+	ops, err := Diff(base, target, opts)
+	if err != nil || len(ops) != 0 {
+		t.Fatalf("ignore order: %v %#v", err, ops)
+	}
+	opts.IgnoreOrder = false
+	opts.IdentityMode = IdentityContentHash
+	ops, err = Diff(base, target, opts)
+	if err != nil || len(ops) != 0 {
+		t.Fatalf("content hash reorder: %v %#v", err, ops)
+	}
+}
+
+func TestDiffPositionReplaceUsesBasePath(t *testing.T) {
+	base := NewDocument()
+	base.CreateElement("root").CreateElement("old").SetText("before")
+	target := NewDocument()
+	target.CreateElement("root").CreateElement("new").SetText("after")
+
+	ops, err := Diff(base, target, DefaultDiffOptions())
+	if err != nil || len(ops) != 1 || ops[0].Type != OpReplace || ops[0].Path != "/root/old[1]" {
+		t.Fatalf("position replacement: %v %#v", err, ops)
+	}
+	patched := base.Copy()
+	if err := ApplyPatch(patched, GeneratePatch(ops)); err != nil {
+		t.Fatal(err)
+	}
+	if !ElementsDeepEqual(patched.Root(), target.Root()) {
+		t.Fatalf("patched tree differs: %s", mustString(patched))
+	}
+}
+
+func TestReversePatchRestoresRemovedElement(t *testing.T) {
+	base := NewDocument()
+	base.CreateElement("root").CreateElement("item").SetText("gone")
+	target := NewDocument()
+	target.CreateElement("root")
+
+	ops, err := Diff(base, target, DefaultDiffOptions())
+	if err != nil || len(ops) != 1 || ops[0].Type != OpRemove {
+		t.Fatalf("removal diff: %v %#v", err, ops)
+	}
+	patch := GeneratePatch(ops)
+	reverse, err := ReversePatch(patch)
+	if err != nil {
+		t.Fatal(err)
+	}
+	restored := target.Copy()
+	if err := ApplyPatch(restored, reverse); err != nil {
+		t.Fatal(err)
+	}
+	if !ElementsDeepEqual(restored.Root(), base.Root()) {
+		t.Fatalf("reverse patch differs: %s", mustString(restored))
+	}
+}
+
+func TestReversePatchRestoresRemovedAttribute(t *testing.T) {
+	base := NewDocument()
+	base.CreateElement("root").CreateAttr("gone", "value")
+	target := NewDocument()
+	target.CreateElement("root")
+	ops, err := Diff(base, target, DefaultDiffOptions())
+	if err != nil {
+		t.Fatal(err)
+	}
+	reverse, err := ReversePatch(GeneratePatch(ops))
+	if err != nil {
+		t.Fatal(err)
+	}
+	restored := target.Copy()
+	if err := ApplyPatch(restored, reverse); err != nil {
+		t.Fatal(err)
+	}
+	if !ElementsDeepEqual(restored.Root(), base.Root()) {
+		t.Fatalf("reverse attribute patch differs: %s", mustString(restored))
+	}
+}
+
+func mustString(d *Document) string { s, _ := d.WriteToString(); return s }
