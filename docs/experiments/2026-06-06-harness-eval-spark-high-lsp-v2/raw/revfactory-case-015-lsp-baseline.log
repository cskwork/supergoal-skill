  assert.deepEqual(decoded[0], message);\"\n 39 \"  assert.deepEqual(decoded[1], message);\"\n 40 \"});\"\n 41 \"\"\n 42 \"test('initialize, shutdown, and exit expose expected LSP lifecycle', async () => {\"\n 43 \"  const server = new MiniLangServer();\"\n 44 \"  const init = await server.handle(request('initialize', { capabilities: {} }, 1));\"\n 45 \"  assert.equal(init.id, 1);\"\n 46 \"  assert.equal(init.result.capabilities.textDocumentSync, 2);\"\n 47 \"  assert.ok(init.result.capabilities.completionProvider);\"\n 48 \"  assert.equal(init.result.capabilities.definitionProvider, true);\"\n 49 \"  assert.equal(init.result.capabilities.hoverProvider, true);\"\n 50 \"\"\n 51 \"  const shutdown = await server.handle(request('shutdown', {}, 2));\"\n 52 \"  assert.deepEqual(shutdown, { jsonrpc: '2.0', id: 2, result: null });\"\n 53 \"  assert.equal(await server.handle(notification('exit')), null);\"\n 54 \"});\"\n 55 \"\"\n 56 \"test('didOpen publishes diagnostics for undefined symbols and wrong arity', async () => {\"\n 57 \"  const uri = 'file:///visible-diagnostics.mini';\"\n 58 \"  const text = [\"\n 59 \"    'fn add(a, b) {',\"\n 60 \"    '  return a',\"\n 61 \"    '}',\"\n 62 \"    'fn main() {',\"\n 63 \"    '  let answer = add(1)',\"\n 64 \"    '  return missing',\"\n 65 \"    '}',\"\n 66 \"  ].join('\\\\n');\"\n 67 \"  const server = new MiniLangServer();\"\n 68 \"  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\"\n 69 \"  const publish = server.takeNotifications().find((item) => item.method === 'textDocument/publishDiagnostics');\"\n 70 \"  assert.ok(publish, 'expected publishDiagnostics notification');\"\n 71 \"  const diagnostics = publish.params.diagnostics;\"\n 72 \"  const messages = diagnostics.map((diag) => diag.message).join('\\\\n').toLowerCase();\"\n 73 \"  assert.match(messages, /undefined.*missing|missing.*undefined/);\"\n 74 \"  assert.match(messages, /arity|argument|expected 2/);\"\n 75 \"