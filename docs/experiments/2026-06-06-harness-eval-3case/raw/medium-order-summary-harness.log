diff --git a/src/summarizeOrders.mjs b/src/summarizeOrders.mjs
index 3a9841670198054c910162b707e0f43801a41ff9..a3b793daa63f68e96a0a2347b36773597e3f9002
--- a/src/summarizeOrders.mjs
+++ b/src/summarizeOrders.mjs
@@ -1,3 +1,69 @@
 export function summarizeOrders(orders) {
-  return [];
+  if (!Array.isArray(orders)) {
+    throw new TypeError('orders must be an array');
+  }
+
+  const summaries = new Map();
+
+  for (const order of orders) {
+    if (order === null || typeof order !== 'object') {
+      throw new TypeError('order must be an object');
+    }
+
+    if (order.status !== 'paid') {
+      continue;
+    }
+
+    assertValidPaidOrder(order);
+
+    const existing = summaries.get(order.currency) ?? {
+      currency: order.currency,
+      count: 0,
+      totalCents: 0,
+      firstOrderDate: order.createdAt,
+      lastOrderDate: order.createdAt,
+    };
+
+    existing.count += 1;
+    existing.totalCents += order.amountCents;
+    existing.firstOrderDate = minDate(existing.firstOrderDate, order.createdAt);
+    existing.lastOrderDate = maxDate(existing.lastOrderDate, order.createdAt);
+    summaries.set(order.currency, existing);
+  }
+
+  return [...summaries.values()].sort((a, b) => {
+    if (a.totalCents !== b.totalCents) {
+      return b.totalCents - a.totalCents;
+    }
+
+    return a.currency.localeCompare(b.currency);
+  });
+}
+
+function assertValidPaidOrder(order) {
+  if (
+    !/^[A-Z]{3}$/.test(order.currency) ||
+    !Number.isInteger(order.amountCents) ||
+    order.amountCents <= 0 ||
+    !isValidOrderDate(order.createdAt)
+  ) {
+    throw new TypeError('invalid paid order data');
+  }
+}
+
+function isValidOrderDate(value) {
+  if (typeof value !== 'string' || !/^\d{4}-\d{2}-\d{2}$/.test(value)) {
+    return false;
+  }
+
+  const date = new Date(`${value}T00:00:00.000Z`);
+  return !Number.isNaN(date.getTime()) && date.toISOString().slice(0, 10) === value;
+}
+
+function minDate(left, right) {
+  return left <= right ? left : right;
+}
+
+function maxDate(left, right) {
+  return left >= right ? left : right;
 }

