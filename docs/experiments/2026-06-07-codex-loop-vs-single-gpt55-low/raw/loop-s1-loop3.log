{"type":"item.completed","item":{"id":"item_4","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' src/server.mjs\"","aggregated_output":"const KEYWORDS = ['fn', 'let', 'return'];\n\nexport function encodeMessage(message) {\n  const body = JSON.stringify(message);\n  return `Content-Length: ${Buffer.byteLength(body, 'utf8')}\\r\\n\\r\\n${body}`;\n}\n\nexport class MessageBuffer {\n  constructor() {\n    this.buffer = Buffer.alloc(0);\n  }\n\n  push(chunk) {\n    this.buffer = Buffer.concat([this.buffer, Buffer.from(chunk)]);\n    const messages = [];\n\n    while (true) {\n      const headerEnd = this.buffer.indexOf('\\r\\n\\r\\n');\n      if (headerEnd === -1) break;\n\n      const header = this.buffer.subarray(0, headerEnd).toString('ascii');\n      const match = header.match(/(?:^|\\r\\n)Content-Length:\\s*(\\d+)\\s*(?:\\r\\n|$)/i);\n      if (!match) throw new Error('Missing Content-Length header');\n\n      const bodyStart = headerEnd + 4;\n      const bodyEnd = bodyStart + Number(match[1]);\n      if (this.buffer.length < bodyEnd) break;\n\n      const body = this.buffer.subarray(bodyStart, bodyEnd).toString('utf8');\n      messages.push(JSON.parse(body));\n      this.buffer = this.buffer.subarray(bodyEnd);\n    }\n\n    return messages;\n  }\n}\n\nfunction range(line, start, end) {\n  return {\n    start: { line, character: Math.max(0, start) },\n    end: { line, character: Math.max(0, end) },\n  };\n}\n\nfunction stripComment(line) {\n  const index = line.indexOf('#');\n  return index === -1 ? line : line.slice(0, index);\n}\n\nfunction wordAt(text, position) {\n  const lineText = text.split(/\\r?\\n/)[position.line] ?? '';\n  const character = Math.max(0, position.character ?? 0);\n  const pattern = /[A-Za-z_][A-Za-z0-9_]*/g;\n\n  for (const match of lineText.matchAll(pattern)) {\n    const start = match.index;\n    const end = start + match[0].length;\n    if (character >= start && character <= end) {\n      return { name: match[0], range: range(position.line, start, end) };\n    }\n  }\n\n  return null;\n}\n\nfunction offsetAt(text, position) {\n  const lines = text.match(/[^\\r\\n]*(?:\\r\\n|\\n|\\r|$)/g) ?? [''];\n  let offset = 0;\n  for (let line = 0; line < Math.min(position.line, lines.length); line += 1) {\n    offset += lines[line].length;\n  }\n  const current = lines[position.line] ?? '';\n  const lineEnd = current.search(/\\r|\\n|$/);\n  return offset + Math.min(Math.max(0, position.character ?? 0), lineEnd);\n}\n\nfunction applyTextChange(text, change) {\n  if (!change.range) return change.text;\n  const start = offsetAt(text, change.range.start);\n  const end = offsetAt(text, change.range.end);\n  return text.slice(0, start) + change.text + text.slice(end);\n}\n\nfunction identifiersInExpression(expr, line, offset) {\n  const refs = [];\n\n  for (const match of expr.matchAll(/[A-Za-z_][A-Za-z0-9_]*/g)) {\n    const name = match[0];\n    if (KEYWORDS.includes(name)) continue;\n\n    const end = match.index + name.length;\n    refs.push({\n      name,\n      isCall: /^\\s*\\(/.test(expr.slice(end)),\n      range: range(line, offset + match.index, offset + end),\n    });\n  }\n\n  return refs;\n}\n\nfunction splitArgs(args) {\n  const trimmed = args.trim();\n  return trimmed ? trimmed.split(',').map((arg) => arg.trim()) : [];\n}\n\nfunction diagnostic(lineRange, message) {\n  return {\n    range: lineRange,\n    severity: 1,\n    source: 'MiniLang',\n    message,\n  };\n}\n\nexport function parseMiniLang(text) {\n  const diagnostics = [];\n  const symbols = [];\n  const references = [];\n  const lines = text.split(/\\r?\\n/);\n  const scopes = [new Map()];\n  let currentFunction = null;\n\n  const declare = (symbol) => {\n    const scope = scopes[scopes.length - 1];\n    if (scope.has(symbol.name)) {\n      diagnostics.push(diagnostic(symbol.range, `Duplicate symbol '${symbol.name}'`));\n    }\n    scope.set(symbol.name, symbol);\n    symbols.push(symbol);\n    return symbol;\n  };\n\n  const resolve = (name) => {\n    for (let i = scopes.length - 1; i >= 0; i -= 1) {\n      if (scopes[i].has(name)) return scopes[i].get(name);\n    }\n    return null;\n  };\n\n  const validateExpression = (expr, line, offset) => {\n    for (const ref of identifiersInExpression(expr, line, offset)) {\n      const symbol = resolve(ref.name);\n      references.push({ ...ref, symbol });\n      if (!symbol) {\n        diagnostics.push(diagnostic(ref.range, `Undefined symbol '${ref.name}'`));\n      } else if (ref.isCall) {\n        validateCall(ref, symbol, expr, offset);\n      }\n    }\n  };\n\n  const validateCall = (ref, symbol, expr, offset) => {\n    const callText = expr.slice(ref.range.start.character - offset);\n    const call = callText.match(/^[A-Za-z_][A-Za-z0-9_]*\\s*\\(([^)]*)\\)/);\n    const actual = call ? splitArgs(call[1]).length : 0;\n    const expected = symbol.params?.length ?? 0;\n    if (symbol.kind !== 'function') {\n      diagnostics.push(diagnostic(ref.range, `'${ref.name}' is not callable`));\n    } else if (actual !== expected) {\n      diagnostics.push(diagnostic(ref.range, `Function '${ref.name}' expects ${expected} arguments but got ${actual}`));\n    }\n  };\n\n  for (let line = 0; line < lines.length; line += 1) {\n    const raw = lines[line];\n    const code = stripComment(raw);\n    const trimmed = code.trim();\n    const base = code.search(/\\S|$/);\n    if (!trimmed) continue;\n\n    if (trimmed === '}') {\n      if (currentFunction) scopes.pop();\n      else diagnostics.push(diagnostic(range(line, base, base + 1), 'Unexpected closing brace'));\n      currentFunction = null;\n      continue;\n    }\n\n    const fn = code.match(/^\\s*fn\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^)]*)\\)\\s*\\{\\s*$/);\n    if (fn) {\n      const nameStart = code.indexOf(fn[1]);\n      const params = splitArgs(fn[2]).filter(Boolean);\n      const symbol = declare({\n        name: fn[1],\n        kind: 'function',\n        params,\n        range: range(line, nameStart, nameStart + fn[1].length),\n        scope: 'global',\n      });\n      currentFunction = symbol;\n      scopes.push(new Map());\n      for (const param of params) {\n        const start = code.indexOf(param, code.indexOf('('));\n        declare({ name: param, kind: 'parameter', range: range(line, start, start + param.length), scope: symbol.name });\n      }\n      continue;\n    }\n\n    if (/^\\s*fn\\b/.test(code)) {\n      diagnostics.push(diagnostic(range(line, base, code.length), `Could not parse function declaration: ${trimmed}`));\n      continue;\n    }\n\n    const letDecl = code.match(/^\\s*let\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.+)$/);\n    if (letDecl) {\n      const nameStart = code.indexOf(letDecl[1]);\n      declare({\n        name: letDecl[1],\n        kind: 'variable',\n        range: range(line, nameStart, nameStart + letDecl[1].length),\n        scope: currentFunction?.name ?? 'global',\n      });\n      const exprStart = code.indexOf(letDecl[2]);\n      validateExpression(letDecl[2], line, exprStart);\n      continue;\n    }\n\n    if (/^\\s*let\\b/.test(code)) {\n      diagnostics.push(diagnostic(range(line, base, code.length), `Could not parse variable declaration: ${trimmed}`));\n      continue;\n    }\n\n    const ret = code.match(/^\\s*return(?:\\s+(.+))?$/);\n    if (ret) {\n      if (!currentFunction) {\n        diagnostics.push(diagnostic(range(line, base, base + 6), 'Return outside function'));\n      }\n      if (ret[1]) validateExpression(ret[1], line, code.indexOf(ret[1]));\n      continue;\n    }\n\n    validateExpression(trimmed, line, base);\n    diagnostics.push(diagnostic(range(line, base, code.length), `Could not parse statement: ${trimmed}`));\n  }\n\n  if (currentFunction) {\n    diagnostics.push(diagnostic(currentFunction.range, `Function '${currentFunction.name}' is missing closing '}'`));\n  }\n\n  return { text, diagnostics, symbols, references };\n}\n\nfunction completionItems(parsed, scope = null) {\n  const visibleSymbols = parsed.symbols.filter((symbol) => (\n    symbol.scope === 'global' || (scope && symbol.scope === scope)\n  ));\n  const symbolItems = visibleSymbols.map((symbol) => ({\n    label: symbol.name,\n    kind: symbol.kind === 'function' ? 3 : 6,\n    detail: symbol.kind === 'function' ? `fn ${symbol.name}(${symbol.params.join(', ')})` : symbol.kind,\n  }));\n\n  return [\n    { label: 'fn', kind: 14, insertText: 'fn ${1:name}(${2:params}) {\\n\\t$0\\n}', insertTextFormat: 2 },\n    { label: 'let', kind: 14 },\n    { label: 'return', kind: 14 },\n    ...symbolItems,\n  ];\n}\n\n","exit_code":0,"status":"completed"}}
