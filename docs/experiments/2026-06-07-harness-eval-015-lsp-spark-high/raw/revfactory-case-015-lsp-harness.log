{"type":"item.completed","item":{"id":"item_36","type":"command_execution","command":"/bin/zsh -lc \"cat -n src/server.mjs | sed -n '1,260p'\"","aggregated_output":"     1\tconst KEYWORDS = new Set(['fn', 'let', 'return']);\n     2\tconst GLOBAL_SCOPE = '__global__';\n     3\t\n     4\tfunction clamp(value, min, max) {\n     5\t  if (value < min) return min;\n     6\t  if (value > max) return max;\n     7\t  return value;\n     8\t}\n     9\t\n    10\texport function encodeMessage(message) {\n    11\t  const body = JSON.stringify(message);\n    12\t  const length = Buffer.byteLength(body, 'utf8');\n    13\t  return `Content-Length: ${length}\\r\\n\\r\\n${body}`;\n    14\t}\n    15\t\n    16\texport class MessageBuffer {\n    17\t  constructor() {\n    18\t    this.buffer = '';\n    19\t  }\n    20\t\n    21\t  push(chunk) {\n    22\t    this.buffer += Buffer.isBuffer(chunk) ? chunk.toString('utf8') : String(chunk);\n    23\t    const messages = [];\n    24\t\n    25\t    while (true) {\n    26\t      const headerEnd = this.buffer.indexOf('\\r\\n\\r\\n');\n    27\t      if (headerEnd === -1) break;\n    28\t\n    29\t      const header = this.buffer.slice(0, headerEnd);\n    30\t      const lengthMatch = /content-length:\\s*(\\d+)/i.exec(header);\n    31\t      if (!lengthMatch) {\n    32\t        this.buffer = this.buffer.slice(headerEnd + 4);\n    33\t        break;\n    34\t      }\n    35\t\n    36\t      const contentLength = Number(lengthMatch[1]);\n    37\t      if (!Number.isInteger(contentLength) || contentLength < 0) {\n    38\t        this.buffer = this.buffer.slice(headerEnd + 4);\n    39\t        break;\n    40\t      }\n    41\t\n    42\t      const bodyStart = headerEnd + 4;\n    43\t      const bodyEnd = bodyStart + contentLength;\n    44\t      if (this.buffer.length < bodyEnd) break;\n    45\t\n    46\t      const body = this.buffer.slice(bodyStart, bodyEnd);\n    47\t      this.buffer = this.buffer.slice(bodyEnd);\n    48\t\n    49\t      try {\n    50\t        messages.push(JSON.parse(body));\n    51\t      } catch {\n    52\t        // keep stream alive on malformed JSON\n    53\t      }\n    54\t    }\n    55\t\n    56\t    return messages;\n    57\t  }\n    58\t}\n    59\t\n    60\tfunction stripComment(line) {\n    61\t  const hash = line.indexOf('#');\n    62\t  return hash === -1 ? line : line.slice(0, hash);\n    63\t}\n    64\t\n    65\tfunction makeRange(line, start, end) {\n    66\t  return {\n    67\t    start: { line, character: clamp(start, 0, Number.MAX_SAFE_INTEGER) },\n    68\t    end: { line, character: clamp(end, 0, Number.MAX_SAFE_INTEGER) },\n    69\t  };\n    70\t}\n    71\t\n    72\tfunction makeDiagnostic(line, start, end, message) {\n    73\t  return {\n    74\t    range: makeRange(line, start, end),\n    75\t    severity: 1,\n    76\t    message,\n    77\t    source: 'MiniLang',\n    78\t  };\n    79\t}\n    80\t\n    81\tfunction parseParamList(rawText) {\n    82\t  const params = [];\n    83\t  let buffer = '';\n    84\t  let depth = 0;\n    85\t\n    86\t  for (let i = 0; i <= rawText.length; i += 1) {\n    87\t    const char = rawText[i] ?? ',';\n    88\t\n    89\t    if ((char === ',' && depth === 0) || i === rawText.length) {\n    90\t      const item = buffer.trim();\n    91\t      if (item) {\n    92\t        const match = /^([A-Za-z_][A-Za-z0-9_]*)$/.exec(item);\n    93\t        if (match) params.push(match[1]);\n    94\t      }\n    95\t      buffer = '';\n    96\t      continue;\n    97\t    }\n    98\t\n    99\t    if (char === '(') depth += 1;\n   100\t    else if (char === ')') depth = Math.max(0, depth - 1);\n   101\t\n   102\t    buffer += char;\n   103\t  }\n   104\t\n   105\t  return params;\n   106\t}\n   107\t\n   108\tfunction splitFunctionCalls(line) {\n   109\t  const out = [];\n   110\t  const callRegex = /([A-Za-z_][A-Za-z0-9_]*)\\s*\\(/g;\n   111\t  let match;\n   112\t\n   113\t  while ((match = callRegex.exec(line))) {\n   114\t    const name = match[1];\n   115\t    const openIndex = match.index + match[0].length - 1;\n   116\t    let depth = 1;\n   117\t    let idx = openIndex + 1;\n   118\t\n   119\t    while (idx < line.length && depth > 0) {\n   120\t      const char = line[idx];\n   121\t      if (char === '(') depth += 1;\n   122\t      else if (char === ')') depth -= 1;\n   123\t      idx += 1;\n   124\t    }\n   125\t\n   126\t    if (depth !== 0) {\n   127\t      idx = line.length;\n   128\t    }\n   129\t\n   130\t    const argText = line.slice(openIndex + 1, idx - 1);\n   131\t    const args = splitFunctionArguments(argText);\n   132\t    out.push({\n   133\t      name,\n   134\t      startChar: match.index,\n   135\t      endChar: idx,\n   136\t      argCount: args.length,\n   137\t    });\n   138\t  }\n   139\t\n   140\t  return out;\n   141\t}\n   142\t\n   143\tfunction splitFunctionArguments(text) {\n   144\t  const args = [];\n   145\t  let depth = 0;\n   146\t  let i = 0;\n   147\t  let current = '';\n   148\t\n   149\t  while (i <= text.length) {\n   150\t    const char = text[i] ?? ',';\n   151\t\n   152\t    if (char === '(') depth += 1;\n   153\t    else if (char === ')') depth = Math.max(0, depth - 1);\n   154\t\n   155\t    if (char === ',' && depth === 0) {\n   156\t      const value = current.trim();\n   157\t      if (value) args.push(value);\n   158\t      current = '';\n   159\t      i += 1;\n   160\t      continue;\n   161\t    }\n   162\t\n   163\t    current += char;\n   164\t    i += 1;\n   165\t  }\n   166\t\n   167\t  if (current.trim() && current.length > 1) {\n   168\t    args.push(current.trim().slice(0, -1));\n   169\t  }\n   170\t\n   171\t  return args;\n   172\t}\n   173\t\n   174\tfunction addSymbol(symbols, mapByScope, scope, symbol) {\n   175\t  symbols.push(symbol);\n   176\t  if (!mapByScope.has(scope)) {\n   177\t    mapByScope.set(scope, new Map());\n   178\t  }\n   179\t  mapByScope.get(scope).set(symbol.name, symbol);\n   180\t}\n   181\t\n   182\texport function parseMiniLang(text) {\n   183\t  const source = typeof text === 'string' ? text : '';\n   184\t  const lines = source.split('\\n');\n   185\t\n   186\t  const diagnostics = [];\n   187\t  const symbols = [];\n   188\t  const functionCallsByLine = new Map();\n   189\t  const lineScope = [];\n   190\t\n   191\t  const functionByName = new Map();\n   192\t  const variablesByScope = new Map();\n   193\t  const scopes = [];\n   194\t\n   195\t  variablesByScope.set(GLOBAL_SCOPE, new Map());\n   196\t\n   197\t  const openScopes = [];\n   198\t\n   199\t  // Pass 1: declarations + block tracking + function call extraction\n   200\t  for (let lineIndex = 0; lineIndex < lines.length; lineIndex += 1) {\n   201\t    const rawLine = stripComment(lines[lineIndex]);\n   202\t    const line = rawLine;\n   203\t\n   204\t    const fnMatch = /^\\s*fn\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\((.*?)\\)\\s*(\\{\\s*)?$/.exec(line);\n   205\t    if (fnMatch) {\n   206\t      const name = fnMatch[1];\n   207\t      const paramsText = fnMatch[2] || '';\n   208\t      const nameStart = line.indexOf(name);\n   209\t      const params = parseParamList(paramsText);\n   210\t      const fnSymbol = {\n   211\t        kind: 'function',\n   212\t        name,\n   213\t        params,\n   214\t        scope: GLOBAL_SCOPE,\n   215\t        declarationLine: lineIndex,\n   216\t        declarationChar: nameStart,\n   217\t        range: makeRange(lineIndex, nameStart, nameStart + name.length),\n   218\t      };\n   219\t      symbols.push(fnSymbol);\n   220\t      functionByName.set(name, fnSymbol);\n   221\t      addSymbol(symbols, variablesByScope, name, {\n   222\t        kind: 'function-symbol',\n   223\t        name,\n   224\t        scope: GLOBAL_SCOPE,\n   225\t        declarationLine: lineIndex,\n   226\t        declarationChar: nameStart,\n   227\t        range: makeRange(lineIndex, nameStart, nameStart + name.length),\n   228\t      });\n   229\t\n   230\t      const paramStartBase = line.indexOf('(');\n   231\t      const fnScope = {\n   232\t        name,\n   233\t        symbol: fnSymbol,\n   234\t        startLine: lineIndex,\n   235\t        endLine: lines.length - 1,\n   236\t        depth: 0,\n   237\t      };\n   238\t      openScopes.push(fnScope);\n   239\t\n   240\t      // Parameters are in-scope inside function body.\n   241\t      const globalLineStart = line.indexOf('(', paramStartBase);\n   242\t      const paramBase = line.slice(globalLineStart + 1);\n   243\t      let cursor = 0;\n   244\t      for (const param of params) {\n   245\t        const rel = paramBase.indexOf(param, cursor);\n   246\t        const abs = rel === -1 ? globalLineStart + 1 : globalLineStart + 1 + rel;\n   247\t        cursor = rel + param.length + 1;\n   248\t        const varSymbol = {\n   249\t          kind: 'variable',\n   250\t          name: param,\n   251\t          scope: name,\n   252\t          declarationLine: lineIndex,\n   253\t          declarationChar: abs,\n   254\t          range: makeRange(lineIndex, abs, abs + param.length),\n   255\t        };\n   256\t        addSymbol(symbols, variablesByScope, name, varSymbol);\n   257\t      }\n   258\t    } else if (/^\\s*fn\\b/.test(line)) {\n   259\t      diagnostics.push(makeDiagnostic(lineIndex, line.indexOf('fn'), Math.min(line.length, line.indexOf('fn') + 2), 'Invalid function declaration')); \n   260\t    }\n","exit_code":0,"status":"completed"}}
