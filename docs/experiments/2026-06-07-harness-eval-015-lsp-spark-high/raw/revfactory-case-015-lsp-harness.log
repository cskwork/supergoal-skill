tialize', { capabilities: {} }, 1));\n 45:   assert.equal(init.id, 1);\n 46:   assert.equal(init.result.capabilities.textDocumentSync, 2);\n 47:   assert.ok(init.result.capabilities.completionProvider);\n 48:   assert.equal(init.result.capabilities.definitionProvider, true);\n 49:   assert.equal(init.result.capabilities.hoverProvider, true);\n 50: \n 51:   const shutdown = await server.handle(request('shutdown', {}, 2));\n 52:   assert.deepEqual(shutdown, { jsonrpc: '2.0', id: 2, result: null });\n 53:   assert.equal(await server.handle(notification('exit')), null);\n 54: });\n 55: \n 56: test('didOpen publishes diagnostics for undefined symbols and wrong arity', async () => {\n 57:   const uri = 'file:///visible-diagnostics.mini';\n 58:   const text = [\n 59:     'fn add(a, b) {',\n 60:     '  return a',\n 61:     '}',\n 62:     'fn main() {',\n 63:     '  let answer = add(1)',\n 64:     '  return missing',\n 65:     '}',\n 66:   ].join('\\n');\n 67:   const server = new MiniLangServer();\n 68:   await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n 69:   const publish = server.takeNotifications().find((item) => item.method === 'textDocument/publishDiagnostics');\n 70:   assert.ok(publish, 'expected publishDiagnostics notification');\n 71:   const diagnostics = publish.params.diagnostics;\n 72:   const messages = diagnostics.map((diag) => diag.message).join('\\n').toLowerCase();\n 73:   assert.match(messages, /undefined.*missing|missing.*undefined/);\n 74:   assert.match(messages, /arity|argument|expected 2/);\n 75:   assert.equal(server.getDiagnostics(uri).length, diagnostics.length);\n 76: });\n 77: \n 78: test('completion includes keywords, in-scope symbols, functions, and snippets', async () => {\n 79:   const uri = 'file:///visible-completion.mini';\n 80:   const text = [\n 81:     'fn add(a, b) {',\n 82:     '  return a',\n 83:     '}',\n 84:     'fn main() {',\n 85:     '  let local = 1',\n 86:     '  return ',\n 87:     '}',\n 88:   ].join('\\n');\n 89:   const server = new MiniLangServer();\n 90:   await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n 91:   const response = await server.handle(request('textDocument/completion', {\n 92:     textDocument: { uri },\n 93:     position: { line: 5, character: 9 },\n 94:   }, 3));\n 95:   const items = itemsFrom(response);\n 96:   const labels = items.map((item) => item.label);\n 97:   assert.ok(labels.includes('fn'));\n 98:   assert.ok(labels.includes('let'));\n 99:   assert.ok(labels.includes('return'));\n100:   assert.ok(labels.includes('add'));\n101:   assert.ok(labels.includes('local'));\n102:   assert.ok(items.some((item) => item.label === 'return' && /return/.test(JSON.stringify(item))));\n103: });\n104: \n105: test('definition and hover resolve function symbols', async () => {\n106:   const uri = 'file:///visible-definition.mini';\n107:   const text = [\n108:     'fn inc(value) {',\n109:     '  return value',\n110:     '}',\n111:     'fn main() {',\n112:     '  let total = inc(1)',\n113:     '  return total',\n114:     '}',\n115:   ].join('\\n');\n116:   const server = new MiniLangServer();\n117:   await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n118:   const definition = await server.handle(request('textDocument/definition', {\n119:     textDocument: { uri },\n120:     position: positionOf(text, 4, 'inc', 1),\n121:   }, 4));\n122:   assert.equal(definition.result.uri, uri);\n123:   assert.equal(definition.result.range.start.line, 0);\n124: \n125:   const hover = await server.handle(request('textDocument/hover', {\n126:     textDocument: { uri },\n127:     position: positionOf(text, 4, 'inc', 1),\n128:   }, 5));\n129:   assert.match(JSON.stringify(hover.result.contents), /fn inc\\(value\\)/);\n130: });\n","exit_code":0,"status":"completed"}}
