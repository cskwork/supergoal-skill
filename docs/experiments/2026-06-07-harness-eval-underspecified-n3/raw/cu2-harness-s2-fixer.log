{"type":"item.completed","item":{"id":"item_31","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,180p' src/csv.mjs\"","aggregated_output":"export function parseCsvLine(line) {\n  const fields = [];\n  let field = '';\n  let inQuotes = false;\n  let atFieldStart = true;\n  let afterClosingQuote = false;\n\n  for (let index = 0; index < line.length; index += 1) {\n    const char = line[index];\n\n    if (char === '\\n' || char === '\\r') {\n      throw new Error('Invalid CSV line: embedded newline');\n    }\n\n    if (inQuotes) {\n      if (char === '\"') {\n        if (line[index + 1] === '\"') {\n          field += '\"';\n          index += 1;\n        } else {\n          inQuotes = false;\n          afterClosingQuote = true;\n        }\n      } else {\n        field += char;\n      }\n      continue;\n    }\n\n    if (char === ',') {\n      fields.push(field);\n      field = '';\n      atFieldStart = true;\n      afterClosingQuote = false;\n    } else if (afterClosingQuote) {\n      throw new Error('Invalid CSV line: character after closing quote');\n    } else if (char === '\"' && atFieldStart) {\n      inQuotes = true;\n      atFieldStart = false;\n    } else if (char === '\"') {\n      throw new Error('Invalid CSV line: quote inside unquoted field');\n    } else {\n      field += char;\n      atFieldStart = false;\n    }\n  }\n\n  if (inQuotes) {\n    throw new Error('Invalid CSV line: unterminated quote');\n  }\n\n  fields.push(field);\n  return fields;\n}\n\nexport default parseCsvLine;\n","exit_code":0,"status":"completed"}}
