{"type":"item.completed","item":{"id":"item_6","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,220p' test/cache.visible.test.mjs\"","aggregated_output":"import assert from 'node:assert/strict';\nimport { test } from 'node:test';\nimport { AsyncCache } from '../src/cache.mjs';\n\ntest('loads then caches; a second sequential get does not reload', async () => {\n  const cache = new AsyncCache();\n  let calls = 0;\n  const loader = async (k) => { calls += 1; return `v:${k}`; };\n  assert.equal(await cache.get('a', loader), 'v:a');\n  assert.equal(await cache.get('a', loader), 'v:a');\n  assert.equal(calls, 1);\n  assert.equal(cache.has('a'), true);\n});\n\ntest('clear() drops cached values', async () => {\n  const cache = new AsyncCache();\n  const loader = async (k) => `v:${k}`;\n  await cache.get('a', loader);\n  cache.clear();\n  assert.equal(cache.has('a'), false);\n});\n\ntest('distinct keys load independently', async () => {\n  const cache = new AsyncCache();\n  const loader = async (k) => `v:${k}`;\n  assert.equal(await cache.get('a', loader), 'v:a');\n  assert.equal(await cache.get('b', loader), 'v:b');\n});\n\ntest('concurrent gets for the same key share one load', async () => {\n  const cache = new AsyncCache();\n  let calls = 0;\n  let resolveLoad;\n  const loadStarted = new Promise((resolve) => {\n    resolveLoad = resolve;\n  });\n\n  const loader = async (k) => {\n    calls += 1;\n    await loadStarted;\n    return `v:${k}`;\n  };\n\n  const first = cache.get('a', loader);\n  const second = cache.get('a', loader);\n  const third = cache.get('a', loader);\n\n  assert.equal(calls, 1);\n  resolveLoad();\n  assert.deepEqual(await Promise.all([first, second, third]), ['v:a', 'v:a', 'v:a']);\n  assert.equal(calls, 1);\n});\n\ntest('rejected in-flight load is not cached and can be retried', async () => {\n  const cache = new AsyncCache();\n  let calls = 0;\n  const loader = async () => {\n    calls += 1;\n    throw new Error(`fail:${calls}`);\n  };\n\n  await assert.rejects(Promise.all([cache.get('a', loader), cache.get('a', loader)]), /fail:1/);\n  assert.equal(calls, 1);\n  assert.equal(cache.has('a'), false);\n\n  await assert.rejects(cache.get('a', loader), /fail:2/);\n  assert.equal(calls, 2);\n});\n","exit_code":0,"status":"completed"}}
