+      requirePath(operation);
+      requireFrom(operation);
+      return addValue(document, operation.path, clone(getValue(document, operation.from)));
+    case 'move': {
+      requirePath(operation);
+      requireFrom(operation);
+      const value = getValue(document, operation.from);
+      document = removeValue(document, operation.from);
+      return addValue(document, operation.path, value);
+    }
+    default:
+      throw new TypeError(`unsupported operation: ${operation.op}`);
+  }
+}
+
+function addValue(document, path, value) {
+  if (path === '') {
+    return value;
+  }
+
+  const { parent, key } = resolveParent(document, path);
+
+  if (Array.isArray(parent)) {
+    if (key === '-') {
+      parent.push(value);
+      return document;
+    }
+
+    const index = parseArrayIndex(key, true);
+    if (index > parent.length) {
+      throw new TypeError('array index out of bounds');
+    }
+    parent.splice(index, 0, value);
+    return document;
+  }
+
+  assertObject(parent);
+  parent[key] = value;
+  return document;
+}
+
+function removeValue(document, path) {
+  if (path === '') {
