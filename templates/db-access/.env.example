# Copy to .domain-agent/db/.env or set DB_ENV_FILE to another gitignored path.
# Choose one dialect: postgres, mysql, or sqlite.
DB_DIALECT=postgres

# PostgreSQL via psql
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=app_db
PGUSER=readonly_user
PGPASSWORD=replace_me

# MySQL via mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=app_db
MYSQL_USER=readonly_user
MYSQL_PWD=replace_me

# SQLite via sqlite3 -readonly
SQLITE_DB_PATH=./data/app.sqlite
