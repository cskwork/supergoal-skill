{"type":"item.completed","item":{"id":"item_7","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' src/server.mjs\"","aggregated_output":"const KEYWORDS = ['fn', 'let', 'return'];\n\nfunction utf8Length(text) {\n  return Buffer.byteLength(text, 'utf8');\n}\n\nfunction range(line, start, end = start) {\n  return {\n    start: { line, character: start },\n    end: { line, character: end },\n  };\n}\n\nfunction diagnostic(line, start, end, message) {\n  return {\n    range: range(line, start, Math.max(start + 1, end)),\n    severity: 1,\n    source: 'minilang',\n    message,\n  };\n}\n\nfunction stripComment(line) {\n  const index = line.indexOf('#');\n  return index === -1 ? line : line.slice(0, index);\n}\n\nfunction wordAt(text, position) {\n  const lines = text.split(/\\r?\\n/);\n  const line = lines[position.line] ?? '';\n  let start = Math.min(position.character, line.length);\n  let end = start;\n\n  while (start > 0 && /[A-Za-z0-9_]/.test(line[start - 1])) start--;\n  while (end < line.length && /[A-Za-z0-9_]/.test(line[end])) end++;\n\n  const name = line.slice(start, end);\n  return name ? { name, range: range(position.line, start, end) } : null;\n}\n\nfunction splitArguments(source) {\n  const args = [];\n  let current = '';\n  let depth = 0;\n\n  for (const char of source) {\n    if (char === '(') depth++;\n    if (char === ')') depth = Math.max(0, depth - 1);\n    if (char === ',' && depth === 0) {\n      args.push(current.trim());\n      current = '';\n    } else {\n      current += char;\n    }\n  }\n\n  const tail = current.trim();\n  if (tail || source.trim()) args.push(tail);\n  return args.filter(Boolean);\n}\n\nfunction findCalls(expression) {\n  const calls = [];\n  const pattern = /\\b([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^()]*)\\)/g;\n  let match;\n\n  while ((match = pattern.exec(expression)) !== null) {\n    calls.push({\n      name: match[1],\n      args: splitArguments(match[2]),\n      index: match.index,\n    });\n  }\n\n  return calls;\n}\n\nexport function encodeMessage(message) {\n  const body = JSON.stringify(message);\n  return `Content-Length: ${utf8Length(body)}\\r\\n\\r\\n${body}`;\n}\n\nexport class MessageBuffer {\n  constructor() {\n    this.buffer = Buffer.alloc(0);\n  }\n\n  push(chunk) {\n    const incoming = Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk), 'utf8');\n    this.buffer = Buffer.concat([this.buffer, incoming]);\n    const messages = [];\n\n    while (true) {\n      const headerEnd = this.buffer.indexOf('\\r\\n\\r\\n');\n      if (headerEnd === -1) return messages;\n\n      const header = this.buffer.slice(0, headerEnd).toString('utf8');\n      const match = /^Content-Length:\\s*(\\d+)$/im.exec(header);\n      if (!match) {\n        this.buffer = Buffer.alloc(0);\n        throw new Error('Missing Content-Length header');\n      }\n\n      const length = Number(match[1]);\n      const bodyStart = headerEnd + 4;\n      const bodyEnd = bodyStart + length;\n      if (this.buffer.length < bodyEnd) return messages;\n\n      const messageBody = this.buffer.slice(bodyStart, bodyEnd).toString('utf8');\n      this.buffer = this.buffer.slice(bodyEnd);\n      messages.push(JSON.parse(messageBody));\n    }\n  }\n}\n\nexport function parseMiniLang(text) {\n  const diagnostics = [];\n  const symbols = [];\n  const functions = new Map();\n  const variables = new Map();\n  const lines = text.split(/\\r?\\n/);\n  let currentFunction = null;\n  let braceDepth = 0;\n\n  for (let lineNo = 0; lineNo < lines.length; lineNo++) {\n    const raw = lines[lineNo];\n    const line = stripComment(raw);\n    const trimmed = line.trim();\n    const indent = line.search(/\\S|$/);\n\n    if (!trimmed) continue;\n\n    const fn = /^\\s*fn\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^)]*)\\)\\s*\\{?/.exec(line);\n    if (fn) {\n      const name = fn[1];\n      const nameStart = line.indexOf(name);\n      const params = fn[2].split(',').map((param) => param.trim()).filter(Boolean);\n      const symbol = {\n        kind: 'function',\n        name,\n        params,\n        range: range(lineNo, nameStart, nameStart + name.length),\n        detail: `fn ${name}(${params.join(', ')})`,\n      };\n      symbols.push(symbol);\n      functions.set(name, symbol);\n      currentFunction = { symbol, locals: new Map(params.map((param) => [param, true])) };\n      braceDepth += (line.match(/\\{/g) ?? []).length - (line.match(/\\}/g) ?? []).length;\n      if (!line.includes('{')) {\n        diagnostics.push(diagnostic(lineNo, line.length, line.length + 1, `Function '${name}' is missing opening brace`));\n      }\n      continue;\n    }\n\n    if (/^\\s*fn\\b/.test(line)) {\n      diagnostics.push(diagnostic(lineNo, indent, line.length, 'Malformed function declaration'));\n      continue;\n    }\n\n    const variable = /^\\s*let\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.+)$/.exec(line);\n    if (variable) {\n      const name = variable[1];\n      const nameStart = line.indexOf(name);\n      const symbol = {\n        kind: 'variable',\n        name,\n        range: range(lineNo, nameStart, nameStart + name.length),\n        detail: `let ${name}`,\n      };\n      symbols.push(symbol);\n      variables.set(name, symbol);\n      currentFunction?.locals.set(name, true);\n      continue;\n    }\n\n    if (/^\\s*let\\b/.test(line)) {\n      diagnostics.push(diagnostic(lineNo, indent, line.length, 'Malformed variable declaration'));\n      continue;\n    }\n\n    if (/^\\s*return\\b/.test(line)) {\n      const expr = line.replace(/^\\s*return\\s*/, '');\n      if (!expr.trim()) {\n        diagnostics.push(diagnostic(lineNo, line.indexOf('return'), line.length, 'Return statement is missing an expression'));\n      }\n      continue;\n    }\n\n    if (/^\\s*\\}/.test(line)) {\n      braceDepth = Math.max(0, braceDepth - 1);\n      if (braceDepth === 0) currentFunction = null;\n      continue;\n    }\n\n    if (findCalls(line).length === 0) {\n      diagnostics.push(diagnostic(lineNo, indent, line.length, 'Unrecognized statement'));\n    }\n  }\n\n  const knownVariables = new Set([...variables.keys()]);\n  for (const symbol of symbols) {\n    if (symbol.kind === 'function') {\n      for (const param of symbol.params) knownVariables.add(param);\n    }\n  }\n\n  for (let lineNo = 0; lineNo < lines.length; lineNo++) {\n    const line = stripComment(lines[lineNo]);\n    for (const call of findCalls(line)) {\n      if (KEYWORDS.includes(call.name)) continue;\n      const fn = functions.get(call.name);\n      if (!fn) {\n        diagnostics.push(diagnostic(lineNo, call.index, call.index + call.name.length, `Undefined function '${call.name}'`));\n      } else if (call.args.length !== fn.params.length) {\n        diagnostics.push(diagnostic(\n          lineNo,\n          call.index,\n          call.index + call.name.length,\n          `Function '${call.name}' expected ${fn.params.length} argument(s), got ${call.args.length}`,\n        ));\n      }\n    }\n\n    const identifierPattern = /\\b([A-Za-z_][A-Za-z0-9_]*)\\b/g;\n    let match;\n    while ((match = identifierPattern.exec(line)) !== null) {\n      const name = match[1];\n      const next = line.slice(match.index + name.length).trimStart()[0];\n      if (KEYWORDS.includes(name) || functions.has(name) || knownVariables.has(name) || next === '(') continue;\n      diagnostics.push(diagnostic(lineNo, match.index, match.index + name.length, `Undefined variable '${name}'`));\n    }\n  }\n\n  return { text, diagnostics, symbols };\n}\n\nexport class MiniLangServer {\n  constructor() {\n    this.documents = new Map();\n    this.notifications = [];\n    this.shutdownRequested = false;\n  }\n\n  async handle(message) {\n    if (message.method === 'initialize') return this.response(message.id, this.initializeResult());\n    if (message.method === 'shutdown') {\n      this.shutdownRequested = true;\n      return this.response(message.id, null);\n    }\n    if (message.method === 'exit') return null;\n    if (message.method === 'textDocument/didOpen') return this.didOpen(message.params);\n    if (message.method === 'textDocument/didChange') return this.didChange(message.params);\n    if (message.method === 'textDocument/completion') return this.response(message.id, this.completionItems());\n    if (message.method === 'textDocument/definition') return this.response(message.id, this.definition(message.params));\n    if (message.method === 'textDocument/hover') return this.response(message.id, this.hover(message.params));\n    if (message.id !== undefined) return this.response(message.id, null);\n    return null;\n  }\n\n  response(id, result) {\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_6","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,220p' test/spec.gen.test.mjs\"","aggregated_output":"import assert from 'node:assert/strict';\nimport test from 'node:test';\nimport { MiniLangServer } from '../src/server.mjs';\n\nfunction request(method, params = {}, id = 1) {\n  return { jsonrpc: '2.0', id, method, params };\n}\n\nfunction notification(method, params = {}) {\n  return { jsonrpc: '2.0', method, params };\n}\n\nfunction textDocument(uri, text, version = 1) {\n  return { uri, languageId: 'minilang', version, text };\n}\n\nfunction completionItems(response) {\n  const result = response.result;\n  return Array.isArray(result) ? result : result.items;\n}\n\nfunction positionOf(text, line, needle, offset = 0) {\n  const lines = text.split('\\n');\n  const character = lines[line].indexOf(needle);\n  assert.notEqual(character, -1, `missing ${needle} on line ${line}`);\n  return { line, character: character + offset };\n}\n\ntest('completion is prefix-filtered and function items include signatures', async () => {\n  const uri = 'file:///prefix-completion.mini';\n  const text = [\n    'fn add(left, right) {',\n    '  return left',\n    '}',\n    'fn apply(value) {',\n    '  let apple = value',\n    '  ap',\n    '}',\n  ].join('\\n');\n  const server = new MiniLangServer();\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n\n  const response = await server.handle(request('textDocument/completion', {\n    textDocument: { uri },\n    position: positionOf(text, 5, 'ap', 2),\n  }));\n  const items = completionItems(response);\n  const labels = items.map((item) => item.label);\n\n  assert.deepEqual(labels.sort(), ['apple', 'apply'].sort());\n  const apply = items.find((item) => item.label === 'apply');\n  assert.match(apply?.detail ?? '', /fn apply\\(value\\)/);\n});\n\ntest('parser recovery keeps semantic diagnostics after a missing closing brace', async () => {\n  const uri = 'file:///recover-diagnostics.mini';\n  const text = [\n    'fn first() {',\n    '  let local = 1',\n    'fn second() {',\n    '  return missingValue',\n    '}',\n  ].join('\\n');\n  const server = new MiniLangServer();\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n\n  const messages = server.getDiagnostics(uri).map((diag) => diag.message).join('\\n');\n  assert.match(messages, /missing.*\\}/i);\n  assert.match(messages, /Undefined variable 'missingValue'/);\n});\n\ntest('go-to-definition prefers a local symbol over a same-named global function', async () => {\n  const uri = 'file:///local-definition.mini';\n  const text = [\n    'fn item() {',\n    '  return 1',\n    '}',\n    'fn main() {',\n    '  let item = 2',\n    '  return item',\n    '}',\n  ].join('\\n');\n  const server = new MiniLangServer();\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n\n  const response = await server.handle(request('textDocument/definition', {\n    textDocument: { uri },\n    position: positionOf(text, 5, 'item', 1),\n  }));\n\n  assert.equal(response.result.uri, uri);\n  assert.equal(response.result.range.start.line, 4);\n});\n\ntest('comments do not create symbols, calls, or diagnostics', async () => {\n  const uri = 'file:///comments.mini';\n  const text = [\n    '# fn ghost(param) {',\n    'fn main() {',\n    '  # missingCall(unknownName)',\n    '  return 1 # trailingName',\n    '}',\n  ].join('\\n');\n  const server = new MiniLangServer();\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n\n  assert.deepEqual(server.getDiagnostics(uri), []);\n\n  const response = await server.handle(request('textDocument/completion', {\n    textDocument: { uri },\n    position: { line: 3, character: 9 },\n  }));\n  const labels = completionItems(response).map((item) => item.label);\n  assert.ok(!labels.includes('ghost'));\n  assert.ok(!labels.includes('missingCall'));\n  assert.ok(!labels.includes('unknownName'));\n});\n\ntest('didChange range edits update the document and clear stale diagnostics', async () => {\n  const uri = 'file:///range-change.mini';\n  const original = [\n    'fn main() {',\n    '  return missing',\n    '}',\n  ].join('\\n');\n  const server = new MiniLangServer();\n  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, original, 1) }));\n  assert.match(server.getDiagnostics(uri).map((diag) => diag.message).join('\\n'), /missing/);\n  server.takeNotifications();\n\n  await server.handle(notification('textDocument/didChange', {\n    textDocument: { uri, version: 2 },\n    contentChanges: [{\n      range: { start: { line: 1, character: 2 }, end: { line: 1, character: 16 } },\n      text: 'let missing = 1\\n  return missing',\n    }],\n  }));\n\n  assert.deepEqual(server.getDiagnostics(uri), []);\n  const publish = server.takeNotifications().find((item) => item.method === 'textDocument/publishDiagnostics');\n  assert.deepEqual(publish?.params.diagnostics, []);\n});\n","exit_code":0,"status":"completed"}}
