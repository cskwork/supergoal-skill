{"type":"item.completed","item":{"id":"item_33","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,280p' src/server.mjs\"","aggregated_output":"const KEYWORDS = new Set(['fn', 'let', 'return']);\nconst IDENT = /[A-Za-z_][A-Za-z0-9_]*/g;\n\nfunction makeRange(start, end) {\n  return { start, end };\n}\n\nfunction pos(line, character) {\n  return { line, character };\n}\n\nfunction diagnostic(line, start, end, message, severity = 1) {\n  return { range: makeRange(pos(line, start), pos(line, end)), severity, message };\n}\n\nfunction stripComment(line) {\n  const index = line.indexOf('#');\n  return index === -1 ? line : line.slice(0, index);\n}\n\nfunction wordAt(text, position) {\n  const lines = text.split(/\\r?\\n/);\n  const line = lines[position.line] ?? '';\n  let start = Math.min(position.character, line.length);\n  while (start > 0 && /[A-Za-z0-9_]/.test(line[start - 1])) start--;\n  let end = Math.min(position.character, line.length);\n  while (end < line.length && /[A-Za-z0-9_]/.test(line[end])) end++;\n  const textValue = line.slice(start, end);\n  return textValue ? { text: textValue, range: makeRange(pos(position.line, start), pos(position.line, end)) } : null;\n}\n\nfunction parseParams(raw, line, offset, diagnostics) {\n  if (!raw.trim()) return [];\n  return raw.split(',').map((part) => part.trim()).filter(Boolean).map((name) => {\n    if (!/^[A-Za-z_][A-Za-z0-9_]*$/.test(name)) {\n      diagnostics.push(diagnostic(line, offset, offset + Math.max(name.length, 1), `Invalid parameter '${name}'`));\n    }\n    return name;\n  });\n}\n\nfunction scanExpression(expr, line, offset, scope, functions, diagnostics, references) {\n  const callPattern = /\\b([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^)]*)\\)/g;\n  for (const match of expr.matchAll(callPattern)) {\n    const name = match[1];\n    const args = match[2].trim() ? match[2].split(',').map((arg) => arg.trim()).filter(Boolean) : [];\n    const at = offset + match.index;\n    references.push({ name, kind: 'call', range: makeRange(pos(line, at), pos(line, at + name.length)) });\n    const fn = functions.get(name);\n    if (!fn && !KEYWORDS.has(name)) {\n      diagnostics.push(diagnostic(line, at, at + name.length, `Undefined function '${name}'`));\n    } else if (fn && fn.params.length !== args.length) {\n      diagnostics.push(diagnostic(line, at, at + name.length, `Function '${name}' expected ${fn.params.length} argument(s), got ${args.length}`));\n    }\n  }\n\n  IDENT.lastIndex = 0;\n  for (const match of expr.matchAll(IDENT)) {\n    const name = match[0];\n    const after = expr.slice(match.index + name.length).match(/^\\s*\\(/);\n    if (KEYWORDS.has(name) || after) continue;\n    if (/^\\d+$/.test(name) || scope.has(name) || functions.has(name)) continue;\n    const at = offset + match.index;\n    diagnostics.push(diagnostic(line, at, at + name.length, `Undefined symbol '${name}'`));\n  }\n}\n\nexport function encodeMessage(message) {\n  const body = JSON.stringify(message);\n  return `Content-Length: ${Buffer.byteLength(body, 'utf8')}\\r\\n\\r\\n${body}`;\n}\n\nexport class MessageBuffer {\n  constructor() {\n    this.buffer = Buffer.alloc(0);\n  }\n\n  push(chunk) {\n    const next = Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk), 'utf8');\n    this.buffer = Buffer.concat([this.buffer, next]);\n    const messages = [];\n\n    while (true) {\n      const headerEnd = this.buffer.indexOf('\\r\\n\\r\\n');\n      if (headerEnd === -1) break;\n      const header = this.buffer.subarray(0, headerEnd).toString('ascii');\n      const lengthMatch = header.match(/(?:^|\\r\\n)Content-Length:\\s*(\\d+)/i);\n      if (!lengthMatch) {\n        this.buffer = Buffer.alloc(0);\n        break;\n      }\n      const length = Number(lengthMatch[1]);\n      const bodyStart = headerEnd + 4;\n      if (this.buffer.length - bodyStart < length) break;\n      const body = this.buffer.subarray(bodyStart, bodyStart + length).toString('utf8');\n      messages.push(JSON.parse(body));\n      this.buffer = this.buffer.subarray(bodyStart + length);\n    }\n\n    return messages;\n  }\n}\n\nexport function parseMiniLang(text) {\n  const diagnostics = [];\n  const symbols = [];\n  const references = [];\n  const functions = new Map();\n  const lines = text.split(/\\r?\\n/);\n  let current = null;\n\n  lines.forEach((rawLine, lineNo) => {\n    const line = stripComment(rawLine);\n    const trimmed = line.trim();\n    const fnMatch = trimmed.match(/^fn\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^)]*)\\)\\s*\\{\\s*$/);\n    if (!fnMatch) return;\n    const name = fnMatch[1];\n    if (!functions.has(name)) {\n      const nameStart = line.indexOf(name);\n      functions.set(name, {\n        name,\n        kind: 'function',\n        params: fnMatch[2].trim() ? fnMatch[2].split(',').map((part) => part.trim()).filter(Boolean) : [],\n        range: makeRange(pos(lineNo, nameStart), pos(lineNo, nameStart + name.length)),\n        declared: false,\n      });\n    }\n  });\n\n  lines.forEach((rawLine, lineNo) => {\n    const line = stripComment(rawLine);\n    const trimmed = line.trim();\n    const indent = line.search(/\\S|$/);\n    if (!trimmed) return;\n\n    const fnMatch = trimmed.match(/^fn\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^)]*)\\)\\s*\\{\\s*$/);\n    if (fnMatch) {\n      const name = fnMatch[1];\n      const nameStart = line.indexOf(name);\n      const params = parseParams(fnMatch[2], lineNo, line.indexOf('(') + 1, diagnostics);\n      const symbol = functions.get(name) ?? { name, kind: 'function', params, range: makeRange(pos(lineNo, nameStart), pos(lineNo, nameStart + name.length)) };\n      if (symbol.declared) diagnostics.push(diagnostic(lineNo, nameStart, nameStart + name.length, `Duplicate function '${name}'`));\n      symbol.declared = true;\n      symbol.params = params;\n      functions.set(name, symbol);\n      symbols.push(symbol);\n      const locals = new Map();\n      for (const param of params) {\n        const paramStart = line.indexOf(param, line.indexOf('('));\n        const paramSymbol = {\n          name: param,\n          kind: 'parameter',\n          range: makeRange(pos(lineNo, paramStart), pos(lineNo, paramStart + param.length)),\n          functionName: name,\n        };\n        locals.set(param, paramSymbol);\n        symbols.push(paramSymbol);\n      }\n      current = { symbol, locals };\n      return;\n    }\n\n    if (trimmed === '}') {\n      current = null;\n      return;\n    }\n\n    if (!current) {\n      diagnostics.push(diagnostic(lineNo, indent, indent + trimmed.length, 'Expected function declaration'));\n      return;\n    }\n\n    const letMatch = trimmed.match(/^let\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.+)$/);\n    if (letMatch) {\n      const name = letMatch[1];\n      const nameStart = line.indexOf(name, indent);\n      const symbol = { name, kind: 'variable', range: makeRange(pos(lineNo, nameStart), pos(lineNo, nameStart + name.length)), functionName: current.symbol.name };\n      if (current.locals.has(name)) diagnostics.push(diagnostic(lineNo, nameStart, nameStart + name.length, `Duplicate symbol '${name}'`));\n      current.locals.set(name, symbol);\n      symbols.push(symbol);\n      const exprStart = line.indexOf('=', nameStart) + 1;\n      scanExpression(line.slice(exprStart), lineNo, exprStart, current.locals, functions, diagnostics, references);\n      return;\n    }\n\n    const returnMatch = trimmed.match(/^return(?:\\s+(.+))?$/);\n    if (returnMatch) {\n      if (!returnMatch[1]) diagnostics.push(diagnostic(lineNo, indent, indent + 6, 'Return requires an expression'));\n      else scanExpression(returnMatch[1], lineNo, line.indexOf(returnMatch[1]), current.locals, functions, diagnostics, references);\n      return;\n    }\n\n    scanExpression(trimmed, lineNo, indent, current.locals, functions, diagnostics, references);\n    if (!/\\b[A-Za-z_][A-Za-z0-9_]*\\s*\\(/.test(trimmed)) {\n      diagnostics.push(diagnostic(lineNo, indent, indent + trimmed.length, 'Expected let, return, or function call'));\n    }\n  });\n\n  return { text, diagnostics, symbols, references, functions };\n}\n\nfunction applyTextChange(text, change) {\n  if (!change.range) return change.text;\n  const lines = text.split(/\\r?\\n/);\n  const { start, end } = change.range;\n  const before = lines.slice(0, start.line);\n  const after = lines.slice(end.line + 1);\n  const startLine = lines[start.line] ?? '';\n  const endLine = lines[end.line] ?? '';\n  const replacement = `${startLine.slice(0, start.character)}${change.text}${endLine.slice(end.character)}`;\n  return [...before, ...replacement.split(/\\r?\\n/), ...after].join('\\n');\n}\n\nexport class MiniLangServer {\n  constructor() {\n    this.documents = new Map();\n    this.notifications = [];\n    this.initialized = false;\n    this.shutdownRequested = false;\n  }\n\n  async handle(message) {\n    const { method, id, params = {} } = message;\n    if (method === 'initialize') {\n      this.initialized = true;\n      return this.response(id, {\n        capabilities: {\n          textDocumentSync: 2,\n          completionProvider: { triggerCharacters: [' ', '('] },\n          definitionProvider: true,\n          hoverProvider: true,\n        },\n      });\n    }\n    if (method === 'shutdown') {\n      this.shutdownRequested = true;\n      return this.response(id, null);\n    }\n    if (method === 'exit') return null;\n    if (method === 'textDocument/didOpen') {\n      this.setDocument(params.textDocument.uri, params.textDocument.text, params.textDocument.version);\n      return null;\n    }\n    if (method === 'textDocument/didChange') {\n      const uri = params.textDocument.uri;\n      const doc = this.documents.get(uri) ?? { text: '', version: 0 };\n      const text = (params.contentChanges ?? []).reduce(applyTextChange, doc.text);\n      this.setDocument(uri, text, params.textDocument.version);\n      return null;\n    }\n    if (method === 'textDocument/completion') return this.response(id, this.completions(params.textDocument.uri));\n    if (method === 'textDocument/definition') return this.response(id, this.definition(params.textDocument.uri, params.position));\n    if (method === 'textDocument/hover') return this.response(id, this.hover(params.textDocument.uri, params.position));\n    return id === undefined ? null : this.response(id, null);\n  }\n\n  response(id, result) {\n    return { jsonrpc: '2.0', id, result };\n  }\n\n  setDocument(uri, text, version) {\n    const parsed = parseMiniLang(text);\n    this.documents.set(uri, { text, version, parsed });\n    this.notifications.push({ jsonrpc: '2.0', method: 'textDocument/publishDiagnostics', params: { uri, diagnostics: parsed.diagnostics } });\n  }\n\n  completions(uri) {\n    const doc = this.documents.get(uri);\n    const symbolItems = doc ? doc.parsed.symbols.map((symbol) => ({ label: symbol.name, kind: symbol.kind === 'function' ? 3 : 6 })) : [];\n    return { isIncomplete: false, items: [\n      { label: 'fn', kind: 14, insertText: 'fn ${1:name}(${2:params}) {\\n\\t${0}\\n}', insertTextFormat: 2 },\n      { label: 'let', kind: 14, insertText: 'let ${1:name} = ${0:expression}', insertTextFormat: 2 },\n      { label: 'return', kind: 14, insertText: 'return ${0:expression}', insertTextFormat: 2 },\n      ...symbolItems,\n    ] };\n  }\n\n  definition(uri, position) {\n    const doc = this.documents.get(uri);\n    if (!doc) return null;\n","exit_code":0,"status":"completed"}}
