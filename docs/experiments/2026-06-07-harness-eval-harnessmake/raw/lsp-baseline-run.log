{"type":"item.completed","item":{"id":"item_23","type":"command_execution","command":"/bin/zsh -lc 'nl -ba src/server.mjs'","aggregated_output":"     1\texport function encodeMessage(message) {\n     2\t  return JSON.stringify(message);\n     3\t}\n     4\t\n     5\texport class MessageBuffer {\n     6\t  constructor() {\n     7\t    this.buffer = '';\n     8\t  }\n     9\t\n    10\t  push(chunk) {\n    11\t    this.buffer += chunk;\n    12\t    return [];\n    13\t  }\n    14\t}\n    15\t\n    16\texport function parseMiniLang(text) {\n    17\t  return { text, diagnostics: [], symbols: [] };\n    18\t}\n    19\t\n    20\texport class MiniLangServer {\n    21\t  constructor() {\n    22\t    this.documents = new Map();\n    23\t    this.notifications = [];\n    24\t  }\n    25\t\n    26\t  async handle(message) {\n    27\t    if (message.method === 'initialize') {\n    28\t      return { jsonrpc: '2.0', id: message.id, result: { capabilities: {} } };\n    29\t    }\n    30\t    if (message.method === 'shutdown') {\n    31\t      return { jsonrpc: '2.0', id: message.id, result: null };\n    32\t    }\n    33\t    return null;\n    34\t  }\n    35\t\n    36\t  takeNotifications() {\n    37\t    const out = this.notifications;\n    38\t    this.notifications = [];\n    39\t    return out;\n    40\t  }\n    41\t\n    42\t  getDiagnostics(uri) {\n    43\t    return [];\n    44\t  }\n    45\t}\n","exit_code":0,"status":"completed"}}
