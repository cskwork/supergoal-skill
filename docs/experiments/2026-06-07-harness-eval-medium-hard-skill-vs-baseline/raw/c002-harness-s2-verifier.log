{"type":"item.completed","item":{"id":"item_4","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' test/spec.gen.test.mjs\"","aggregated_output":"import assert from 'node:assert/strict';\nimport test from 'node:test';\nimport { AsyncCache } from '../src/cache.mjs';\n\ntest('clear() during an in-flight load prevents that load from repopulating the cache', async () => {\n  const cache = new AsyncCache();\n  let resolveLoad;\n  const first = cache.get('a', async () => new Promise((resolve) => {\n    resolveLoad = resolve;\n  }));\n\n  assert.equal(cache.has('a'), false);\n  cache.clear();\n  resolveLoad('stale');\n  assert.equal(await first, 'stale');\n\n  assert.equal(cache.has('a'), false);\n\n  let reloads = 0;\n  assert.equal(await cache.get('a', async () => {\n    reloads += 1;\n    return 'fresh';\n  }), 'fresh');\n  assert.equal(reloads, 1);\n});\n\ntest('concurrent same-key callers use the first in-flight loader even if later callers pass different loaders', async () => {\n  const cache = new AsyncCache();\n  let resolveFirst;\n  let secondLoaderCalls = 0;\n\n  const first = cache.get('a', async () => new Promise((resolve) => {\n    resolveFirst = resolve;\n  }));\n  const second = cache.get('a', async () => {\n    secondLoaderCalls += 1;\n    return 'second';\n  });\n\n  assert.equal(secondLoaderCalls, 0);\n  resolveFirst('first');\n  assert.equal(await first, 'first');\n  assert.equal(await second, 'first');\n  assert.equal(cache.has('a'), true);\n});\n","exit_code":0,"status":"completed"}}
