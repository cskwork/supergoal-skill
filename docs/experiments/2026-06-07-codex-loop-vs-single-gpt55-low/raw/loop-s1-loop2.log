{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/bin/zsh -lc 'nl -ba test/lsp.visible.test.mjs'","aggregated_output":"     1\timport assert from 'node:assert/strict';\n     2\timport { test } from 'node:test';\n     3\timport { encodeMessage, MessageBuffer, MiniLangServer } from '../src/server.mjs';\n     4\t\n     5\tfunction request(method, params = {}, id = 1) {\n     6\t  return { jsonrpc: '2.0', id, method, params };\n     7\t}\n     8\t\n     9\tfunction notification(method, params = {}) {\n    10\t  return { jsonrpc: '2.0', method, params };\n    11\t}\n    12\t\n    13\tfunction textDocument(uri, text, version = 1) {\n    14\t  return { uri, languageId: 'minilang', version, text };\n    15\t}\n    16\t\n    17\tfunction itemsFrom(response) {\n    18\t  const result = response.result;\n    19\t  return Array.isArray(result) ? result : result.items;\n    20\t}\n    21\t\n    22\tfunction positionOf(text, line, needle, offset = 0) {\n    23\t  const lines = text.split('\\n');\n    24\t  const character = lines[line].indexOf(needle);\n    25\t  assert.notEqual(character, -1, `missing ${needle} on line ${line}`);\n    26\t  return { line, character: character + offset };\n    27\t}\n    28\t\n    29\ttest('JSON-RPC transport frames and streams Content-Length messages', () => {\n    30\t  const message = { jsonrpc: '2.0', id: 7, result: { ok: true } };\n    31\t  const framed = encodeMessage(message);\n    32\t  assert.match(framed, /^Content-Length: \\d+\\r\\n\\r\\n/);\n    33\t\n    34\t  const buffer = new MessageBuffer();\n    35\t  assert.deepEqual(buffer.push(framed.slice(0, 9)), []);\n    36\t  const decoded = buffer.push(framed.slice(9) + framed);\n    37\t  assert.equal(decoded.length, 2);\n    38\t  assert.deepEqual(decoded[0], message);\n    39\t  assert.deepEqual(decoded[1], message);\n    40\t});\n    41\t\n    42\ttest('initialize, shutdown, and exit expose expected LSP lifecycle', async () => {\n    43\t  const server = new MiniLangServer();\n    44\t  const init = await server.handle(request('initialize', { capabilities: {} }, 1));\n    45\t  assert.equal(init.id, 1);\n    46\t  assert.equal(init.result.capabilities.textDocumentSync, 2);\n    47\t  assert.ok(init.result.capabilities.completionProvider);\n    48\t  assert.equal(init.result.capabilities.definitionProvider, true);\n    49\t  assert.equal(init.result.capabilities.hoverProvider, true);\n    50\t\n    51\t  const shutdown = await server.handle(request('shutdown', {}, 2));\n    52\t  assert.deepEqual(shutdown, { jsonrpc: '2.0', id: 2, result: null });\n    53\t  assert.equal(await server.handle(notification('exit')), null);\n    54\t});\n    55\t\n    56\ttest('didOpen publishes diagnostics for undefined symbols and wrong arity', async () => {\n    57\t  const uri = 'file:///visible-diagnostics.mini';\n    58\t  const text = [\n    59\t    'fn add(a, b) {',\n    60\t    '  return a',\n    61\t    '}',\n    62\t    'fn main() {',\n    63\t    '  let answer = add(1)',\n    64\t    '  return missing',\n    65\t    '}',\n    66\t  ].join('\\n');\n    67\t  const server = new MiniLangServer();\n    68\t  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n    69\t  const publish = server.takeNotifications().find((item) => item.method === 'textDocument/publishDiagnostics');\n    70\t  assert.ok(publish, 'expected publishDiagnostics notification');\n    71\t  const diagnostics = publish.params.diagnostics;\n    72\t  const messages = diagnostics.map((diag) => diag.message).join('\\n').toLowerCase();\n    73\t  assert.match(messages, /undefined.*missing|missing.*undefined/);\n    74\t  assert.match(messages, /arity|argument|expected 2/);\n    75\t  assert.equal(server.getDiagnostics(uri).length, diagnostics.length);\n    76\t});\n    77\t\n    78\ttest('completion includes keywords, in-scope symbols, functions, and snippets', async () => {\n    79\t  const uri = 'file:///visible-completion.mini';\n    80\t  const text = [\n    81\t    'fn add(a, b) {',\n    82\t    '  return a',\n    83\t    '}',\n    84\t    'fn main() {',\n    85\t    '  let local = 1',\n    86\t    '  return ',\n    87\t    '}',\n    88\t  ].join('\\n');\n    89\t  const server = new MiniLangServer();\n    90\t  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n    91\t  const response = await server.handle(request('textDocument/completion', {\n    92\t    textDocument: { uri },\n    93\t    position: { line: 5, character: 9 },\n    94\t  }, 3));\n    95\t  const items = itemsFrom(response);\n    96\t  const labels = items.map((item) => item.label);\n    97\t  assert.ok(labels.includes('fn'));\n    98\t  assert.ok(labels.includes('let'));\n    99\t  assert.ok(labels.includes('return'));\n   100\t  assert.ok(labels.includes('add'));\n   101\t  assert.ok(labels.includes('local'));\n   102\t  assert.ok(items.some((item) => item.label === 'return' && /return/.test(JSON.stringify(item))));\n   103\t});\n   104\t\n   105\ttest('definition and hover resolve function symbols', async () => {\n   106\t  const uri = 'file:///visible-definition.mini';\n   107\t  const text = [\n   108\t    'fn inc(value) {',\n   109\t    '  return value',\n   110\t    '}',\n   111\t    'fn main() {',\n   112\t    '  let total = inc(1)',\n   113\t    '  return total',\n   114\t    '}',\n   115\t  ].join('\\n');\n   116\t  const server = new MiniLangServer();\n   117\t  await server.handle(notification('textDocument/didOpen', { textDocument: textDocument(uri, text) }));\n   118\t  const definition = await server.handle(request('textDocument/definition', {\n   119\t    textDocument: { uri },\n   120\t    position: positionOf(text, 4, 'inc', 1),\n   121\t  }, 4));\n   122\t  assert.equal(definition.result.uri, uri);\n   123\t  assert.equal(definition.result.range.start.line, 0);\n   124\t\n   125\t  const hover = await server.handle(request('textDocument/hover', {\n   126\t    textDocument: { uri },\n   127\t    position: positionOf(text, 4, 'inc', 1),\n   128\t  }, 5));\n   129\t  assert.match(JSON.stringify(hover.result.contents), /fn inc\\(value\\)/);\n   130\t});\n","exit_code":0,"status":"completed"}}
