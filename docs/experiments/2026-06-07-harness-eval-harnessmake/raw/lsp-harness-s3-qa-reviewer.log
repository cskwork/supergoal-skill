.equal(secondNotif.params.uri, uri, 'changed diagnostic uri should match');\nassert.ok(secondNotif.params.diagnostics.length <= firstNotif.params.diagnostics.length, 'didChange should clear stale diagnostics when no longer present');\nassert.deepEqual(server.getDiagnostics(uri), secondNotif.params.diagnostics, 'getDiagnostics should reflect latest parsed diagnostics');\n\nconst fresh = new MiniLangServer();\nconst init = await fresh.handle(mkReq('initialize', { processId: null, rootUri: null }, 1));\nassert.equal(init.result?.capabilities?.textDocumentSync, 2, 'initialize should return textDocumentSync 2');\nassert.ok(init.result?.capabilities?.completionProvider, 'completionProvider missing');\nassert.deepEqual(init.result?.capabilities?.definitionProvider, true, true);\nassert.deepEqual(init.result?.capabilities?.hoverProvider, true, true);\n\nawait fresh.handle(mkReq('shutdown', {}, 2));\nawait fresh.handle(mkNotif('exit', {}));\nassert.equal(fresh.exitCode, 0, 'exit after shutdown should be 0');\n\nconst fresh2 = new MiniLangServer();\nawait fresh2.handle(mkReq('initialize', {}, 3));\nawait fresh2.handle(mkNotif('exit', {}));\nassert.equal(fresh2.exitCode, 1, 'exit without shutdown should be 1');\n\nconsole.log('MANUAL CHECKS PASS');\nEOF\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
