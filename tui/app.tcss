/* Supergoal Board layout. Clean two-pane: roster left, detail right. */

Screen {
    background: $surface;
}

#agents {
    width: 42%;
    height: 1fr;
    border-right: tall $primary 30%;
}

#detail {
    width: 1fr;
    height: 1fr;
}

#stages {
    height: 3;
    padding: 1 0;
    content-align: left middle;
    border-bottom: tall $primary 30%;
}

#board {
    height: 1fr;
    border-bottom: tall $primary 30%;
}

#events {
    height: 38%;
    min-height: 6;
    padding: 0 1;
}

DataTable > .datatable--cursor {
    background: $accent 40%;
}
