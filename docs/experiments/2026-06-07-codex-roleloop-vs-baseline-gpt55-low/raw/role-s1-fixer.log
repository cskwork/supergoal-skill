  }\n    56\t\n    57\t  const tail = current.trim();\n    58\t  if (tail || source.trim()) args.push(tail);\n    59\t  return args.filter(Boolean);\n    60\t}\n    61\t\n    62\tfunction findCalls(expression) {\n    63\t  const calls = [];\n    64\t  const pattern = /\\b([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^()]*)\\)/g;\n    65\t  let match;\n    66\t\n    67\t  while ((match = pattern.exec(expression)) !== null) {\n    68\t    calls.push({\n    69\t      name: match[1],\n    70\t      args: splitArguments(match[2]),\n    71\t      index: match.index,\n    72\t    });\n    73\t  }\n    74\t\n    75\t  return calls;\n    76\t}\n    77\t\n    78\texport function encodeMessage(message) {\n    79\t  const body = JSON.stringify(message);\n    80\t  return `Content-Length: ${utf8Length(body)}\\r\\n\\r\\n${body}`;\n    81\t}\n    82\t\n    83\texport class MessageBuffer {\n    84\t  constructor() {\n    85\t    this.buffer = Buffer.alloc(0);\n    86\t  }\n    87\t\n    88\t  push(chunk) {\n    89\t    const incoming = Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk), 'utf8');\n    90\t    this.buffer = Buffer.concat([this.buffer, incoming]);\n    91\t    const messages = [];\n    92\t\n    93\t    while (true) {\n    94\t      const headerEnd = this.buffer.indexOf('\\r\\n\\r\\n');\n    95\t      if (headerEnd === -1) return messages;\n    96\t\n    97\t      const header = this.buffer.slice(0, headerEnd).toString('utf8');\n    98\t      const match = /^Content-Length:\\s*(\\d+)$/im.exec(header);\n    99\t      if (!match) {\n   100\t        this.buffer = Buffer.alloc(0);\n   101\t        throw new Error('Missing Content-Length header');\n   102\t      }\n   103\t\n   104\t      const length = Number(match[1]);\n   105\t      const bodyStart = headerEnd + 4;\n   106\t      const bodyEnd = bodyStart + length;\n   107\t      if (this.buffer.length < bodyEnd) return messages;\n   108\t\n   109\t      const messageBody = this.buffer.slice(bodyStart, bodyEnd).toString('utf8');\n   110\t      this.buffer = this.buffer.slice(bodyEnd);\n   111\t      messages.push(JSON.parse(messageBody));\n   112\t    }\n   113\t  }\n   114\t}\n   115\t\n   116\texport function parseMiniLang(text) {\n   117\t  const diagnostics = [];\n   118\t  const symbols = [];\n   119\t  const functions = new Map();\n   120\t  const variables = new Map();\n   121\t  const lines = text.split(/\\r?\\n/);\n   122\t  let currentFunction = null;\n   123\t  let braceDepth = 0;\n   124\t\n   125\t  for (let lineNo = 0; lineNo < lines.length; lineNo++) {\n   126\t    const raw = lines[lineNo];\n   127\t    const line = stripComment(raw);\n   128\t    const trimmed = line.trim();\n   129\t    const indent = line.search(/\\S|$/);\n   130\t\n   131\t    if (!trimmed) continue;\n   132\t\n   133\t    const fn = /^\\s*fn\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^)]*)\\)\\s*\\{?/.exec(line);\n   134\t    if (fn) {\n   135\t      const name = fn[1];\n   136\t      const nameStart = line.indexOf(name);\n   137\t      const params = fn[2].split(',').map((param) => param.trim()).filter(Boolean);\n   138\t      const symbol = {\n   139\t        kind: 'function',\n   140\t        name,\n   141\t        params,\n   142\t        range: range(lineNo, nameStart, nameStart + name.length),\n   143\t        detail: `fn ${name}(${params.join(', ')})`,\n   144\t      };\n   145\t      symbols.push(symbol);\n   146\t      functions.set(name, symbol);\n   147\t      currentFunction = { symbol, locals: new Map(params.map((param) => [param, true])) };\n   148\t      braceDepth += (line.match(/\\{/g) ?? []).length - (line.match(/\\}/g) ?? []).length;\n   149\t      if (!line.includes('{')) {\n   150\t        diagnostics.push(diagnostic(lineNo, line.length, line.length + 1, `Function '${name}' is missing opening brace`));\n   151\t      }\n   152\t      continue;\n   153\t    }\n   154\t\n   155\t    if (/^\\s*fn\\b/.test(line)) {\n   156\t      diagnostics.push(diagnostic(lineNo, indent, line.length, 'M