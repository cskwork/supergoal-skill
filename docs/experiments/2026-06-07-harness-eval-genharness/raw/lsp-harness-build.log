ing' && typeof value.value === 'undefined') return JSON.stringify(value);\n    51\t  }\n    52\t  return JSON.stringify(value);\n    53\t};\n    54\t\n    55\tasync function runRule(name, fn) {\n    56\t  try {\n    57\t    await fn();\n    58\t    console.log(`PASS ${name}`);\n    59\t  } catch (err) {\n    60\t    console.error(`FAIL ${name}: ${err.message}`);\n    61\t    throw err;\n    62\t  }\n    63\t}\n    64\t\n    65\t(async () => {\n    66\t  await runRule('R1 transport framing', async () => {\n    67\t    const message = { jsonrpc: '2.0', id: 7, result: { ok: true } };\n    68\t    const framed = encodeMessage(message);\n    69\t    const body = JSON.stringify(message);\n    70\t\n    71\t    assert.match(framed, /^Content-Length: \\d+\\r\\n\\r\\n/);\n    72\t    const headerEnd = framed.indexOf('\\r\\n\\r\\n');\n    73\t    assert.ok(headerEnd >= 0, 'missing CRLF separator');\n    74\t    const header = framed.slice(0, headerEnd);\n    75\t    const lengthMatch = header.match(/Content-Length:\\s*(\\d+)/);\n    76\t    assert.ok(lengthMatch, 'missing Content-Length header value');\n    77\t    assert.equal(Number(lengthMatch[1]), body.length);\n    78\t    assert.equal(framed.slice(headerEnd + 4), body);\n    79\t\n    80\t    const buffer = new MessageBuffer();\n    81\t    assert.deepEqual(buffer.push(framed.slice(0, 10)), []);\n    82\t    const firstRound = buffer.push(framed.slice(10));\n    83\t    assert.equal(firstRound.length, 1);\n    84\t    assert.deepEqual(firstRound[0], message);\n    85\t\n    86\t    const secondMessage = { jsonrpc: '2.0', id: 8, result: { ok: false } };\n    87\t    const batch = framed + encodeMessage(secondMessage);\n    88\t    const splitter = Math.floor(batch.length / 2);\n    89\t\n    90\t    const batchBuffer = new MessageBuffer();\n    91\t    const head = batchBuffer.push(batch.slice(0, splitter));\n    92\t    const tail = batchBuffer.push(batch.slice(splitter));\n    93\t    const all = [...head, ...tail];\n 