\nfunction makeRange(lineText, line, start, name) {\n  return {\n    start: { line, character: start },\n    end: { line, character: start + name.length },\n  };\n}\n\nfunction makeDiagnostic(lineText, line, match, message) {\n  return {\n    message,\n    severity: 1,\n    range: {\n      start: { line, character: match.index },\n      end: { line, character: match.index + match[0].length },\n    },\n    source: lineText,\n  };\n}\n\nfunction symbolKey(line, from, to) {\n  return `${line}:${from}-${to}`;\n}\n\nfunction countCallArgs(lineText, openParenIndex) {\n  if (lineText[openParenIndex] !== '(') {\n    return { count: null, closeIndex: openParenIndex };\n  }\n\n  let count = 0;\n  let nested = 0;\n  let closeIndex = -1;\n  let i = openParenIndex + 1;\n\n  // Empty argument list.\n  while (i < lineText.length && /\\s/.test(lineText[i])) {\n    i += 1;\n  }\n\n  if (lineText[i] === ')') {\n    return { count: 0, closeIndex: i };\n  }\n\n  count = 1;\n\n  for (; i < lineText.length; i += 1) {\n    const char = lineText[i];\n\n    if (char === '(') {\n      nested += 1;\n    } else if (char === ')') {\n      if (nested === 0) {\n        closeIndex = i;\n        break;\n      }\n      nested -= 1;\n    } else if (char === ',' && nested === 0) {\n      count += 1;\n    }\n  }\n\n  if (closeIndex === -1) {\n    return { count: null, closeIndex: lineText.length };\n  }\n\n  return { count, closeIndex };\n}\n\nfunction tokenAt(lineText, column) {\n  if (!lineText) {\n    return null;\n  }\n\n  if (!/[A-Za-z_]/.test(lineText[column] || '')) {\n    return null;\n  }\n\n  let start = column;\n  while (start > 0 && /[A-Za-z0-9_]/.test(lineText[start - 1])) {\n    start -= 1;\n  }\n\n  let end = column;\n  while (end < lineText.length && /[A-Za-z0-9_]/.test(lineText[end])) {\n    end += 1;\n  }\n\n  if (start === end) {\n    return null;\n  }\n\n  return {\n    name: lineText.slice(start, end),\n    start,\n    end,\n  };\n}\n\nexport function parseMiniLang(text) {\n  const lines = text.split('\\n');\n  const diagnostics = [];\n  const symbols = [];\n  const scopes = [];\n  const declarationTokens = new Set();\n\n  const globalScope = {\n    id: 'global',\n    startLine: 0,\n    endLine: Infinity,\n    depth: 0,\n    symbols: new Map(),\n  };\n\n  const activeScopes = [globalScope];\n  scopes.push(globalScope);\n\n  let depth = 0;\n\n  for (let line = 0; line < lines.length; line += 1) {\n    const lineText = lines[line];\n\n    const fnMatch = lineText.match(/^\\s*fn\\s+([A-Za-z_]\\w*)\\s*\\(([^)]*)\\)/);\n    if (fnMatch) {\n      const name = fnMatch[1];\n      const paramsText = fnMatch[2] || '';\n      const params = parseParams(paramsText);\n      const nameIndex = fnMatch.index + fnMatch[0].indexOf(name);\n\n      const fnSymbol = {\n        kind: 'function',\n        name,\n        params,\n        range: makeRange(lineText, line, nameIndex, name),\n        scopeId: `fn:${name}:${line}`,\n        declLine: line,\n      };\n\n      const currentScope = activeScopes[activeScopes.length - 1];\n      currentScope.symbols.set(name, fnSymbol);\n      symbols.push(fnSymbol);\n      declarationTokens.add(symbolKey(line, nameIndex, nameIndex + name.length));\n\n      const functionScope = {\n        id: fnSymbol.scopeId,\n        startLine: line,\n        endLine: Infinity,\n        depth: depth + 1,\n        symbols: new Map(),\n      };\n\n      const paramIndexBase = lineText.indexOf('(') + 1;\n      let cursor = 0;\n      for (const param of params) {\n        const paramStart = lineText.indexOf(param, paramIndexBase + cursor);\n        const paramEnd = paramStart + param.length;\n        const paramRange = makeRange(lineText, line, paramStart, param);\n        functionScope.symbols.set(param, {\n          kind: 'parameter',\n          name: param,\n          params: [],\n          range: paramRange,\n          scopeId: functionScope.id,\n          declLine: line,\n          declType: 'param',\n        });\n        cursor = paramEnd;\n        declarationTokens.add(symbolKey(line, paramStart, paramEnd));\n      }\n\n      symbols.push(...functionScope.symbols.values());\n      scopes.push(functionScope);\n      activeScopes.push(functionScope);\n    }\n\n","exit_code":0,"status":"completed"}}
