{"type":"item.completed","item":{"id":"item_34","type":"command_execution","command":"/bin/zsh -lc 'ls -la src && cat src/*'","aggregated_output":"total 32\ndrwxr-xr-x@ 3 danny  wheel     96 Jun  7 12:24 .\ndrwxr-xr-x@ 8 danny  wheel    256 Jun  7 12:29 ..\n-rw-r--r--@ 1 danny  staff  14813 Jun  7 12:32 server.mjs\nexport function encodeMessage(message) {\n  const payload = JSON.stringify(message);\n  const length = Buffer.byteLength(payload, 'utf8');\n  return `Content-Length: ${length}\\r\\n\\r\\n${payload}`;\n}\n\nexport class MessageBuffer {\n  constructor() {\n    this.buffer = '';\n  }\n\n  push(chunk) {\n    if (chunk instanceof Buffer) {\n      chunk = chunk.toString('utf8');\n    } else if (typeof chunk !== 'string') {\n      return [];\n    }\n\n    this.buffer += chunk;\n    const messages = [];\n\n    while (true) {\n      const headerEnd = this.buffer.indexOf('\\r\\n\\r\\n');\n      if (headerEnd === -1) {\n        break;\n      }\n\n      const header = this.buffer.slice(0, headerEnd);\n      const lines = header.split('\\r\\n');\n      const contentLengthLine = lines.find((line) => line.toLowerCase().startsWith('content-length:'));\n\n      if (!contentLengthLine) {\n        throw new Error('Invalid JSON-RPC framing: missing Content-Length');\n      }\n\n      const contentLength = Number(contentLengthLine.split(':')[1]?.trim());\n      if (!Number.isFinite(contentLength) || contentLength < 0) {\n        throw new Error('Invalid JSON-RPC framing: invalid Content-Length');\n      }\n\n      const bodyStart = headerEnd + 4;\n      const bodyEnd = bodyStart + contentLength;\n      if (this.buffer.length < bodyEnd) {\n        break;\n      }\n\n      const body = this.buffer.slice(bodyStart, bodyEnd);\n      this.buffer = this.buffer.slice(bodyEnd);\n\n      messages.push(JSON.parse(body));\n    }\n\n    return messages;\n  }\n}\n\nconst KEYWORDS = new Set(['fn', 'let', 'return']);\n\nfunction parseParams(paramText) {\n  return paramText\n    .split(',')\n    .map((param) => param.trim())\n    .filter(Boolean)\n    .map((param) => param.replace(/^([A-Za-z_][A-Za-z0-9_]*)\\b.*$/, '$1'))\n    .filter(Boolean);\n}\n\nfunction makeRange(lineText, line, start, name) {\n  return {\n    start: { line, character: start },\n    end: { line, character: start + name.length },\n  };\n}\n\nfunction makeDiagnostic(lineText, line, match, message) {\n  return {\n    message,\n    severity: 1,\n    range: {\n      start: { line, character: match.index },\n      end: { line, character: match.index + match[0].length },\n    },\n    source: lineText,\n  };\n}\n\nfunction symbolKey(line, from, to) {\n  return `${line}:${from}-${to}`;\n}\n\nfunction countCallArgs(lineText, openParenIndex) {\n  if (lineText[openParenIndex] !== '(') {\n    return { count: null, closeIndex: openParenIndex };\n  }\n\n  let count = 0;\n  let nested = 0;\n  let closeIndex = -1;\n  let i = openParenIndex + 1;\n\n  // Empty argument list.\n  while (i < lineText.length && /\\s/.test(lineText[i])) {\n    i += 1;\n  }\n\n  if (lineText[i] === ')') {\n    return { count: 0, closeIndex: i };\n  }\n\n  count = 1;\n\n  for (; i < lineText.length; i += 1) {\n    const char = lineText[i];\n\n    if (char === '(') {\n      nested += 1;\n    } else if (char === ')') {\n      if (nested === 0) {\n        closeIndex = i;\n        break;\n      }\n      nested -= 1;\n    } else if (char === ',' && nested === 0) {\n      count += 1;\n    }\n  }\n\n  if (closeIndex === -1) {\n    return { count: null, closeIndex: lineText.length };\n  }\n\n  return { count, closeIndex };\n}\n\nfunction tokenAt(lineText, column) {\n  if (!lineText) {\n    return null;\n  }\n\n  if (!/[A-Za-z_]/.test(lineText[column] || '')) {\n    return null;\n  }\n\n  let start = column;\n  while (start > 0 && /[A-Za-z0-9_]/.test(lineText[start - 1])) {\n    start -= 1;\n  }\n\n  let end = column;\n  while (end < lineText.length && /[A-Za-z0-9_]/.test(lineText[end])) {\n    end += 1;\n  }\n\n  if (start === en