{"type":"item.completed","item":{"id":"item_24","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' test/cache.visible.test.mjs\"","aggregated_output":"import assert from 'node:assert/strict';\nimport { test } from 'node:test';\nimport { AsyncCache } from '../src/cache.mjs';\n\ntest('loads then caches; a second sequential get does not reload', async () => {\n  const cache = new AsyncCache();\n  let calls = 0;\n  const loader = async (k) => { calls += 1; return `v:${k}`; };\n  assert.equal(await cache.get('a', loader), 'v:a');\n  assert.equal(await cache.get('a', loader), 'v:a');\n  assert.equal(calls, 1);\n  assert.equal(cache.has('a'), true);\n});\n\ntest('clear() drops cached values', async () => {\n  const cache = new AsyncCache();\n  const loader = async (k) => `v:${k}`;\n  await cache.get('a', loader);\n  cache.clear();\n  assert.equal(cache.has('a'), false);\n});\n\ntest('distinct keys load independently', async () => {\n  const cache = new AsyncCache();\n  const loader = async (k) => `v:${k}`;\n  assert.equal(await cache.get('a', loader), 'v:a');\n  assert.equal(await cache.get('b', loader), 'v:b');\n});\n\ntest('concurrent gets for the same key share one in-flight load', async () => {\n  const cache = new AsyncCache();\n  let calls = 0;\n  let resolveLoad;\n  const loader = async (k) => {\n    calls += 1;\n    return new Promise((resolve) => {\n      resolveLoad = () => resolve(`v:${k}`);\n    });\n  };\n\n  const first = cache.get('a', loader);\n  const second = cache.get('a', loader);\n  const third = cache.get('a', loader);\n\n  assert.equal(calls, 1);\n  resolveLoad();\n  assert.deepEqual(await Promise.all([first, second, third]), ['v:a', 'v:a', 'v:a']);\n  assert.equal(await cache.get('a', loader), 'v:a');\n  assert.equal(calls, 1);\n});\n\ntest('concurrent gets for different keys do not block each other', async () => {\n  const cache = new AsyncCache();\n  const started = [];\n  const resolvers = new Map();\n  const loader = async (k) => {\n    started.push(k);\n    return new Promise((resolve) => {\n      resolvers.set(k, () => resolve(`v:${k}`));\n    });\n  };\n\n  const first = cache.get('a', loader);\n  const second = cache.get('b', loader);\n\n  assert.deepEqual(started, ['a', 'b']);\n  resolvers.get('b')();\n  assert.equal(await second, 'v:b');\n  resolvers.get('a')();\n  assert.equal(await first, 'v:a');\n});\n\ntest('rejected in-flight loads are not cached and can be retried', async () => {\n  const cache = new AsyncCache();\n  let calls = 0;\n  let rejectLoad;\n  const error = new Error('load failed');\n  const loader = async (k) => {\n    calls += 1;\n    if (calls === 1) {\n      return new Promise((resolve, reject) => {\n        rejectLoad = () => reject(error);\n      });\n    }\n    return `v:${k}`;\n  };\n\n  const first = cache.get('a', loader);\n  const second = cache.get('a', loader);\n\n  assert.equal(calls, 1);\n  rejectLoad();\n  await assert.rejects(first, error);\n  await assert.rejects(second, error);\n  assert.equal(cache.has('a'), false);\n  assert.equal(await cache.get('a', loader), 'v:a');\n  assert.equal(calls, 2);\n});\n","exit_code":0,"status":"completed"}}
