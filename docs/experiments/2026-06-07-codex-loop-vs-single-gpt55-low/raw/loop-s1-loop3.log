visibleSymbols = parsed.symbols.filter((symbol) => (\n    symbol.scope === 'global' || (scope && symbol.scope === scope)\n  ));\n  const symbolItems = visibleSymbols.map((symbol) => ({\n    label: symbol.name,\n    kind: symbol.kind === 'function' ? 3 : 6,\n    detail: symbol.kind === 'function' ? `fn ${symbol.name}(${symbol.params.join(', ')})` : symbol.kind,\n  }));\n\n  return [\n    { label: 'fn', kind: 14, insertText: 'fn ${1:name}(${2:params}) {\\n\\t$0\\n}', insertTextFormat: 2 },\n    { label: 'let', kind: 14 },\n    { label: 'return', kind: 14 },\n    ...symbolItems,\n  ];\n}\n\nfunction scopeAt(text, position) {\n  let current = null;\n  const lines = text.split(/\\r?\\n/);\n\n  for (let line = 0; line <= position.line && line < lines.length; line += 1) {\n    const code = stripComment(lines[line]);\n    const fn = code.match(/^\\s*fn\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\([^)]*\\)\\s*\\{\\s*$/);\n    if (fn) current = fn[1];\n    if (code.trim() === '}') current = null;\n  }\n\n  return current;\n}\n\nfunction jsonResponse(id, result) {\n  return { jsonrpc: '2.0', id, result };\n}\n\nexport class MiniLangServer {\n  constructor() {\n    this.documents = new Map();\n    this.notifications = [];\n    this.shutdown = false;\n  }\n\n  async handle(message) {\n    if (message.method === 'initialize') return this.initialize(message.id);\n    if (message.method === 'shutdown') {\n      this.shutdown = true;\n      return jsonResponse(message.id, null);\n    }\n    if (message.method === 'exit') return null;\n    if (message.method === 'textDocument/didOpen') return this.didOpen(message.params.textDocument);\n    if (message.method === 'textDocument/didChange') return this.didChange(message.params);\n    if (message.method === 'textDocument/completion') return jsonResponse(message.id, this.completion(message.params.textDocument.uri, message.params.position));\n    if (message.method === 'textDocument/definition') return jsonResponse(message.id, this.definition(message.params.textDocument.uri, message.params.position));\n    if (message.method === 'textDocument/hover') return jsonResponse(message.id, this.hover(message.params.textDocument.uri, message.params.position));\n    return message.id === undefined ? null : jsonResponse(message.id, null);\n  }\n\n  initialize(id) {\n    return jsonResponse(id, {\n      capabilities: {\n        textDocumentSync: 2,\n        completionProvider: { triggerCharacters: [' ', '('] },\n        definitionProvider: true,\n        hoverProvider: true,\n      },\n    });\n  }\n\n  didOpen(textDocument) {\n    this.updateDocument(textDocument.uri, textDocument.text, textDocument.version);\n    return null;\n  }\n\n  didChange(params) {\n    const doc = this.documents.get(params.textDocument.uri);\n    let text = doc?.text ?? '';\n    for (const change of params.contentChanges ?? []) {\n      text = applyTextChange(text, change);\n    }\n    this.updateDocument(params.textDocument.uri, text, params.textDocument.version);\n    return null;\n  }\n\n  updateDocument(uri, text, version) {\n    const parsed = parseMiniLang(text);\n    this.documents.set(uri, { uri, text, version, parsed });\n    this.notifications.push({\n      jsonrpc: '2.0',\n      method: 'textDocument/publishDiagnostics',\n      params: { uri, version, diagnostics: parsed.diagnostics },\n    });\n  }\n\n  takeNotifications() {\n    const out = this.notifications;\n    this.notifications = [];\n    return out;\n  }\n\n  getDiagnostics(uri) {\n    return this.documents.get(uri)?.parsed.diagnostics ?? [];\n  }\n\n  completion(uri, position = { line: 0, character: 0 }) {\n    const doc = this.documents.get(uri);\n    const parsed = doc?.parsed ?? parseMiniLang('');\n    return completionItems(parsed, doc ? scopeAt(doc.text, position) : null);\n  }\n\n  definition(uri, position) {\n    const doc = this.documents.get(uri);\n    const found = doc && wordAt(doc.text, position);\n    const symbol = found && this.resolveAt(doc.parsed, found.name,