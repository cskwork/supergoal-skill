-Za-z0-9_]*\\s*\\(([^)]*)\\)/);\n   156\t    const actual = call ? splitArgs(call[1]).length : 0;\n   157\t    const expected = symbol.params?.length ?? 0;\n   158\t    if (symbol.kind !== 'function') {\n   159\t      diagnostics.push(diagnostic(ref.range, `'${ref.name}' is not callable`));\n   160\t    } else if (actual !== expected) {\n   161\t      diagnostics.push(diagnostic(ref.range, `Function '${ref.name}' expects ${expected} arguments but got ${actual}`));\n   162\t    }\n   163\t  };\n   164\t\n   165\t  for (let line = 0; line < lines.length; line += 1) {\n   166\t    const raw = lines[line];\n   167\t    const code = stripComment(raw);\n   168\t    const trimmed = code.trim();\n   169\t    const base = code.search(/\\S|$/);\n   170\t    if (!trimmed) continue;\n   171\t\n   172\t    if (trimmed === '}') {\n   173\t      if (currentFunction) scopes.pop();\n   174\t      currentFunction = null;\n   175\t      continue;\n   176\t    }\n   177\t\n   178\t    const fn = code.match(/^\\s*fn\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^)]*)\\)\\s*\\{\\s*$/);\n   179\t    if (fn) {\n   180\t      const nameStart = code.indexOf(fn[1]);\n   181\t      const params = splitArgs(fn[2]).filter(Boolean);\n   182\t      const symbol = declare({\n   183\t        name: fn[1],\n   184\t        kind: 'function',\n   185\t        params,\n   186\t        range: range(line, nameStart, nameStart + fn[1].length),\n   187\t        scope: 'global',\n   188\t      });\n   189\t      currentFunction = symbol;\n   190\t      scopes.push(new Map());\n   191\t      for (const param of params) {\n   192\t        const start = code.indexOf(param, code.indexOf('('));\n   193\t        declare({ name: param, kind: 'parameter', range: range(line, start, start + param.length), scope: symbol.name });\n   194\t      }\n   195\t      continue;\n   196\t    }\n   197\t\n   198\t    const letDecl = code.match(/^\\s*let\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.+)$/);\n   199\t    if (letDecl) {\n   200\t      const nameStart = code.indexOf(letDecl[1]);\n   201\t      declare({\n   202\t        name: letDecl[1],\n   203\t        kind: 'variable',\n   204\t        range: range(line, nameStart, nameStart + letDecl[1].length),\n   205\t        scope: currentFunction?.name ?? 'global',\n   206\t      });\n   207\t      const exprStart = code.indexOf(letDecl[2]);\n   208\t      validateExpression(letDecl[2], line, exprStart);\n   209\t      continue;\n   210\t    }\n   211\t\n   212\t    const ret = code.match(/^\\s*return(?:\\s+(.+))?$/);\n   213\t    if (ret) {\n   214\t      if (!currentFunction) {\n   215\t        diagnostics.push(diagnostic(range(line, base, base + 6), 'Return outside function'));\n   216\t      }\n   217\t      if (ret[1]) validateExpression(ret[1], line, code.indexOf(ret[1]));\n   218\t      continue;\n   219\t    }\n   220\t\n   221\t    validateExpression(trimmed, line, base);\n   222\t    diagnostics.push(diagnostic(range(line, base, code.length), `Could not parse statement: ${trimmed}`));\n   223\t  }\n   224\t\n   225\t  if (currentFunction) {\n   226\t    diagnostics.push(diagnostic(currentFunction.range, `Function '${currentFunction.name}' is missing closing '}'`));\n   227\t  }\n   228\t\n   229\t  return { text, diagnostics, symbols, references };\n   230\t}\n   231\t\n   232\tfunction completionItems(parsed) {\n   233\t  const symbolItems = parsed.symbols.map((symbol) => ({\n   234\t    label: symbol.name,\n   235\t    kind: symbol.kind === 'function' ? 3 : 6,\n   236\t    detail: symbol.kind === 'function' ? `fn ${symbol.name}(${symbol.params.join(', ')})` : symbol.kind,\n   237\t  }));\n   238\t\n   239\t  return [\n   240\t    { label: 'fn', kind: 14, insertText: 'fn ${1:name}(${2:params}) {\\n\\t$0\\n}', insertTextFormat: 2 },\n   241\t    { label: 'let', kind: 14 },\n   242\t    { label: 'return', kind: 14 },\n   243\t    ...symbolItems,\n   244\t  ];\n   245\t}\n   246\t\n   247\tfunction jsonResponse(id, result) {\n   248\t  return { jsonrpc: '2.0', id, result };\n   249\t}\n   250\t\n   251\texport class MiniLangServer {\n   252\t  constructor() {\n   253\t    this.documents = new Map();\n   254\t    this.notifications = [];\n   255\t    this.shutdown = false;\n   256\t  }\n   257\t\n   258\t  async handle(message) {\n   259\t    if (message.method === 'initialize') return this.initialize(message.id);\n   260\t    if (message.method === 'shutdown') {\n   261\t      this.shutdown = true;\n   262\t      return jsonResponse(message.id, null);\n   263\t    }\n   264\t    if (message.method === 'exit') return null;\n   265\t    if (message.method === 'textDocument/didOpen') return this.didOpen(message.params.textDocument);\n   266\t    if (message.method === 'textDocument/didChange') return this.didChange(message.params);\n   267\t    if (message.method === 'textDocument/completion') return jsonResponse(message.id, this.completion(message.params.textDocument.uri));\n   268\t    if (message.method === 'textDocument/definition') return jsonResponse(message.id, this.definition(message.params.textDocument.uri, message.params.position));\n   269\t    if (message.method === 'textDocument/hover') return jsonResponse(message.id, this.hover(message.params.textDocument.uri, message.params.position));\n   270\t    return message.id === undefined ? null : jsonResponse(message.id, null);\n   271\t  }\n   272\t\n   273\t  initialize(id) {\n   274\t    return jsonResponse(id, {\n   275\t      capabilities: {\n   276\t        textDocumentSync: 2,\n   277\t        completionProvider: { triggerCharacters: [' ', '('] },\n   278\t        definitionProvider: true,\n   279\t        hoverProvider: true,\n   280\t      },\n   281\t    });\n   282\t  }\n   283\t\n   284\t  didOpen(textDocument) {\n   285\t    this.updateDocument(textDocument.uri, textDocument.text, textDocument.version);\n   286\t    return null;\n   287\t  }\n   288\t\n   289\t  didChange(params) {\n   290\t    const doc = this.documents.get(params.textDocument.uri);\n   291\t    let text = doc?.text ?? '';\n   292\t    for (const change of params.contentChanges ?? []) {\n   293\t      text = applyTextChange(text, change);\n   294\t    }\n   295\t    this.updateDocument(params.textDocument.uri, text, params.textDocument.version);\n   296\t    return null;\n   297\t  }\n   298\t\n   299\t  updateDocument(uri, text, version) {\n   300\t    const parsed = parseMiniLang(text);\n   301\t    this.documents.set(uri, { uri, text, version, parsed });\n   302\t    this.notifications.push({\n   303\t      jsonrpc: '2.0',\n   304\t      method: 'textDocument/publishDiagnostics',\n   305\t      params: { uri, version, diagnostics: parsed.diagnostics },\n   306\t    });\n   307\t  }\n   308\t\n   309\t  takeNotifications() {\n   310\t    const out = this.notifications;\n   311\t    this.notifications = [];\n   312\t    return out;\n   313\t  }\n   314\t\n   315\t  getDiagnostics(uri) {\n   316\t    return this.documents.get(uri)?.parsed.diagnostics ?? [];\n   317\t  }\n   318\t\n   319\t  completion(uri) {\n   320\t    return completionItems(this.documents.get(uri)?.parsed ?? parseMiniLang(''));\n   321\t  }\n   322\t\n   323\t  definition(uri, position) {\n   324\t    const doc = this.documents.get(uri);\n   325\t    const found = doc && wordAt(doc.text, position);\n   326\t    const symbol = found && this.resolveAt(doc.parsed, found.name, found.range);\n   327\t    return symbol ? { uri, range: symbol.range } : null;\n   328\t  }\n   329\t\n   330\t  hover(uri, position) {\n   331\t    const doc = this.documents.get(uri);\n   332\t    const found = doc && wordAt(doc.text, position);\n   333\t    const symbol = found && this.resolveAt(doc.parsed, found.name, found.range);\n   334\t    if (!symbol) return null;\n   335\t    const value = symbol.kind === 'function'\n   336\t      ? `fn ${symbol.name}(${symbol.params.join(', ')})`\n   337\t      : `${symbol.kind} ${symbol.name}`;\n   338\t    return { contents: { kind: 'markdown', value }, range: found.range };\n   339\t  }\n   340\t\n   341\t  resolveAt(parsed, name, useRange = null) {\n   342\t    const ref = useRange && parsed.references.find((item) => sameRange(item.range, useRange));\n   343\t    if (ref?.symbol) return ref.symbol;\n   344\t    const exact = useRange && parsed.symbols.find((symbol) => sameRange(symbol.range, useRange));\n   345\t    if (exact) return exact;\n   346\t    return parsed.symbols.find((symbol) => symbol.name === name && symbol.kind === 'function')\n   347\t      ?? parsed.symbols.find((symbol) => symbol.name === name)\n   348\t      ?? null;\n   349\t  }\n   350\t}\n   351\t\n   352\tfunction sameRange(left, right) {\n   353\t  return left.start.line === right.start.line\n   354\t    && left.start.character === right.start.character\n   355\t    && left.end.line === right.end.line\n   356\t    && left.end.character === right.end.character;\n   357\t}\n   358\t\n   359\texport default { encodeMessage, MessageBuffer, parseMiniLang, MiniLangServer };\n","exit_code":0,"status":"completed"}}
