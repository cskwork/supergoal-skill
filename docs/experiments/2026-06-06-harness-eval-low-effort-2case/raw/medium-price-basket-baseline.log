diff --git a/src/priceBasket.mjs b/src/priceBasket.mjs
index cafc98be653b34db6f75f6b3dc6218aeb43fc64f..97301470a8330228e185b825ded771782660769e
--- a/src/priceBasket.mjs
+++ b/src/priceBasket.mjs
@@ -1,3 +1,99 @@
 export function priceBasket(items, rules = {}) {
-  return { subtotalCents: 0, discountCents: 0, taxCents: 0, shippingCents: 0, totalCents: 0 };
+  validateItems(items);
+  validateRules(rules);
+
+  let subtotalCents = 0;
+  let discountCents = 0;
+  let taxableCents = 0;
+
+  for (const item of items) {
+    const lineSubtotalCents = item.unitCents * item.quantity;
+    const discountBps = rules.categoryDiscountsBps?.[item.category] ?? 0;
+    const lineDiscountCents = Math.floor((lineSubtotalCents * discountBps) / 10000);
+    const discountedLineCents = lineSubtotalCents - lineDiscountCents;
+
+    subtotalCents += lineSubtotalCents;
+    discountCents += lineDiscountCents;
+
+    if (item.taxable) {
+      taxableCents += discountedLineCents;
+    }
+  }
+
+  const discountedSubtotalCents = subtotalCents - discountCents;
+  const taxCents = Math.round((taxableCents * (rules.taxRateBps ?? 0)) / 10000);
+  const shippingCents =
+    discountedSubtotalCents >= (rules.freeShippingThresholdCents ?? Infinity)
+      ? 0
+      : rules.shippingCents ?? 0;
+  const totalCents = discountedSubtotalCents + taxCents + shippingCents;
+
+  return { subtotalCents, discountCents, taxCents, shippingCents, totalCents };
+}
+
+function validateItems(items) {
+  if (!Array.isArray(items)) {
+    throw new TypeError('items must be an array');
+  }
+
+  for (const [index, item] of items.entries()) {
+    if (!isPlainObject(item)) {
+      throw new TypeError(`items[${index}] must be an object`);
+    }
+
+    assertInteger(item.unitCents, `items[${index}].unitCents`, { min: 0 });
+    assertInteger(item.quantity, `items[${index}].quantity`, { min: 1 });
+
+    if (typeof item.category !== 'string' || item.category.length === 0) {
+      throw new TypeError(`items[${index}].category must be a non-empty string`);
+    }
+
+    if (typeof item.taxable !== 'boolean') {
+      throw new TypeError(`items[${index}].taxable must be a boolean`);
+    }
+  }
+}
+
+function validateRules(rules) {
+  if (!isPlainObject(rules)) {
+    throw new TypeError('rules must be an object');
+  }
+
+  assertOptionalInteger(rules.taxRateBps, 'rules.taxRateBps', { min: 0 });
+  assertOptionalInteger(rules.shippingCents, 'rules.shippingCents', { min: 0 });
+  assertOptionalInteger(rules.freeShippingThresholdCents, 'rules.freeShippingThresholdCents', {
+    min: 0,
+  });
+
+  if (rules.categoryDiscountsBps === undefined) {
+    return;
+  }
+
+  if (!isPlainObject(rules.categoryDiscountsBps)) {
+    throw new TypeError('rules.categoryDiscountsBps must be an object');
+  }
+
+  for (const [category, discountBps] of Object.entries(rules.categoryDiscountsBps)) {
+    if (category.length === 0) {
+      throw new TypeError('rules.categoryDiscountsBps categories must be non-empty strings');
+    }
+
+    assertInteger(discountBps, `rules.categoryDiscountsBps.${category}`, { min: 0, max: 10000 });
+  }
+}
+
+function assertOptionalInteger(value, label, range) {
+  if (value !== undefined) {
+    assertInteger(value, label, range);
+  }
+}
+
+function assertInteger(value, label, { min, max = Infinity }) {
+  if (!Number.isInteger(value) || value < min || value > max) {
+    throw new TypeError(`${label} must be an integer from ${min} to ${max}`);
+  }
+}
+
+function isPlainObject(value) {
+  return value !== null && typeof value === 'object' && !Array.isArray(value);
 }

